@@ -0,0 +1,1596 @@
+//! **ML-DSA-87 verify FRONT stage, JOINED into the matvec through the forward NTT** — closes the
+//! front-side gap for ẑ: the matvec-tail (`expanda_chain_matvec.rs`) consumed ẑ/ĉ/t̂1 (NTT-domain)
+//! as INPUT publics that were REPRESENTATIVE canonical residues (a documented deferred gap). This
+//! file lands the forward-NTT stage that PRODUCES ẑ = NTT(z) from a coefficient-domain z, and BINDS
+//! it into the matvec's ẑ INPUT, so the matvec's ẑ is no longer representative but the REAL forward
+//! NTT of a z:
+//!
+//! ```text
+//!   z ──forwardNTT──▶ ẑ   ──Tie──▶   ẑ ──[matvec Â∘ẑ − ĉ∘(t̂1·2^d)]──▶ ŵ_i
+//!   (Leg F, THIS FILE's            (Leg M, matvec front,
+//!    new front stage)               expanda_chain_matvec)
+//! ```
+//!
+//! This is the FORWARD partner of the invNTT bridge (`verify_tail_join.rs`, 0a70ac3): that file
+//! ported the n=8 Gentleman-Sande inverse as a batch-STARK leg and tied `w = invNTT(ŵ)` into the
+//! accept tail. Here we MIRROR that for the forward Cooley-Tukey n=8 NTT (`ntt_wired8_air.rs`, the
+//! forward CT partner) and tie `ẑ = NTT(z)` into the matvec's ẑ INPUT.
+//!
+//!   - **Leg F — forward NTT** (NEW; the COMPLETE Cooley-Tukey **n=8** forward NTT over Z_q, VERBATIM
+//!     CT constraints ported from `docs/bench/plonky3-shield-air/ntt_wired8_air.rs` — the reduced
+//!     partner of the proven 256-pt `ntt_wired256_air.rs`): 12 CT butterflies across all 3 layers
+//!     with FULL in-AIR cross-layer routing (every layer's inputs constrained == the previous layer's
+//!     outputs, every twiddle pinned to the canonical n=8 ζ = ψ^brv3(k), ψ=1753^32). Exposes the
+//!     coefficient-domain **z INPUT** publics [0..8] and the NTT-domain **ẑ OUTPUT** publics [8..16].
+//!     Validated to BE the n=8 NTT via the convolution theorem `NTT(f)∘NTT(g) == NTT(f·g mod x⁸+1)`
+//!     and the forward/inverse round-trip `invNTT(NTT(x)) == x`, coefficient-exact vs the `ntt_zq.rs`
+//!     reference oracle. No n⁻¹ scaling — that normalization belongs to the inverse transform only.
+//!   - **Leg M — matvec front** (`ExpandaPlaceAir`, VERBATIM from `expanda_chain_matvec.rs`): placed
+//!     Â∘ẑ − ĉ∘(t̂1·2^d), consuming ẑ as INPUT publics (`PI_Z_M`). Real libcrux seed-5 ρ.
+//!
+//!   - **Tie (front↔matvec)**: `Leg-F ẑ[k] (OUTPUT) == Leg-M ẑ_in[k] (INPUT, PI_Z_M)` for k in 0..8.
+//!     An ALU `sub` asserted zero (each surfaced public read once — a direct `connect` breaks the
+//!     Public-table LogUp, exactly as the sibling chains).
+//!
+//! ## Scope (REDUCED-BUT-REAL)
+//!   - Leg F is the COMPLETE n=8 CT transform (not a partial slice): all 12 butterflies, 3 layers,
+//!     real pinned twiddles. n=8 (not 256) is the reduced point count the invNTT bridge blessed; the
+//!     256-pt wiring is the same pattern (`ntt_wired256_air.rs`, already proven as a uni-stark AIR)
+//!     generalized by the multi-row lookup, out of scope here.
+//!   - The 8 ẑ coefficients that flow Leg F → matvec are bound by the tie; matvec consumes NM=64 ẑ
+//!     (the untied remainder [8..64] is representative). The ẑ tied into matvec is Leg F's REAL
+//!     forward NTT of a coefficient-domain z; ẑ = NTT(z) is diff-tested exact.
+//!   - ĉ = NTT(c) and t̂1 = NTT(t1) are the IDENTICAL mechanism (a forward NTT leg + a tie into the
+//!     matvec's ĉ / t̂1 inputs); ẑ is done here as the exemplar.
+//!
+//! ## Cases (all in one run)
+//!   1. HONEST (ẑ tied into matvec = REAL NTT(z)): outer prove+verify SUCCEEDS = the front stage is
+//!      recursion-composed and bound into the matvec.
+//!   2. NEG-ZH (feed matvec a ẑ inconsistent with NTT(z)): the tie mismatch → REJECTS at prove.
+//!   3. NEG-BF (tamper one Leg F butterfly output): Leg F's own cross-layer routing is violated →
+//!      Leg F native batch verify REJECTS.
+//!
+//! ```bash
+//! cargo run --release --example front_ntt_join
+//! ```
+
+#[macro_use]
+mod common;
+use common::*;
+
+use p3_air::{Air, AirBuilder, BaseAir, WindowAccess};
+use p3_batch_stark::{BatchProof, ProverData, StarkInstance, prove_batch, verify_batch};
+use p3_circuit_prover::{AirVariant, RecomposePreprocessor, recompose_air_builders};
+use p3_field::PrimeField64;
+use std::time::Instant;
+use tiny_keccak::{Hasher, Shake};
+
+fn main() {
+    init_logger();
+    kb::run();
+}
+
+mod kb {
+    // The matvec / usehint modules are copied VERBATIM from the sibling examples; a few of their
+    // host reference helpers (matvec_ref / m / mulq / ahat_read_cell / psum_cell / QI_M) are the
+    // diff-test oracles those files use but this join does not — kept for byte-fidelity.
+    #![allow(dead_code)]
+    use super::*;
+
+    // KoalaBear, D=4, W=16 Poseidon2 — same field/hash plumbing as `expanda_chain_matvec` /
+    // `accept_tail` (the GS invNTT gadget is generic over PrimeField64; q < 2^23 ≪ KoalaBear p,
+    // so every limb/product value stores exactly and the BabyBear-authored gadget is byte-for-byte
+    // the same constraint system over KoalaBear).
+    define_field_module_types!(
+        p3_koala_bear::KoalaBear,
+        p3_koala_bear::Poseidon2KoalaBear<16>,
+        p3_koala_bear::default_koalabear_poseidon2_16,
+        Poseidon2Config::KOALA_BEAR_D4_W16,
+        p3_poseidon2_circuit_air::KoalaBearD4Width16,
+        4,
+        16,
+        8,
+        8,
+        enable_poseidon2_perm,
+        p3_koala_bear::default_koalabear_poseidon2_16,
+        16,
+        8,
+        enable_recompose,
+        generate_poseidon2_trace,
+        p3_circuit::ops::Poseidon2Params
+    );
+
+    // ---- shared constants ----
+    const Q: u64 = 8380417; // ML-DSA / Dilithium modulus (matvec uses u64 form)
+    const QI: i64 = Q as i64; // i64 form (UseHint / invNTT reference arithmetic)
+    const N: usize = 256; // coefficients per poly (matvec candidate placement)
+    const CBUD: usize = 320; // per-entry candidate budget (matvec Leg-B pack tie)
+    const STREAM_BYTES: usize = 3 * CBUD; // 960 candidate bytes per ExpandA entry
+    const I_ROW: usize = 0; // shipped ExpandA output row index i
+
+    // UseHint / Decompose constants (FIPS-204 ML-DSA-87)
+    const GAMMA2: i64 = (QI - 1) / 32; // 261888
+    const G2: i64 = 2 * GAMMA2; // 523776
+    const MM: i64 = 16; // (q-1)/(2γ2)
+    const KB_P: i64 = 2130706433; // KoalaBear prime (is-zero-witness modulus for Leg U)
+    const NW1: usize = 256; // one poly's worth of w / w1 (reduced-but-real)
+
+    const NJOIN: usize = 8; // coefficients carried matvec→invNTT→UseHint (= the n=8 invNTT width)
+    const SECURITY: usize = 100;
+    // =======================================================================================
+    // LEG F — forward NTT (the FRONT stage). COMPLETE Cooley-Tukey n=8 forward NTT over Z_q with
+    // FULL in-AIR cross-layer routing (CT constraints VERBATIM from ntt_wired8_air.rs, the reduced
+    // partner of the proven 256-pt ntt_wired256_air.rs). Exposes z INPUT publics [0..8] and the
+    // ẑ = NTT(z) OUTPUT publics [8..16]. No n⁻¹ scaling (that belongs to the inverse transform).
+    // =======================================================================================
+    pub mod ntt {
+        use super::*;
+
+        const BETA: u64 = 4096;
+        const Q1: u64 = 2046;
+
+        // one CT butterfly's 38 primary columns (VERBATIM layout from ntt_wired8_air.rs) then bits.
+        const Z0: usize = 0;
+        const Z1: usize = 1;
+        const B0: usize = 2;
+        const B1: usize = 3;
+        const MC0: usize = 4;
+        const MC1: usize = 5;
+        const T0: usize = 6;
+        const T1: usize = 7;
+        const KL0: usize = 8;
+        const KL1: usize = 9;
+        const KL2: usize = 10;
+        const KR0: usize = 11;
+        const KR1: usize = 12;
+        const KR2: usize = 13;
+        const L0: usize = 14;
+        const L1: usize = 15;
+        const L2: usize = 16;
+        const M0: usize = 17;
+        const M1: usize = 18;
+        const M2: usize = 19;
+        const GT0: usize = 20;
+        const GT1: usize = 21;
+        const GM0: usize = 22;
+        const GM1: usize = 23;
+        const A0: usize = 24;
+        const A1: usize = 25;
+        const O00: usize = 26;
+        const O01: usize = 27;
+        const O10: usize = 28;
+        const O11: usize = 29;
+        const KO0: usize = 30;
+        const KO1: usize = 31;
+        const GA0: usize = 32;
+        const GA1: usize = 33;
+        const GO00: usize = 34;
+        const GO01: usize = 35;
+        const GO10: usize = 36;
+        const GO11: usize = 37;
+        const NP: usize = 38;
+        const WIDTHS: [usize; NP] = [
+            12, 11, 12, 11, 12, 11, 12, 11, 12, 13, 11, 2, 13, 11, 12, 12, 12, 12, 12, 12, 12, 11, 12, 11, 12, 11, 12, 11,
+            12, 11, 1, 1, 12, 11, 12, 11, 12, 11,
+        ];
+        const BF_COLS: usize = 460; // 38 primary + 422 bits
+        // 12 CT butterflies of the n=8 forward (3 layers × 4). No scaling stage (forward has no n⁻¹).
+        const NBF: usize = 12;
+        pub const NUM_COLS: usize = NBF * BF_COLS; // 5520
+        // butterfly bases in schedule order:
+        //   layer1 (len=4): bf0=(0,4) bf1=(1,5) bf2=(2,6) bf3=(3,7)
+        //   layer2 (len=2): bf4=(0,2) bf5=(1,3) bf6=(4,6) bf7=(5,7)
+        //   layer3 (len=1): bf8=(0,1) bf9=(2,3) bf10=(4,5) bf11=(6,7)
+        const BASE: [usize; NBF] = {
+            let mut b = [0usize; NBF];
+            let mut i = 0;
+            while i < NBF {
+                b[i] = i * BF_COLS;
+                i += 1;
+            }
+            b
+        };
+
+        fn bit_off(col: usize) -> usize {
+            NP + WIDTHS[..col].iter().sum::<usize>()
+        }
+
+        // ---- public values: z INPUT [0..8] then ẑ OUTPUT [8..16] ----
+        pub const PI_Z: usize = 0;
+        pub const PI_ZHAT: usize = NJOIN;
+        pub const NUM_PIS: usize = 2 * NJOIN;
+
+        pub fn height() -> usize {
+            64 // ≥ 2^6 FRI foldability floor; every row carries the same full transform
+        }
+        pub fn num_pis() -> usize {
+            NUM_PIS
+        }
+
+        /// The 8 layer-1 INPUT ports (z position p) as (butterfly, is_b):
+        /// bf0=(pos0,pos4) bf1=(pos1,pos5) bf2=(pos2,pos6) bf3=(pos3,pos7) — so p<4 is bf_p.a,
+        /// p≥4 is bf_{p-4}.b.
+        fn in_port(p: usize) -> (usize, bool) {
+            if p < 4 { (p, false) } else { (p - 4, true) }
+        }
+        /// The layer-3 OUTPUT at natural position p as (butterfly, is_out1):
+        /// pos0=bf8.out0,pos1=bf8.out1,…,pos6=bf11.out0,pos7=bf11.out1.
+        fn out_port(p: usize) -> (usize, bool) {
+            (8 + p / 2, p % 2 == 1)
+        }
+
+        /// The AIR carries the seven canonical n=8 twiddles ζ[k]=ψ^brv3(k), ψ=1753^32.
+        #[derive(Clone)]
+        pub struct NttAir {
+            pub zetas: [u64; 7],
+        }
+
+        impl<F: PrimeField64> BaseAir<F> for NttAir {
+            fn width(&self) -> usize {
+                NUM_COLS
+            }
+            fn num_public_values(&self) -> usize {
+                num_pis()
+            }
+            fn max_constraint_degree(&self) -> Option<usize> {
+                Some(2)
+            }
+        }
+
+        impl<AB: AirBuilder> Air<AB> for NttAir
+        where
+            AB::F: PrimeField64,
+        {
+            fn eval(&self, builder: &mut AB) {
+                let one = AB::Expr::ONE;
+                let beta = AB::Expr::from_u64(BETA);
+                let q1 = AB::Expr::from_u64(Q1);
+                let q = AB::Expr::from_u64(Q);
+                let qm1 = AB::Expr::from_u64(Q - 1);
+                let pis: Vec<AB::Expr> =
+                    (0..num_pis()).map(|k| builder.public_values()[k].into()).collect();
+                let main = builder.main();
+                let row = main.current_slice();
+                let e = |i: usize| -> AB::Expr { row[i].into() };
+
+                // ---- each CT butterfly (all 12): the proven gadget, VERBATIM from ntt_wired8_air.rs ----
+                for &b in BASE.iter() {
+                    for c in 0..NP {
+                        let bo = b + bit_off(c);
+                        let mut acc = AB::Expr::ZERO;
+                        let mut w = AB::Expr::ONE;
+                        for j in 0..WIDTHS[c] {
+                            let bit: AB::Expr = row[bo + j].into();
+                            builder.assert_zero(bit.clone() * (bit.clone() - one.clone()));
+                            acc = acc + bit * w.clone();
+                            w = w.clone() + w.clone();
+                        }
+                        builder.assert_eq(e(b + c), acc);
+                    }
+                    // mod-q multiply t = ζ·b (limb carry chain)
+                    builder.assert_eq(e(b + Z0) * e(b + B0), e(b + L0) + beta.clone() * e(b + KL0));
+                    builder.assert_eq(
+                        e(b + Z0) * e(b + B1) + e(b + Z1) * e(b + B0) + e(b + KL0),
+                        e(b + L1) + beta.clone() * e(b + KL1),
+                    );
+                    builder.assert_eq(e(b + Z1) * e(b + B1) + e(b + KL1), e(b + L2) + beta.clone() * e(b + KL2));
+                    builder.assert_eq(e(b + MC0) + e(b + T0), e(b + M0) + beta.clone() * e(b + KR0));
+                    builder.assert_eq(
+                        e(b + MC0) * q1.clone() + e(b + MC1) + e(b + T1) + e(b + KR0),
+                        e(b + M1) + beta.clone() * e(b + KR1),
+                    );
+                    builder.assert_eq(e(b + MC1) * q1.clone() + e(b + KR1), e(b + M2) + beta.clone() * e(b + KR2));
+                    builder.assert_eq(e(b + L0), e(b + M0));
+                    builder.assert_eq(e(b + L1), e(b + M1));
+                    builder.assert_eq(e(b + L2), e(b + M2));
+                    builder.assert_eq(e(b + KL2), e(b + KR2));
+
+                    let t_val = e(b + T0) + beta.clone() * e(b + T1);
+                    let a_val = e(b + A0) + beta.clone() * e(b + A1);
+                    let out0 = e(b + O00) + beta.clone() * e(b + O01);
+                    let out1 = e(b + O10) + beta.clone() * e(b + O11);
+                    let m_val = e(b + MC0) + beta.clone() * e(b + MC1);
+                    // add/sub: out0 = a + t, out1 = a − t  (t = ζ·b)
+                    builder.assert_eq(a_val.clone() + t_val.clone(), out0.clone() + e(b + KO0) * q.clone());
+                    builder.assert_eq(a_val.clone() + e(b + KO1) * q.clone(), t_val.clone() + out1.clone());
+                    // ranges
+                    let slack = |lo: usize, hi: usize| -> AB::Expr { e(b + lo) + beta.clone() * e(b + hi) };
+                    builder.assert_eq(t_val + slack(GT0, GT1), qm1.clone());
+                    builder.assert_eq(m_val + slack(GM0, GM1), qm1.clone());
+                    builder.assert_eq(a_val + slack(GA0, GA1), qm1.clone());
+                    builder.assert_eq(out0 + slack(GO00, GO01), qm1.clone());
+                    builder.assert_eq(out1 + slack(GO10, GO11), qm1.clone());
+                }
+
+                // ---- pin each butterfly's twiddle to the canonical ζ (VERBATIM forward schedule) ----
+                // layer1 (k=1): ζ[0]; layer2 (k=2,3): ζ[1],ζ[2]; layer3 (k=4..7): ζ[3..7].
+                let pin = |builder: &mut AB, b: usize, zeta: u64| {
+                    builder.assert_eq(e(b + Z0) + beta.clone() * e(b + Z1), AB::Expr::from_u64(zeta));
+                };
+                pin(builder, BASE[0], self.zetas[0]);
+                pin(builder, BASE[1], self.zetas[0]);
+                pin(builder, BASE[2], self.zetas[0]);
+                pin(builder, BASE[3], self.zetas[0]);
+                pin(builder, BASE[4], self.zetas[1]);
+                pin(builder, BASE[5], self.zetas[1]);
+                pin(builder, BASE[6], self.zetas[2]);
+                pin(builder, BASE[7], self.zetas[2]);
+                pin(builder, BASE[8], self.zetas[3]);
+                pin(builder, BASE[9], self.zetas[4]);
+                pin(builder, BASE[10], self.zetas[5]);
+                pin(builder, BASE[11], self.zetas[6]);
+
+                // ---- CROSS-LAYER WIRING (VERBATIM ntt_wired8): each layer's inputs == prev layer's
+                // outputs. out0=(O00,O01), out1=(O10,O11); inputs a=(A0,A1), b=(B0,B1). ----
+                let wire = |builder: &mut AB, db: usize, d_lo: usize, d_hi: usize, sb: usize, s_lo: usize, s_hi: usize| {
+                    builder.assert_eq(e(db + d_lo), e(sb + s_lo));
+                    builder.assert_eq(e(db + d_hi), e(sb + s_hi));
+                };
+                let (bf0, bf1, bf2, bf3) = (BASE[0], BASE[1], BASE[2], BASE[3]);
+                let (bf4, bf5, bf6, bf7) = (BASE[4], BASE[5], BASE[6], BASE[7]);
+                let (bf8, bf9, bf10, bf11) = (BASE[8], BASE[9], BASE[10], BASE[11]);
+                // layer2 reads layer1 outputs:
+                wire(builder, bf4, A0, A1, bf0, O00, O01);
+                wire(builder, bf4, B0, B1, bf2, O00, O01);
+                wire(builder, bf5, A0, A1, bf1, O00, O01);
+                wire(builder, bf5, B0, B1, bf3, O00, O01);
+                wire(builder, bf6, A0, A1, bf0, O10, O11);
+                wire(builder, bf6, B0, B1, bf2, O10, O11);
+                wire(builder, bf7, A0, A1, bf1, O10, O11);
+                wire(builder, bf7, B0, B1, bf3, O10, O11);
+                // layer3 reads layer2 outputs:
+                wire(builder, bf8, A0, A1, bf4, O00, O01);
+                wire(builder, bf8, B0, B1, bf5, O00, O01);
+                wire(builder, bf9, A0, A1, bf4, O10, O11);
+                wire(builder, bf9, B0, B1, bf5, O10, O11);
+                wire(builder, bf10, A0, A1, bf6, O00, O01);
+                wire(builder, bf10, B0, B1, bf7, O00, O01);
+                wire(builder, bf11, A0, A1, bf6, O10, O11);
+                wire(builder, bf11, B0, B1, bf7, O10, O11);
+
+                // ---- IO binding on the first row: z INPUT and ẑ OUTPUT to the surfaced publics ----
+                let mut wf = builder.when_first_row();
+                for p in 0..NJOIN {
+                    let (ibf, is_b) = in_port(p);
+                    let ib = BASE[ibf];
+                    let (lo, hi) = if is_b { (B0, B1) } else { (A0, A1) };
+                    let v = Into::<AB::Expr>::into(row[ib + lo]) + beta.clone() * Into::<AB::Expr>::into(row[ib + hi]);
+                    wf.assert_eq(v, pis[PI_Z + p].clone());
+                }
+                for p in 0..NJOIN {
+                    let (obf, is_out1) = out_port(p);
+                    let ob = BASE[obf];
+                    let (lo, hi) = if is_out1 { (O10, O11) } else { (O00, O01) };
+                    let v = Into::<AB::Expr>::into(row[ob + lo]) + beta.clone() * Into::<AB::Expr>::into(row[ob + hi]);
+                    wf.assert_eq(v, pis[PI_ZHAT + p].clone());
+                }
+            }
+        }
+
+        fn split(v: u64) -> (u64, u64) {
+            (v % BETA, v / BETA)
+        }
+
+        /// Fill one CT butterfly's 460 columns for (a, b, ζ) → (out0=a+ζb, out1=a−ζb) mod q.
+        /// Returns (out0, out1). VERBATIM from ntt_wired8_air.rs::fill_bf.
+        fn fill_bf<F: PrimeField64>(vals: &mut [F], base: usize, a: u64, b: u64, zeta: u64) -> (u64, u64) {
+            let (z0, z1) = split(zeta);
+            let (b0, b1) = split(b);
+            let prod = (zeta as u128) * (b as u128);
+            let t = (prod % Q as u128) as u64;
+            let m = (prod / Q as u128) as u64;
+            let (m0, m1) = split(m);
+            let (t0, t1) = split(t);
+            let s0 = z0 * b0;
+            let (l0, kl0) = (s0 % BETA, s0 / BETA);
+            let s1 = z0 * b1 + z1 * b0 + kl0;
+            let (l1, kl1) = (s1 % BETA, s1 / BETA);
+            let s2 = z1 * b1 + kl1;
+            let (l2, kl2) = (s2 % BETA, s2 / BETA);
+            let u0 = m0 + t0;
