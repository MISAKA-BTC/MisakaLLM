@@ -0,0 +1,1962 @@
+//! **ML-DSA-87 verify TAIL, JOINED END-TO-END through the invNTT bridge** — the CAPSTONE that
+//! welds the two recursion-composed ends of `Verify` into ONE continuous chain:
+//!
+//! ```text
+//!   ρ→SHAKE→…→ŵ_i   ──Tie1──▶   ŵ ──invNTT──▶ w   ──Tie2──▶   w→UseHint→…→(c̃'==c̃)
+//!   (matvec front,             (Leg I, THIS FILE's                (accept tail,
+//!    expanda_chain_matvec)      new bridge)                        accept_tail.rs)
+//! ```
+//!
+//! Both ends already compose through recursion independently:
+//!   - INPUT end (`expanda_chain_matvec.rs`): ρ → SHAKE → pi_stream → placed Â → pointwise Â∘ẑ
+//!     accumulate → **ŵ_i (NTT-domain), exposed as OUTPUT publics** (real libcrux seed-5 ρ).
+//!   - ACCEPT end (`accept_tail.rs`): **w (coefficient-domain) → UseHint** → w1Encode → SHAKE256
+//!     → (c̃'==c̃). w was consumed as a *representative* INPUT because the stage that produces it —
+//!     the inverse NTT `w = invNTT(ŵ)` — was NOT YET a recursion leg. **That is the missing link.**
+//!
+//! This file lands the invNTT stage as a real batch-STARK **Leg I** and JOINS the two ends with the
+//! TWO cross-stage ties, so ONE outer proof covers the whole chain **matvec → invNTT → UseHint**:
+//!
+//!   - **Leg M — matvec front** (`ExpandaPlaceAir`, VERBATIM from `expanda_chain_matvec.rs`):
+//!     placed Â∘ẑ − ĉ∘(t̂1·2^d), exposing ŵ_i[0..NM] as OUTPUT publics. Real seed-5 ρ.
+//!   - **Leg I — invNTT** (NEW; the COMPLETE Gentleman-Sande **n=8** inverse NTT over Z_q, VERBATIM
+//!     GS constraints ported from `docs/bench/plonky3-shield-air/invntt_wired8_air.rs` — the
+//!     reduced partner of the proven 256-pt `invntt_wired256_air.rs`): 12 GS butterflies across all
+//!     3 layers with FULL in-AIR cross-layer routing (every layer's inputs constrained == the
+//!     previous layer's outputs, every twiddle pinned to the canonical n=8 ζ), PLUS the `n⁻¹` (=
+//!     inv(8) mod q) normalization as 8 further proven mod-q multiplies (one per coefficient, the
+//!     exact "one further mod-q mult per coeff" the 256-pt file documents). Exposes ŵ INPUT publics
+//!     [0..8] and the coefficient-domain **w OUTPUT** publics [0..8]. Round-trip-checked vs the
+//!     `ntt_zq.rs` reference: `invNTT(NTT(x)) == x` coefficient-exact.
+//!   - **Leg U — UseHint** (VERBATIM from `accept_tail.rs`/`usehint_air.rs`, EXTENDED to also
+//!     surface its `w` INPUT publics): FIPS-204 Decompose ∘ hint. Consumes w as INPUT.
+//!
+//!   - **Tie 1 (front↔invNTT)**: `Leg-M ŵ_i[k] == Leg-I ŵ_in[k]` for k in 0..8.
+//!   - **Tie 2 (invNTT↔accept)**: `Leg-I w_out[k] == Leg-U w_in[k]` for k in 0..8.
+//!   Each is an ALU `sub` asserted zero (each surfaced public read once — a direct `connect` breaks
+//!   the Public-table LogUp, exactly as the sibling chains).
+//!
+//! ## Scope (REDUCED-BUT-REAL)
+//!   - invNTT is the COMPLETE n=8 GS transform (not a partial slice): all 12 butterflies, 3 layers,
+//!     real pinned twiddles, + real inv(8) scaling. n=8 (not 256) is the reduced point count the
+//!     task blesses; the 256-pt wiring is the same pattern (`invntt_wired256_air.rs`, already
+//!     proven as a uni-stark AIR) generalized by the multi-row lookup, out of scope here.
+//!   - The 8 coefficients that flow matvec→invNTT→UseHint are bound by the two ties; matvec produces
+//!     NM=64 ŵ and UseHint consumes NW1=256 w (the untied remainder is representative). ŵ fed to
+//!     Leg I is matvec's REAL output slice ŵ_i[0..8]; w = invNTT(ŵ) is diff-tested exact.
+//!   - Everything downstream of UseHint (w1Encode→SHAKE256→c̃'==c̃) is the already-proven
+//!     `accept_tail.rs`; this file references it and re-proves only Leg U as the join anchor.
+//!
+//! ## Cases (all in one run)
+//!   1. HONEST (ŵ→w consistent, both ties): outer prove+verify SUCCEEDS = the whole tail composes.
+//!   2. NEG-W (feed UseHint a w inconsistent with invNTT(ŵ)): Tie 2 mismatch → REJECTS at prove.
+//!   3. NEG-BF (tamper one invNTT butterfly output): Leg I's own cross-layer routing is violated →
+//!      Leg I native batch verify REJECTS.
+//!   4. NEG-WH (tamper the ŵ slice fed to invNTT vs matvec's real ŵ): Tie 1 mismatch → REJECTS.
+//!
+//! ```bash
+//! cargo run --release --example verify_tail_join
+//! ```
+
+#[macro_use]
+mod common;
+use common::*;
+
+use p3_air::{Air, AirBuilder, BaseAir, WindowAccess};
+use p3_batch_stark::{BatchProof, ProverData, StarkInstance, prove_batch, verify_batch};
+use p3_circuit_prover::{AirVariant, RecomposePreprocessor, recompose_air_builders};
+use p3_field::PrimeField64;
+use std::time::Instant;
+use tiny_keccak::{Hasher, Shake};
+
+fn main() {
+    init_logger();
+    kb::run();
+}
+
+mod kb {
+    // The matvec / usehint modules are copied VERBATIM from the sibling examples; a few of their
+    // host reference helpers (matvec_ref / m / mulq / ahat_read_cell / psum_cell / QI_M) are the
+    // diff-test oracles those files use but this join does not — kept for byte-fidelity.
+    #![allow(dead_code)]
+    use super::*;
+
+    // KoalaBear, D=4, W=16 Poseidon2 — same field/hash plumbing as `expanda_chain_matvec` /
+    // `accept_tail` (the GS invNTT gadget is generic over PrimeField64; q < 2^23 ≪ KoalaBear p,
+    // so every limb/product value stores exactly and the BabyBear-authored gadget is byte-for-byte
+    // the same constraint system over KoalaBear).
+    define_field_module_types!(
+        p3_koala_bear::KoalaBear,
+        p3_koala_bear::Poseidon2KoalaBear<16>,
+        p3_koala_bear::default_koalabear_poseidon2_16,
+        Poseidon2Config::KOALA_BEAR_D4_W16,
+        p3_poseidon2_circuit_air::KoalaBearD4Width16,
+        4,
+        16,
+        8,
+        8,
+        enable_poseidon2_perm,
+        p3_koala_bear::default_koalabear_poseidon2_16,
+        16,
+        8,
+        enable_recompose,
+        generate_poseidon2_trace,
+        p3_circuit::ops::Poseidon2Params
+    );
+
+    // ---- shared constants ----
+    const Q: u64 = 8380417; // ML-DSA / Dilithium modulus (matvec uses u64 form)
+    const QI: i64 = Q as i64; // i64 form (UseHint / invNTT reference arithmetic)
+    const N: usize = 256; // coefficients per poly (matvec candidate placement)
+    const CBUD: usize = 320; // per-entry candidate budget (matvec Leg-B pack tie)
+    const STREAM_BYTES: usize = 3 * CBUD; // 960 candidate bytes per ExpandA entry
+    const I_ROW: usize = 0; // shipped ExpandA output row index i
+
+    // UseHint / Decompose constants (FIPS-204 ML-DSA-87)
+    const GAMMA2: i64 = (QI - 1) / 32; // 261888
+    const G2: i64 = 2 * GAMMA2; // 523776
+    const MM: i64 = 16; // (q-1)/(2γ2)
+    const KB_P: i64 = 2130706433; // KoalaBear prime (is-zero-witness modulus for Leg U)
+    const NW1: usize = 256; // one poly's worth of w / w1 (reduced-but-real)
+
+    const NJOIN: usize = 8; // coefficients carried matvec→invNTT→UseHint (= the n=8 invNTT width)
+    const SECURITY: usize = 100;
+    // =======================================================================================
+    // LEG I — invNTT (the BRIDGE). COMPLETE Gentleman-Sande n=8 inverse NTT over Z_q with FULL
+    // in-AIR cross-layer routing (GS constraints VERBATIM from invntt_wired8_air.rs, the reduced
+    // partner of the proven 256-pt invntt_wired256_air.rs) + the inv(8) normalization as 8 further
+    // proven mod-q multiplies. Exposes ŵ INPUT publics [0..8] and w OUTPUT publics [0..8].
+    // =======================================================================================
+    pub mod invntt {
+        use super::*;
+
+        const BETA: u64 = 4096;
+        const Q1: u64 = 2046;
+
+        // one GS butterfly's 40 primary columns (VERBATIM layout from invntt_wired8_air.rs /
+        // invntt_butterfly_air.rs) then its range-check bits.
+        const Z0: usize = 0;
+        const Z1: usize = 1;
+        const D0: usize = 2; // d = (b − a) mod q, the multiply's 2nd operand
+        const D1: usize = 3;
+        const MC0: usize = 4;
+        const MC1: usize = 5;
+        const T0: usize = 6; // t = ζ·d mod q = out1
+        const T1: usize = 7;
+        const KL0: usize = 8;
+        const KL1: usize = 9;
+        const KL2: usize = 10;
+        const KR0: usize = 11;
+        const KR1: usize = 12;
+        const KR2: usize = 13;
+        const L0: usize = 14;
+        const L1: usize = 15;
+        const L2: usize = 16;
+        const M0: usize = 17;
+        const M1: usize = 18;
+        const M2: usize = 19;
+        const GT0: usize = 20;
+        const GT1: usize = 21;
+        const GM0: usize = 22;
+        const GM1: usize = 23;
+        const A0: usize = 24; // a
+        const A1: usize = 25;
+        const BB0: usize = 26; // b
+        const BB1: usize = 27;
+        const O00: usize = 28; // out0 = (a+b) mod q
+        const O01: usize = 29;
+        const KD: usize = 30; // borrow bit for d = (b−a) mod q
+        const KO: usize = 31; // carry bit for out0 = (a+b) mod q
+        const GA0: usize = 32;
+        const GA1: usize = 33;
+        const GB0: usize = 34;
+        const GB1: usize = 35;
+        const GD0: usize = 36;
+        const GD1: usize = 37;
+        const GO0: usize = 38;
+        const GO1: usize = 39;
+        const NP: usize = 40;
+        const WIDTHS: [usize; NP] = [
+            12, 11, 12, 11, 12, 11, 12, 11, // z d m t
+            12, 13, 11, 2, 13, 11, //          kL0 kL1 kL2 kR0 kR1 kR2
+            12, 12, 12, 12, 12, 12, //         L0 L1 L2 M0 M1 M2
+            12, 11, 12, 11, //                 gt gm
+            12, 11, 12, 11, 12, 11, //         a b out0
+            1, 1, //                           kd ko
+            12, 11, 12, 11, 12, 11, 12, 11, // ga gb gd go
+        ];
+        const BF_COLS: usize = 480; // 40 primary + 440 bits
+        // 12 GS butterflies of the n=8 inverse (3 layers × 4) + 8 inv(8)-scaling butterflies.
+        const NBF: usize = 20;
+        pub const NUM_COLS: usize = NBF * BF_COLS; // 9600
+        const BASE: [usize; NBF] = {
+            let mut b = [0usize; NBF];
+            let mut i = 0;
+            while i < NBF {
+                b[i] = i * BF_COLS;
+                i += 1;
+            }
+            b
+        };
+        // the 12 invNTT butterflies (bf0..bf11) then the 8 scaling butterflies (bf12..bf19).
+        const NINV_BF: usize = 12;
+
+        fn bit_off(col: usize) -> usize {
+            NP + WIDTHS[..col].iter().sum::<usize>()
+        }
+
+        // ---- public values: ŵ INPUT [0..8] then w OUTPUT [0..8] ----
+        pub const PI_WHAT: usize = 0;
+        pub const PI_W: usize = NJOIN;
+        pub const NUM_PIS: usize = 2 * NJOIN;
+
+        pub fn height() -> usize {
+            64 // ≥ 2^6 FRI foldability floor; every row carries the same full transform
+        }
+        pub fn num_pis() -> usize {
+            NUM_PIS
+        }
+
+        /// The 8 layer-1 INPUT ports (ŵ position p) as (butterfly, is_b):
+        /// bf0=(pos0,pos1) bf1=(pos2,pos3) bf2=(pos4,pos5) bf3=(pos6,pos7).
+        fn in_port(p: usize) -> (usize, bool) {
+            (p / 2, p % 2 == 1)
+        }
+        /// The layer-3 (unscaled) OUTPUT at natural position p as (butterfly, is_out1):
+        /// pos0..3 = bf8..bf11.out0, pos4..7 = bf8..bf11.out1.
+        fn out_port(p: usize) -> (usize, bool) {
+            if p < 4 { (8 + p, false) } else { (8 + (p - 4), true) }
+        }
+
+        /// The AIR carries the seven canonical n=8 twiddles ζ (same table as the forward; the
+        /// GS ζ·(b−a) convention absorbs the Dilithium −ζ sign) and n⁻¹ = inv(8) mod q.
+        #[derive(Clone)]
+        pub struct InvNttAir {
+            pub zetas: [u64; 7],
+            pub ninv: u64,
+        }
+
+        impl<F: PrimeField64> BaseAir<F> for InvNttAir {
+            fn width(&self) -> usize {
+                NUM_COLS
+            }
+            fn num_public_values(&self) -> usize {
+                num_pis()
+            }
+            fn max_constraint_degree(&self) -> Option<usize> {
+                Some(2)
+            }
+        }
+
+        impl<AB: AirBuilder> Air<AB> for InvNttAir
+        where
+            AB::F: PrimeField64,
+        {
+            fn eval(&self, builder: &mut AB) {
+                let one = AB::Expr::ONE;
+                let beta = AB::Expr::from_u64(BETA);
+                let q1 = AB::Expr::from_u64(Q1);
+                let q = AB::Expr::from_u64(Q);
+                let qm1 = AB::Expr::from_u64(Q - 1);
+                let pis: Vec<AB::Expr> =
+                    (0..num_pis()).map(|k| builder.public_values()[k].into()).collect();
+                let main = builder.main();
+                let row = main.current_slice();
+                let e = |i: usize| -> AB::Expr { row[i].into() };
+
+                // ---- each GS butterfly (all 20): the proven gadget, VERBATIM ----
+                for &b in BASE.iter() {
+                    for c in 0..NP {
+                        let bo = b + bit_off(c);
+                        let mut acc = AB::Expr::ZERO;
+                        let mut w = AB::Expr::ONE;
+                        for j in 0..WIDTHS[c] {
+                            let bit: AB::Expr = row[bo + j].into();
+                            builder.assert_zero(bit.clone() * (bit.clone() - one.clone()));
+                            acc = acc + bit * w.clone();
+                            w = w.clone() + w.clone();
+                        }
+                        builder.assert_eq(e(b + c), acc);
+                    }
+                    // mod-q multiply t = ζ·d (limb carry chain)
+                    builder.assert_eq(e(b + Z0) * e(b + D0), e(b + L0) + beta.clone() * e(b + KL0));
+                    builder.assert_eq(
+                        e(b + Z0) * e(b + D1) + e(b + Z1) * e(b + D0) + e(b + KL0),
+                        e(b + L1) + beta.clone() * e(b + KL1),
+                    );
+                    builder.assert_eq(e(b + Z1) * e(b + D1) + e(b + KL1), e(b + L2) + beta.clone() * e(b + KL2));
+                    builder.assert_eq(e(b + MC0) + e(b + T0), e(b + M0) + beta.clone() * e(b + KR0));
+                    builder.assert_eq(
+                        e(b + MC0) * q1.clone() + e(b + MC1) + e(b + T1) + e(b + KR0),
+                        e(b + M1) + beta.clone() * e(b + KR1),
+                    );
+                    builder.assert_eq(e(b + MC1) * q1.clone() + e(b + KR1), e(b + M2) + beta.clone() * e(b + KR2));
+                    builder.assert_eq(e(b + L0), e(b + M0));
+                    builder.assert_eq(e(b + L1), e(b + M1));
+                    builder.assert_eq(e(b + L2), e(b + M2));
+                    builder.assert_eq(e(b + KL2), e(b + KR2));
+
+                    let t_val = e(b + T0) + beta.clone() * e(b + T1); // out1 = ζ·d
+                    let d_val = e(b + D0) + beta.clone() * e(b + D1);
+                    let a_val = e(b + A0) + beta.clone() * e(b + A1);
+                    let b_val = e(b + BB0) + beta.clone() * e(b + BB1);
+                    let out0 = e(b + O00) + beta.clone() * e(b + O01);
+                    let m_val = e(b + MC0) + beta.clone() * e(b + MC1);
+                    // GS add/sub: d = (b−a) mod q, out0 = (a+b) mod q
+                    builder.assert_eq(a_val.clone() + d_val.clone(), b_val.clone() + e(b + KD) * q.clone());
+                    builder.assert_eq(a_val.clone() + b_val.clone(), out0.clone() + e(b + KO) * q.clone());
+                    // ranges
+                    let slack = |lo: usize, hi: usize| -> AB::Expr { e(b + lo) + beta.clone() * e(b + hi) };
+                    builder.assert_eq(t_val + slack(GT0, GT1), qm1.clone());
+                    builder.assert_eq(m_val + slack(GM0, GM1), qm1.clone());
+                    builder.assert_eq(a_val + slack(GA0, GA1), qm1.clone());
+                    builder.assert_eq(b_val + slack(GB0, GB1), qm1.clone());
+                    builder.assert_eq(d_val + slack(GD0, GD1), qm1.clone());
+                    builder.assert_eq(out0 + slack(GO0, GO1), qm1.clone());
+                }
+
+                // ---- pin each invNTT butterfly's twiddle to the canonical ζ (VERBATIM schedule) ----
+                // inverse schedule order: len=1 → ζ[6,5,4,3]; len=2 → ζ[2,2,1,1]; len=4 → ζ[0]×4.
+                let pin = |builder: &mut AB, b: usize, zeta: u64| {
+                    builder.assert_eq(e(b + Z0) + beta.clone() * e(b + Z1), AB::Expr::from_u64(zeta));
+                };
+                pin(builder, BASE[0], self.zetas[6]);
+                pin(builder, BASE[1], self.zetas[5]);
+                pin(builder, BASE[2], self.zetas[4]);
+                pin(builder, BASE[3], self.zetas[3]);
+                pin(builder, BASE[4], self.zetas[2]);
+                pin(builder, BASE[5], self.zetas[2]);
+                pin(builder, BASE[6], self.zetas[1]);
+                pin(builder, BASE[7], self.zetas[1]);
+                pin(builder, BASE[8], self.zetas[0]);
+                pin(builder, BASE[9], self.zetas[0]);
+                pin(builder, BASE[10], self.zetas[0]);
+                pin(builder, BASE[11], self.zetas[0]);
+
+                // ---- CROSS-LAYER WIRING (VERBATIM invntt_wired8): each layer's inputs == prev
+                // layer's outputs. out0=(O00,O01), out1=(T0,T1); inputs a=(A0,A1), b=(BB0,BB1). ----
+                let wire = |builder: &mut AB, db: usize, d_lo: usize, d_hi: usize, sb: usize, s_lo: usize, s_hi: usize| {
+                    builder.assert_eq(e(db + d_lo), e(sb + s_lo));
+                    builder.assert_eq(e(db + d_hi), e(sb + s_hi));
+                };
+                let (bf0, bf1, bf2, bf3) = (BASE[0], BASE[1], BASE[2], BASE[3]);
+                let (bf4, bf5, bf6, bf7) = (BASE[4], BASE[5], BASE[6], BASE[7]);
+                let (bf8, bf9, bf10, bf11) = (BASE[8], BASE[9], BASE[10], BASE[11]);
+                // layer2 reads layer1 outputs:
+                wire(builder, bf4, A0, A1, bf0, O00, O01);
+                wire(builder, bf4, BB0, BB1, bf1, O00, O01);
+                wire(builder, bf5, A0, A1, bf0, T0, T1);
+                wire(builder, bf5, BB0, BB1, bf1, T0, T1);
+                wire(builder, bf6, A0, A1, bf2, O00, O01);
+                wire(builder, bf6, BB0, BB1, bf3, O00, O01);
+                wire(builder, bf7, A0, A1, bf2, T0, T1);
+                wire(builder, bf7, BB0, BB1, bf3, T0, T1);
+                // layer3 reads layer2 outputs:
+                wire(builder, bf8, A0, A1, bf4, O00, O01);
+                wire(builder, bf8, BB0, BB1, bf6, O00, O01);
+                wire(builder, bf9, A0, A1, bf5, O00, O01);
+                wire(builder, bf9, BB0, BB1, bf7, O00, O01);
+                wire(builder, bf10, A0, A1, bf4, T0, T1);
+                wire(builder, bf10, BB0, BB1, bf6, T0, T1);
+                wire(builder, bf11, A0, A1, bf5, T0, T1);
+                wire(builder, bf11, BB0, BB1, bf7, T0, T1);
+
+                // ---- inv(8) SCALING stage: for each natural position p, scaling butterfly bf(12+p)
+                // computes w[p] = n⁻¹ · unscaled[p] mod q as a GS butterfly with a=0, b=unscaled[p],
+                // ζ=n⁻¹ (so out1 = n⁻¹·(b−0) = n⁻¹·unscaled[p]). Wire b to the layer-3 output, pin a=0
+                // and ζ=n⁻¹. This is the "one further mod-q mult per coeff" the 256-pt file documents. ----
+                for p in 0..NJOIN {
+                    let sb = BASE[NINV_BF + p];
+                    // a == 0
+                    builder.assert_zero(e(sb + A0) + beta.clone() * e(sb + A1));
+                    // ζ == n⁻¹
+                    builder.assert_eq(e(sb + Z0) + beta.clone() * e(sb + Z1), AB::Expr::from_u64(self.ninv));
+                    // b == layer-3 unscaled output at position p
+                    let (obf, is_out1) = out_port(p);
+                    let ob = BASE[obf];
+                    let (o_lo, o_hi) = if is_out1 { (T0, T1) } else { (O00, O01) };
+                    builder.assert_eq(e(sb + BB0), e(ob + o_lo));
+                    builder.assert_eq(e(sb + BB1), e(ob + o_hi));
+                }
+
+                // ---- IO binding on the first row: ŵ INPUT and w OUTPUT to the surfaced publics ----
+                let mut wf = builder.when_first_row();
+                for p in 0..NJOIN {
+                    let (ibf, is_b) = in_port(p);
+                    let ib = BASE[ibf];
+                    let (lo, hi) = if is_b { (BB0, BB1) } else { (A0, A1) };
+                    let v = Into::<AB::Expr>::into(row[ib + lo]) + beta.clone() * Into::<AB::Expr>::into(row[ib + hi]);
+                    wf.assert_eq(v, pis[PI_WHAT + p].clone());
+                }
+                for p in 0..NJOIN {
+                    let sb = BASE[NINV_BF + p]; // scaling butterfly for position p: out1 = w[p]
+                    let v = Into::<AB::Expr>::into(row[sb + T0]) + beta.clone() * Into::<AB::Expr>::into(row[sb + T1]);
+                    wf.assert_eq(v, pis[PI_W + p].clone());
+                }
+            }
+        }
+
+        fn split(v: u64) -> (u64, u64) {
+            (v % BETA, v / BETA)
+        }
+
+        /// Fill one GS butterfly's 480 columns for (a, b, ζ) → (out0=a+b, out1=ζ·(b−a)) mod q.
+        /// Returns (out0, out1). VERBATIM from invntt_wired8_air.rs::fill_gs.
+        fn fill_gs<F: PrimeField64>(vals: &mut [F], base: usize, a: u64, b: u64, zeta: u64) -> (u64, u64) {
+            let d = (b + Q - a) % Q;
+            let kd = if b >= a { 0u64 } else { 1 };
+            let (z0, z1) = split(zeta);
+            let (d0, d1) = split(d);
+            let prod = (zeta as u128) * (d as u128);
+            let t = (prod % Q as u128) as u64; // out1
+            let m = (prod / Q as u128) as u64;
+            let (m0, m1) = split(m);
+            let (t0, t1) = split(t);
+            let s0 = z0 * d0;
+            let (l0, kl0) = (s0 % BETA, s0 / BETA);
+            let s1 = z0 * d1 + z1 * d0 + kl0;
+            let (l1, kl1) = (s1 % BETA, s1 / BETA);
+            let s2 = z1 * d1 + kl1;
+            let (l2, kl2) = (s2 % BETA, s2 / BETA);
+            let u0 = m0 + t0;
+            let (mm0, kr0) = (u0 % BETA, u0 / BETA);
+            let u1 = m0 * Q1 + m1 + t1 + kr0;
+            let (mm1, kr1) = (u1 % BETA, u1 / BETA);
+            let u2 = m1 * Q1 + kr1;
+            let (mm2, kr2) = (u2 % BETA, u2 / BETA);
+            assert_eq!((l0, l1, l2, kl2), (mm0, mm1, mm2, kr2), "limb mismatch");
+            let sum = a + b;
+            let ko = if sum >= Q { 1u64 } else { 0 };
+            let out0 = sum - ko * Q;
+            assert!(out0 < Q && t < Q);
+            let (a0, a1) = split(a);
+            let (bb0, bb1) = split(b);
+            let (o00, o01) = split(out0);
+            let (gt0, gt1) = split((Q - 1) - t);
+            let (gm0, gm1) = split((Q - 1) - m);
+            let (ga0, ga1) = split((Q - 1) - a);
+            let (gb0, gb1) = split((Q - 1) - b);
+            let (gd0, gd1) = split((Q - 1) - d);
+            let (go0, go1) = split((Q - 1) - out0);
+            let prim = [
+                (Z0, z0), (Z1, z1), (D0, d0), (D1, d1), (MC0, m0), (MC1, m1), (T0, t0), (T1, t1),
+                (KL0, kl0), (KL1, kl1), (KL2, kl2), (KR0, kr0), (KR1, kr1), (KR2, kr2),
+                (L0, l0), (L1, l1), (L2, l2), (M0, mm0), (M1, mm1), (M2, mm2),
+                (GT0, gt0), (GT1, gt1), (GM0, gm0), (GM1, gm1),
+                (A0, a0), (A1, a1), (BB0, bb0), (BB1, bb1), (O00, o00), (O01, o01),
+                (KD, kd), (KO, ko),
+                (GA0, ga0), (GA1, ga1), (GB0, gb0), (GB1, gb1), (GD0, gd0), (GD1, gd1), (GO0, go0), (GO1, go1),
+            ];
+            for (col, v) in prim {
+                vals[base + col] = F::from_u64(v);
+                let bo = base + bit_off(col);
+                for j in 0..WIDTHS[col] {
+                    vals[bo + j] = F::from_u64((v >> j) & 1);
+                }
+            }
+            (out0, t)
+        }
+
+        /// Fill the full-height trace: every row holds the complete n=8 GS inverse (12 butterflies,
+        /// threaded in-place exactly as invntt_wired8_air.rs) + 8 inv(8)-scaling butterflies.
+        /// Returns the trace and the coefficient-domain output w (= scaled invNTT of ŵ).
+        pub fn generate<F: PrimeField64>(what_in: &[u64; NJOIN], zetas: &[u64; 7], ninv: u64) -> (RowMajorMatrix<F>, [u64; NJOIN]) {
+            let h = height();
+            let mut vals = F::zero_vec(h * NUM_COLS);
+            let mut w_out = [0u64; NJOIN];
+            for r in 0..h {
+                let o = r * NUM_COLS;
+                let seg = &mut vals[o..o + NUM_COLS];
+                // 12 invNTT butterflies, in-place GS schedule (len = 1, 2, 4)
+                let mut a = *what_in;
+                let mut bf = 0usize;
+                let mut k = 7usize;
+                let mut len = 1;
+                while len < 8 {
+                    let mut start = 0;
+                    while start < 8 {
+                        k -= 1;
+                        let zeta = zetas[k];
+                        for j in start..start + len {
+                            let (o0, o1) = fill_gs(seg, BASE[bf], a[j], a[j + len], zeta);
+                            a[j] = o0;
+                            a[j + len] = o1;
+                            bf += 1;
+                        }
+                        start += 2 * len;
+                    }
+                    len *= 2;
+                }
+                // a[] now holds the UNSCALED inverse (natural position order). Scale each by n⁻¹.
+                for p in 0..NJOIN {
+                    let (_o0, o1) = fill_gs(seg, BASE[NINV_BF + p], 0, a[p], ninv);
+                    w_out[p] = o1; // = n⁻¹ · unscaled[p] mod q
+                }
+            }
+            (RowMajorMatrix::new(vals, NUM_COLS), w_out)
+        }
+
+        pub fn build_pis<F: PrimeField64>(what_in: &[u64; NJOIN], w_out: &[u64; NJOIN]) -> Vec<F> {
+            what_in.iter().chain(w_out.iter()).map(|&v| F::from_u64(v)).collect()
+        }
+
+        // ---- reference oracles (VERBATIM ntt8 / invntt8_unscaled from invntt_wired8_air.rs) ----
+        fn modpow(base: u64, mut e: u64) -> u64 {
+            let mut r = 1u128;
+            let mut b = base as u128 % Q as u128;
+            while e > 0 {
+                if e & 1 == 1 {
+                    r = r * b % Q as u128;
+                }
+                b = b * b % Q as u128;
+                e >>= 1;
+            }
+            r as u64
+        }
+
+        /// Canonical n=8 twiddles ζ[k] (k=1..7) and n⁻¹ = inv(8) mod q.
+        pub fn params() -> ([u64; 7], u64) {
+            let psi = modpow(1753, 32);
+            let brv3 = |x: u64| -> u64 { ((x & 1) << 2) | (x & 2) | ((x >> 2) & 1) };
+            let zetas: [u64; 7] = std::array::from_fn(|i| modpow(psi, brv3((i + 1) as u64)));
+            let ninv = modpow(8, Q - 2);
+            (zetas, ninv)
+        }
+
+        /// forward n=8 NTT (produces the ŵ the inverse round-trips).
+        pub fn ntt8(x: &[u64; 8], z: &[u64; 7]) -> [u64; 8] {
+            let mut a = *x;
+            let mut k = 0usize;
+            let mut len = 4;
+            while len >= 1 {
+                let mut start = 0;
+                while start < 8 {
+                    k += 1;
+                    let zeta = z[k - 1];
+                    for j in start..start + len {
+                        let t = ((zeta as u128 * a[j + len] as u128) % Q as u128) as u64;
+                        a[j + len] = (a[j] + Q - t) % Q;
+                        a[j] = (a[j] + t) % Q;
+                    }
+                    start += 2 * len;
+                }
+                if len == 1 {
+                    break;
+                }
+                len /= 2;
+            }
+            a
+        }
+
+        /// reference GS inverse WITH the n⁻¹ normalization → the true coefficient-domain w.
+        pub fn invntt8_scaled(input: &[u64; 8], z: &[u64; 7], ninv: u64) -> [u64; 8] {
+            let mut a = *input;
+            let mut k = 7usize;
+            let mut len = 1;
+            while len < 8 {
+                let mut start = 0;
+                while start < 8 {
+                    k -= 1;
+                    let zeta = z[k];
+                    for j in start..start + len {
+                        let aa = a[j];
+                        let bb = a[j + len];
+                        a[j] = (aa + bb) % Q;
+                        let d = (bb + Q - aa) % Q;
+                        a[j + len] = ((zeta as u128 * d as u128) % Q as u128) as u64;
+                    }
+                    start += 2 * len;
+                }
+                len *= 2;
+            }
+            std::array::from_fn(|i| ((a[i] as u128 * ninv as u128) % Q as u128) as u64)
+        }
+    }
