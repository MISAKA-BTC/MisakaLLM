+        pub fn decompose(r: i64) -> (i64, i64) {
+            let r = r.rem_euclid(QI);
+            let mut r0 = r % G2;
+            if r0 > GAMMA2 {
+                r0 -= G2;
+            }
+            if r - r0 == QI - 1 { (0, r0 - 1) } else { ((r - r0) / G2, r0) }
+        }
+        pub fn use_hint(h: bool, r: i64) -> i64 {
+            let (r1, r0) = decompose(r);
+            if h {
+                if r0 > 0 { (r1 + 1).rem_euclid(MM) } else { (r1 - 1).rem_euclid(MM) }
+            } else {
+                r1
+            }
+        }
+
+        fn inv(x: i64) -> i64 {
+            let x = x.rem_euclid(KB_P);
+            if x == 0 {
+                return 0;
+            }
+            let (mut a, mut b, mut u, mut v) = (x, KB_P, 1i64, 0i64);
+            while a != 0 {
+                let q = b / a;
+                (a, b) = (b - q * a, a);
+                (u, v) = (v - q * u, u);
+            }
+            v.rem_euclid(KB_P)
+        }
