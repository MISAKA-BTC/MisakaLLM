+
+        // ---- reduced ExpandA constants (verbatim structure; counts reduced) ----
+        pub const NM: usize = 64; // accepted coefficients (256 → 64)
+        pub const CBUDM: usize = CBUD; // 320 candidate budget KEPT (full Leg-B pack tie)
+        const CAND_ROWS_M: usize = CBUDM; // l=1 ⇒ 320 candidate rows
+        const COEFF0_M: usize = CAND_ROWS_M; // first coefficient row = 320
+        const REAL_ROWS_M: usize = CAND_ROWS_M + NM; // 384
+        pub const HEIGHT_M: usize = 512; // next_pow2(384)
+        const TWO24: u64 = 1 << 24;
+        pub const LDIM_M: usize = 1; // reduced ExpandA columns (additive Â∘ẑ products)
+        const BETA: u64 = 4096; // 2^12 limb base of the mult gadget (ntt_mul_air.rs)
+        const Q1: u64 = 2046; // q = 1 + 2046·β
+        pub const D2: u64 = 8192; // 2^d, d = 13 (the t̂1 scale)
+
+        // stream one-hot factoring: SHI_M × SLO_M == CAND_ROWS_M (8 × 40 = 320)
+        const SHI_M: usize = 8;
+        const SLO_M: usize = 40;
+        // coeff one-hot factoring: CHI_M × CLO_M == NM (8 × 8 = 64)
+        const CHI_M: usize = 8;
+        const CLO_M: usize = 8;
+
+        // ---- main columns: candidate block (verbatim) ----
+        const CIN: usize = 0; // 24 input bits (3 bytes LE)
+        const CT: usize = 24; // t = low 23 bits (bit 23 dropped = & 0x7FFFFF)
+        const CLT: usize = 25; // accept flag [t < q]
+        const CDIFF: usize = 26; // t − q + lt·2^24
+        const CDIFFB: usize = 27; // 24 bits of diff
+        const CCNT: usize = 51; // acceptances before this row
+        const CU: usize = 52; // u = N − cnt
+        const CUB: usize = 53; // 9 bits of u
+        const CINVU: usize = 62; // u⁻¹ when u ≠ 0
+        const CACT: usize = 63; // act = [cnt < N]
+        const CPLACE: usize = 64; // place = lt·act
+        const CSEL: usize = 65; // N one-hot placement selectors
+        const BANK: usize = CSEL + NM; // 129; the single bank (l=1), N cols
+        // ---- coefficient block (verbatim from expanda_matvec_air.rs, reduced l=1/N=64) ----
+        const CB: usize = BANK + LDIM_M * NM; // 193
+        const MG_COLS: usize = 296; // one mod-q mult gadget (24 primary + 272 bits)
+        const MG_AZ0: usize = CB; // az gadget j = 0 (Â[0][k]·ẑ[0][k])
+        const MG_T1S: usize = CB + LDIM_M * MG_COLS; // 2^d scale gadget (8192·t̂1[k])
+        const MG_PSUB: usize = CB + (LDIM_M + 1) * MG_COLS; // ĉ·t1s gadget
+        const PCOL: usize = CB + (LDIM_M + 2) * MG_COLS; // P[0..LDIM_M] accumulate inputs
+        const PSUBCOL: usize = PCOL + LDIM_M; // PSUB accumulate input
+        const O0: usize = PSUBCOL + 1; // out limb 0 (12b)
+        const O1: usize = O0 + 1; // out limb 1 (11b)
+        const GO0: usize = O0 + 2; // slack q−1−out limb 0
+        const GO1: usize = O0 + 3; // slack limb 1
+        const KKC: usize = O0 + 4; // reduction k ∈ [0,8)
+        const OBITS: usize = O0 + 5; // bits: O0 12 | O1 11 | GO0 12 | GO1 11 | KK 3 = 49
+        pub const NUM_COLS_M: usize = OBITS + 49; // 1137
+
+        // ---- mult gadget relative layout (verbatim ntt_mul_air.rs) ----
+        const MG_Z0: usize = 0;
+        const MG_Z1: usize = 1;
+        const MG_B0: usize = 2;
+        const MG_B1: usize = 3;
+        const MG_M0: usize = 4;
+        const MG_M1: usize = 5;
+        const MG_T0: usize = 6;
+        const MG_T1: usize = 7;
+        const MG_KL0: usize = 8;
+        const MG_KL1: usize = 9;
+        const MG_KL2: usize = 10;
+        const MG_KR0: usize = 11;
+        const MG_KR1: usize = 12;
+        const MG_KR2: usize = 13;
+        const MG_L0: usize = 14;
+        const MG_L1: usize = 15;
+        const MG_L2: usize = 16;
+        const MG_MM0: usize = 17;
+        const MG_MM1: usize = 18;
+        const MG_MM2: usize = 19;
+        const MG_GT0: usize = 20;
+        const MG_GT1: usize = 21;
+        const MG_GM0: usize = 22;
+        const MG_GM1: usize = 23;
+        const MG_NP: usize = 24;
+        const MG_WIDTHS: [usize; MG_NP] = [
+            12, 11, 12, 11, 12, 11, 12, 11, // z0 z1 b0 b1 m0 m1 t0 t1
+            12, 13, 11, 2, 13, 11, // kL0 kL1 kL2 kR0 kR1 kR2
+            12, 12, 12, 12, 12, 12, // L0 L1 L2 M0 M1 M2
+            12, 11, 12, 11, // gt0 gt1 gm0 gm1
+        ];
+        fn mg_bit_off(c: usize) -> usize {
+            MG_NP + MG_WIDTHS[..c].iter().sum::<usize>()
+        }
+
+        // ---- public values ----
+        pub const PI_STREAM_M: usize = 0; // 320: candidate rr at rr (24-bit LE pack) — INPUT
+        pub const PI_Z_M: usize = CBUDM; // 64: ẑ[0][k] — INPUT
+        pub const PI_T1_M: usize = PI_Z_M + NM; // 64: t̂1_i = NTT(t1_i) (unscaled) — INPUT
+        pub const PI_C_M: usize = PI_T1_M + NM; // 64: ĉ — INPUT
+        pub const PI_OUT_M: usize = PI_C_M + NM; // 64: ŵ_i (Σ Â∘ẑ − ĉ∘(t̂1·2^d)) — OUTPUT
+        pub const NUM_PIS_M: usize = PI_OUT_M + NM; // 576
+
+        // ---- preprocessed columns ----
+        const PF_ENTRY: usize = 0; // 1: flag = 1 on entry-0 candidate rows (gates bank WRITE)
+        const PF_THREAD: usize = 1; // 1: flag = 1 where the bank threads IDENTITY (coeff rows)
+        const PF_CAND: usize = 2; // 1 on candidate rows (gates cnt + u == N)
+        const PF_STEP: usize = 3; // candidate row, not entry-last (gates cnt' = cnt + place)
+        const PF_EFIRST: usize = 4; // entry-first row (gates cnt == 0)
+        const PF_ELAST: usize = 5; // entry-last row (gates cnt == N — budget completion)
+        const PF_ROW0: usize = 6; // row 0 (gates bank == 0)
+        const PF_COEFF: usize = 7; // coefficient rows (gates t1s ζ == 8192)
+        const PF_SHI: usize = 8; // 8 stream one-hot (hi)
+        const PF_SLO: usize = PF_SHI + SHI_M; // 40 stream one-hot (lo)
+        const PF_CHI: usize = PF_SLO + SLO_M; // 8 coeff one-hot (hi)
+        const PF_CLO: usize = PF_CHI + CHI_M; // 8 coeff one-hot (lo)
+        const PREP_W_M: usize = PF_CLO + CLO_M; // 72
+
+        // ---- host mod-q helpers (verbatim ntt semantics; for the ŵ_i diff-test reference) ----
+        const QI_M: i64 = Q as i64;
+        fn m(x: i64) -> i64 {
+            let r = x % QI_M;
+            if r < 0 { r + QI_M } else { r }
+        }
+        fn mulq(a: i64, b: i64) -> i64 {
+            m((a as i128 * b as i128 % QI_M as i128) as i64)
+        }
+        /// The `mldsa_verify_ref.rs` matrix-vector row (reduced l=1/N=64), computed the reference
+        /// way: ŵ_i[k] = ( Â[0][k]·ẑ[0][k] − ĉ[k]·(t̂1[k]·2^d) ) mod q. NTT-domain arithmetic is
+        /// pointwise, so the first-64 output is the same arithmetic as the full row, count reduced.
+        pub fn matvec_ref(
+            ahat: &[u64; NM],
+            zhat: &[u64; NM],
+            t1n: &[u64; NM],
+            chat: &[u64; NM],
+        ) -> [u64; NM] {
+            core::array::from_fn(|k| {
+                let t1s = mulq(D2 as i64, t1n[k] as i64);
+                let az = mulq(ahat[k] as i64, zhat[k] as i64);
+                let ct = mulq(chat[k] as i64, t1s);
+                m(az - ct) as u64
+            })
+        }
+
+        /// Flat trace index of the placed Â[0][k] bank cell on coefficient row k (the row whose
+        /// mult b-input reads it) — the `--corrupt-coeff` tamper surface.
+        pub fn ahat_read_cell(k: usize) -> usize {
+            (COEFF0_M + k) * NUM_COLS_M + BANK + k
+        }
+        /// Flat trace index of the accumulate partial-sum P[0] on coefficient row jj — the
+        /// `--corrupt-psum` tamper surface.
+        pub fn psum_cell(jj: usize) -> usize {
+            (COEFF0_M + jj) * NUM_COLS_M + PCOL
+        }
+
+        #[derive(Clone)]
+        pub struct ExpandaPlaceAir {}
+
+        impl<F: PrimeField64> BaseAir<F> for ExpandaPlaceAir {
+            fn width(&self) -> usize {
+                NUM_COLS_M
+            }
+            fn num_public_values(&self) -> usize {
+                NUM_PIS_M
+            }
+            fn max_constraint_degree(&self) -> Option<usize> {
+                Some(3)
+            }
+            fn preprocessed_width(&self) -> usize {
+                PREP_W_M
+            }
+            fn preprocessed_trace(&self) -> Option<RowMajorMatrix<F>> {
+                Some(build_prep::<F>())
+            }
+            // Default `preprocessed_next_row_columns` (open ALL at zeta + zeta_next), as the
+            // batch-STARK recursion requires — eval reads only the current preprocessed row.
+        }
+
+        /// The preprocessed schedule (verbatim structure from expanda_matvec_air.rs::build_prep,
+        /// reduced to l=1 / N=NM / C=CBUDM).
+        pub fn build_prep<F: PrimeField64>() -> RowMajorMatrix<F> {
+            let mut vals = F::zero_vec(HEIGHT_M * PREP_W_M);
+            for r in 0..HEIGHT_M {
+                let base = r * PREP_W_M;
+                if r < CAND_ROWS_M {
+                    // entry-0 candidate rows: bank WRITE (no other banks to thread; l=1)
+                    vals[base + PF_ENTRY] = F::ONE;
+                    vals[base + PF_CAND] = F::ONE;
+                    if r != CBUDM - 1 {
+                        vals[base + PF_STEP] = F::ONE;
+                    }
+                    if r == 0 {
+                        vals[base + PF_EFIRST] = F::ONE;
+                        vals[base + PF_ROW0] = F::ONE;
+                    }
+                    if r == CBUDM - 1 {
+                        vals[base + PF_ELAST] = F::ONE;
+                    }
+                    vals[base + PF_SHI + r / SLO_M] = F::ONE;
+                    vals[base + PF_SLO + r % SLO_M] = F::ONE;
+                } else if r < REAL_ROWS_M {
+                    let jj = r - COEFF0_M;
+                    // bank threads identity through the coefficient region; nothing after row 383.
+                    if r < REAL_ROWS_M - 1 {
+                        vals[base + PF_THREAD] = F::ONE;
+                    }
+                    vals[base + PF_COEFF] = F::ONE;
+                    vals[base + PF_CHI + jj / CLO_M] = F::ONE;
+                    vals[base + PF_CLO + jj % CLO_M] = F::ONE;
+                }
+                // padding rows: all zero.
+            }
+            RowMajorMatrix::new(vals, PREP_W_M)
+        }
+
+        impl<AB: AirBuilder> Air<AB> for ExpandaPlaceAir
+        where
+            AB::F: PrimeField64,
+        {
+            fn eval(&self, builder: &mut AB) {
+                let pis: Vec<AB::Expr> =
+                    (0..NUM_PIS_M).map(|k| builder.public_values()[k].into()).collect();
+                let prep: Vec<AB::Var> = builder.preprocessed().current_slice().to_vec();
+                let main = builder.main();
+                let row = main.current_slice();
+                let nxt = main.next_slice();
+                let one = AB::Expr::ONE;
+                let beta = AB::Expr::from_u64(BETA);
+                let q = AB::Expr::from_u64(Q);
+                let qm1 = AB::Expr::from_u64(Q - 1);
+                let e = |i: usize| -> AB::Expr { row[i].into() };
+                // mult-gadget limb reader: value = lo + β·hi (base-2^12 limbs).
+                let mgv = |b: usize, lo: usize, hi: usize| -> AB::Expr {
+                    Into::<AB::Expr>::into(row[b + lo]) + beta.clone() * Into::<AB::Expr>::into(row[b + hi])
+                };
+
+                // ---- candidate block (unconditional; padding carries the valid zero fill) ------
+                for j in 0..24 {
+                    let b: AB::Expr = row[CIN + j].into();
+                    builder.assert_zero(b.clone() * (b - one.clone()));
+                    let d: AB::Expr = row[CDIFFB + j].into();
+                    builder.assert_zero(d.clone() * (d - one.clone()));
+                }
+                for j in 0..9 {
+                    let b: AB::Expr = row[CUB + j].into();
+                    builder.assert_zero(b.clone() * (b - one.clone()));
+                }
+                for c in [CLT, CACT, CPLACE] {
+                    let b: AB::Expr = row[c].into();
+                    builder.assert_zero(b.clone() * (b - one.clone()));
+                }
+                for k in 0..NM {
+                    let b: AB::Expr = row[CSEL + k].into();
+                    builder.assert_zero(b.clone() * (b - one.clone()));
+                }
+                // t = Σ_{j<23} in_j·2^j  (bit 23 dropped — the & 0x7FFFFF)
+                let mut t_acc = AB::Expr::ZERO;
+                let mut w = AB::Expr::ONE;
+                for j in 0..23 {
+                    t_acc = t_acc + Into::<AB::Expr>::into(row[CIN + j]) * w.clone();
+                    w = w.clone() + w.clone();
+                }
+                builder.assert_eq(e(CT), t_acc);
+                // diff recomposition + the sound less-than: t − q + lt·2^24 = diff ∈ [0,2^24)
+                let mut d_acc = AB::Expr::ZERO;
+                let mut w2 = AB::Expr::ONE;
+                for j in 0..24 {
+                    d_acc = d_acc + Into::<AB::Expr>::into(row[CDIFFB + j]) * w2.clone();
+                    w2 = w2.clone() + w2.clone();
+                }
+                builder.assert_eq(e(CDIFF), d_acc);
+                builder.assert_eq(e(CT) - q.clone() + e(CLT) * AB::Expr::from_u64(TWO24), e(CDIFF));
+                // u recomposition; act = [u ≠ 0] via the exact nonzero test; place = lt·act
+                let mut u_acc = AB::Expr::ZERO;
+                let mut w3 = AB::Expr::ONE;
+                for j in 0..9 {
+                    u_acc = u_acc + Into::<AB::Expr>::into(row[CUB + j]) * w3.clone();
+                    w3 = w3.clone() + w3.clone();
+                }
+                builder.assert_eq(e(CU), u_acc);
+                builder.assert_eq(e(CACT), e(CU) * e(CINVU));
+                builder.assert_zero(e(CU) * (one.clone() - e(CACT)));
+                builder.assert_eq(e(CPLACE), e(CLT) * e(CACT));
+                // one-hot placement: Σ sel = place, Σ k·sel = cnt·place  (⇒ slot = cnt exactly)
+                let mut sel_sum = AB::Expr::ZERO;
+                let mut sel_idx = AB::Expr::ZERO;
+                for k in 0..NM {
+                    sel_sum = sel_sum + Into::<AB::Expr>::into(row[CSEL + k]);
+                    sel_idx =
+                        sel_idx + Into::<AB::Expr>::into(row[CSEL + k]) * AB::Expr::from_u64(k as u64);
+                }
+                builder.assert_eq(sel_sum, e(CPLACE));
+                builder.assert_eq(sel_idx, e(CCNT) * e(CPLACE));
+                // gated counter bookkeeping
+                let f_cand: AB::Expr = prep[PF_CAND].into();
+                builder.assert_zero(f_cand * (e(CCNT) + e(CU) - AB::Expr::from_u64(NM as u64)));
+                let f_step: AB::Expr = prep[PF_STEP].into();
+                builder.assert_zero(f_step * (Into::<AB::Expr>::into(nxt[CCNT]) - e(CCNT) - e(CPLACE)));
+                let f_first: AB::Expr = prep[PF_EFIRST].into();
+                builder.assert_zero(f_first * e(CCNT));
+                let f_last: AB::Expr = prep[PF_ELAST].into();
+                builder.assert_zero(f_last * (e(CCNT) - AB::Expr::from_u64(NM as u64)));
+                // stream binding: candidate value (all 24 bits incl. the dropped one) == its public
+                let mut in_val = AB::Expr::ZERO;
+                let mut w4 = AB::Expr::ONE;
+                for j in 0..24 {
+                    in_val = in_val + Into::<AB::Expr>::into(row[CIN + j]) * w4.clone();
+                    w4 = w4.clone() + w4.clone();
+                }
+                for h in 0..SHI_M {
+                    let fh: AB::Expr = prep[PF_SHI + h].into();
+                    for o in 0..SLO_M {
+                        let fo: AB::Expr = prep[PF_SLO + o].into();
+                        builder.assert_zero(
+                            fh.clone() * fo * (in_val.clone() - pis[PI_STREAM_M + h * SLO_M + o].clone()),
+                        );
+                    }
+                }
+
+                // ---- A-bank: write (placement) xor thread (identity), every transition ---------
+                let f_row0: AB::Expr = prep[PF_ROW0].into();
+                let wf: AB::Expr = prep[PF_ENTRY].into();
+                let tf: AB::Expr = prep[PF_THREAD].into();
+                for k in 0..NM {
+                    let a: AB::Expr = row[BANK + k].into();
+                    let an: AB::Expr = nxt[BANK + k].into();
+                    let sel: AB::Expr = row[CSEL + k].into();
+                    // placement transition: next.A = A + sel·(t − A)  (degree 3 with the gate)
+                    builder.assert_zero(wf.clone() * (an.clone() - a.clone() - sel * (e(CT) - a.clone())));
+                    // identity thread
+                    builder.assert_zero(tf.clone() * (an - a.clone()));
+                    // bank starts at 0
+                    builder.assert_zero(f_row0.clone() * a);
+                }
+
+                // ---- mult gadgets (unconditional, valid zero instance elsewhere) --------------
+                // VERBATIM ntt_mul_air.rs base-2^12 limb-carry mod-q multiply, one per gadget:
+                //   g = 0..LDIM_M : az_j = Â[0][k]·ẑ[0][k]   (LDIM_M=1)
+                //   g = LDIM_M    : t1s  = 8192·t̂1[k]        (2^d scale)
+                //   g = LDIM_M+1  : psub = ĉ[k]·t1s          (the ĉ∘t̂1 leg)
+                for g in 0..(LDIM_M + 2) {
+                    let base = CB + g * MG_COLS;
+                    // bind + range-check every primary column via its bits
+                    for c in 0..MG_NP {
+                        let bo = base + mg_bit_off(c);
+                        let mut acc = AB::Expr::ZERO;
+                        let mut wg = AB::Expr::ONE;
+                        for j in 0..MG_WIDTHS[c] {
+                            let bit: AB::Expr = row[bo + j].into();
+                            builder.assert_zero(bit.clone() * (bit.clone() - one.clone()));
+                            acc = acc + bit * wg.clone();
+                            wg = wg.clone() + wg.clone();
+                        }
+                        builder.assert_eq(e(base + c), acc);
+                    }
+                    let q1 = AB::Expr::from_u64(Q1);
+                    // LHS = ζ·b limbified with carries (each partial product < 2^24 < p)
+                    builder.assert_eq(
+                        e(base + MG_Z0) * e(base + MG_B0),
+                        e(base + MG_L0) + beta.clone() * e(base + MG_KL0),
+                    );
+                    builder.assert_eq(
+                        e(base + MG_Z0) * e(base + MG_B1) + e(base + MG_Z1) * e(base + MG_B0) + e(base + MG_KL0),
+                        e(base + MG_L1) + beta.clone() * e(base + MG_KL1),
+                    );
+                    builder.assert_eq(
+                        e(base + MG_Z1) * e(base + MG_B1) + e(base + MG_KL1),
+                        e(base + MG_L2) + beta.clone() * e(base + MG_KL2),
+                    );
+                    // RHS = m·q + t limbified (Q0 = 1, Q1 = 2046)
+                    builder.assert_eq(
+                        e(base + MG_M0) + e(base + MG_T0),
+                        e(base + MG_MM0) + beta.clone() * e(base + MG_KR0),
+                    );
+                    builder.assert_eq(
+                        e(base + MG_M0) * q1.clone() + e(base + MG_M1) + e(base + MG_T1) + e(base + MG_KR0),
+                        e(base + MG_MM1) + beta.clone() * e(base + MG_KR1),
+                    );
+                    builder.assert_eq(
+                        e(base + MG_M1) * q1 + e(base + MG_KR1),
+                        e(base + MG_MM2) + beta.clone() * e(base + MG_KR2),
+                    );
+                    builder.assert_eq(e(base + MG_L0), e(base + MG_MM0));
+                    builder.assert_eq(e(base + MG_L1), e(base + MG_MM1));
+                    builder.assert_eq(e(base + MG_L2), e(base + MG_MM2));
+                    builder.assert_eq(e(base + MG_KL2), e(base + MG_KR2));
+                    // canonical residues: t < q, m < q
+                    builder.assert_eq(
+                        e(base + MG_T0) + beta.clone() * e(base + MG_T1) + e(base + MG_GT0) + beta.clone() * e(base + MG_GT1),
+                        qm1.clone(),
+                    );
+                    builder.assert_eq(
+                        e(base + MG_M0) + beta.clone() * e(base + MG_M1) + e(base + MG_GM0) + beta.clone() * e(base + MG_GM1),
+                        qm1.clone(),
+                    );
+                }
+
+                // ---- stage wiring on coefficient rows -----------------------------------------
+                // accumulate inputs are MATERIALIZED and ==-bound to the mult outputs (the tamper
+                // surface); the psub b-input is ==-bound to the t1s output (the ĉ∘t̂1 wire).
+                for j in 0..LDIM_M {
+                    builder.assert_eq(e(PCOL + j), mgv(MG_AZ0 + j * MG_COLS, MG_T0, MG_T1));
+                }
+                builder.assert_eq(e(PSUBCOL), mgv(MG_PSUB, MG_T0, MG_T1));
+                builder.assert_eq(mgv(MG_PSUB, MG_B0, MG_B1), mgv(MG_T1S, MG_T0, MG_T1));
+                let f_coeff: AB::Expr = prep[PF_COEFF].into();
+                builder.assert_zero(f_coeff * (mgv(MG_T1S, MG_Z0, MG_Z1) - AB::Expr::from_u64(D2)));
+
+                // out block bits
+                let ow = [12usize, 11, 12, 11, 3];
+                let ocols = [O0, O1, GO0, GO1, KKC];
+                let mut off = OBITS;
+                for (ci, &col) in ocols.iter().enumerate() {
+                    let mut acc = AB::Expr::ZERO;
+                    let mut wo = AB::Expr::ONE;
+                    for j in 0..ow[ci] {
+                        let bit: AB::Expr = row[off + j].into();
+                        builder.assert_zero(bit.clone() * (bit.clone() - one.clone()));
+                        acc = acc + bit * wo.clone();
+                        wo = wo.clone() + wo.clone();
+                    }
+                    builder.assert_eq(e(col), acc);
+                    off += ow[ci];
+                }
+                // accumulation-reduction: Σ P − PSUB + q = out + k·q  (in-field: LDIM_M·q < 2^26 < p),
+                // out < q by slack (VERBATIM ntt_accumulate_air.rs).
+                let out_val = e(O0) + beta.clone() * e(O1);
+                builder.assert_eq(out_val.clone() + e(GO0) + beta.clone() * e(GO1), qm1);
+                let mut acc_sum = AB::Expr::ZERO;
+                for j in 0..LDIM_M {
+                    acc_sum = acc_sum + e(PCOL + j);
+                }
+                builder.assert_eq(acc_sum - e(PSUBCOL) + q.clone(), out_val.clone() + e(KKC) * q);
+
+                // ---- diagonal reads (factored one-hot): banks + publics -----------------------
+                // The placed bank feeds the az b-input DIRECTLY (the reference bank→mult wire);
+                // ẑ/t̂1/ĉ are pinned to INPUT publics and ŵ_i = out_val to the OUTPUT public.
+                for a in 0..CHI_M {
+                    let fa: AB::Expr = prep[PF_CHI + a].into();
+                    for b in 0..CLO_M {
+                        let fb: AB::Expr = prep[PF_CLO + b].into();
+                        let g = fa.clone() * fb;
+                        let k = a * CLO_M + b;
+                        for j in 0..LDIM_M {
+                            // mult b-input == the PLACED bank coefficient (the sampling→mult wire)
+                            builder.assert_zero(
+                                g.clone()
+                                    * (mgv(MG_AZ0 + j * MG_COLS, MG_B0, MG_B1)
+                                        - Into::<AB::Expr>::into(row[BANK + j * NM + k])),
+                            );
+                            // mult ζ-input == ẑ[j][k] public
+                            builder.assert_zero(
+                                g.clone() * (mgv(MG_AZ0 + j * MG_COLS, MG_Z0, MG_Z1) - pis[PI_Z_M + j * NM + k].clone()),
+                            );
+                        }
+                        builder.assert_zero(g.clone() * (mgv(MG_T1S, MG_B0, MG_B1) - pis[PI_T1_M + k].clone()));
+                        builder.assert_zero(g.clone() * (mgv(MG_PSUB, MG_Z0, MG_Z1) - pis[PI_C_M + k].clone()));
+                        builder.assert_zero(g * (out_val.clone() - pis[PI_OUT_M + k].clone()));
+                    }
+                }
+            }
+        }
+
+        // ---- trace generation (verbatim structure; reduced counts) ----
+        /// Fill the candidate gadget for a 24-bit value with counter state (verbatim, N=NM).
+        /// Returns place.
+        fn fill_cand<F: PrimeField64>(vals: &mut [F], base: usize, v: u64, cnt: usize) -> bool {
+            assert!(v < TWO24);
+            let t = v & 0x7F_FFFF;
+            let lt = if t < Q { 1u64 } else { 0 };
+            let diff = t + lt * TWO24 - Q;
+            for j in 0..24 {
+                vals[base + CIN + j] = F::from_u64((v >> j) & 1);
+                vals[base + CDIFFB + j] = F::from_u64((diff >> j) & 1);
+            }
+            vals[base + CT] = F::from_u64(t);
+            vals[base + CLT] = F::from_u64(lt);
+            vals[base + CDIFF] = F::from_u64(diff);
+            let u = (NM - cnt) as u64;
+            let act = if u != 0 { 1u64 } else { 0 };
+            let place = lt == 1 && act == 1;
+            vals[base + CCNT] = F::from_u64(cnt as u64);
+            vals[base + CU] = F::from_u64(u);
+            for j in 0..9 {
+                vals[base + CUB + j] = F::from_u64((u >> j) & 1);
+            }
+            vals[base + CINVU] = if u != 0 { F::from_u64(u).inverse() } else { F::ZERO };
+            vals[base + CACT] = F::from_u64(act);
+            vals[base + CPLACE] = F::from_u64(place as u64);
+            if place {
+                vals[base + CSEL + cnt] = F::ONE;
+            }
+            place
+        }
+
+        /// Valid zero fill of the candidate gadget (readout + padding rows): v=0 ⇒ t=0<q ⇒ lt=1,
+        /// diff=2^24−q; cnt=u=act=place=0 (the f_cand/f_step/... gates are off on these rows).
+        fn fill_cand_zero<F: PrimeField64>(vals: &mut [F], base: usize) {
+            let diff = TWO24 - Q;
+            for j in 0..24 {
+                vals[base + CDIFFB + j] = F::from_u64((diff >> j) & 1);
+            }
+            vals[base + CLT] = F::ONE;
+            vals[base + CDIFF] = F::from_u64(diff);
+        }
+
+        fn split(v: u64) -> (u64, u64) {
+            (v % BETA, v / BETA)
+        }
+
+        /// Fill one mod-q mult gadget (VERBATIM arithmetic from ntt_mul_air.rs). Returns t = ζ·b mod q.
+        fn fill_mult<F: PrimeField64>(vals: &mut [F], off: usize, zeta: u64, b: u64) -> u64 {
+            assert!(zeta < (1 << 23) && b < (1 << 23));
+            let (z0, z1) = split(zeta);
+            let (b0, b1) = split(b);
+            let prod = (zeta as u128) * (b as u128);
+            let t = (prod % Q as u128) as u64;
+            let mm = (prod / Q as u128) as u64;
+            let (m0, m1) = split(mm);
+            let (t0, t1) = split(t);
+            let s0 = z0 * b0;
+            let (l0, kl0) = (s0 % BETA, s0 / BETA);
+            let s1 = z0 * b1 + z1 * b0 + kl0;
+            let (l1, kl1) = (s1 % BETA, s1 / BETA);
+            let s2 = z1 * b1 + kl1;
+            let (l2, kl2) = (s2 % BETA, s2 / BETA);
+            let u0 = m0 + t0;
+            let (mm0, kr0) = (u0 % BETA, u0 / BETA);
+            let u1 = m0 * Q1 + m1 + t1 + kr0;
+            let (mm1, kr1) = (u1 % BETA, u1 / BETA);
+            let u2 = m1 * Q1 + kr1;
+            let (mm2, kr2) = (u2 % BETA, u2 / BETA);
+            assert_eq!((l0, l1, l2, kl2), (mm0, mm1, mm2, kr2), "limb mismatch (zeta={zeta}, b={b})");
+            let (gt0, gt1) = split((Q - 1) - t);
+            let (gm0, gm1) = split((Q - 1) - mm);
+            let prim = [
+                (MG_Z0, z0), (MG_Z1, z1), (MG_B0, b0), (MG_B1, b1),
+                (MG_M0, m0), (MG_M1, m1), (MG_T0, t0), (MG_T1, t1),
+                (MG_KL0, kl0), (MG_KL1, kl1), (MG_KL2, kl2),
+                (MG_KR0, kr0), (MG_KR1, kr1), (MG_KR2, kr2),
+                (MG_L0, l0), (MG_L1, l1), (MG_L2, l2),
+                (MG_MM0, mm0), (MG_MM1, mm1), (MG_MM2, mm2),
+                (MG_GT0, gt0), (MG_GT1, gt1), (MG_GM0, gm0), (MG_GM1, gm1),
+            ];
+            for (col, v) in prim {
+                vals[off + col] = F::from_u64(v);
+                let bo = off + mg_bit_off(col);
+                for j in 0..MG_WIDTHS[col] {
+                    vals[bo + j] = F::from_u64((v >> j) & 1);
+                }
+            }
+            t
+        }
+
+        /// Valid zero fill of the out block: Σ0 − 0 + q = 0 + 1·q ⇒ out = 0, kk = 1, slack = q−1.
+        /// (VERBATIM ntt_accumulate_air.rs reduction.) Returns out.
+        fn fill_out<F: PrimeField64>(vals: &mut [F], base: usize, psum: u64, psub: u64) -> u64 {
+            let s = psum + Q - psub;
+            let out = s % Q;
+            let kk = s / Q;
+            assert!(kk < 8);
+            let (o0, o1) = split(out);
+            let (g0, g1) = split(Q - 1 - out);
+            let prim = [(O0, o0), (O1, o1), (GO0, g0), (GO1, g1), (KKC, kk)];
+            let ow = [12usize, 11, 12, 11, 3];
+            let mut off = OBITS;
+            for (ci, &(col, v)) in prim.iter().enumerate() {
+                vals[base + col] = F::from_u64(v);
+                for j in 0..ow[ci] {
+                    vals[base + off + j] = F::from_u64((v >> j) & 1);
+                }
+                off += ow[ci];
+            }
+            out
+        }
+
+        /// Build the full Leg-M trace + pis: placement core + matvec arithmetic tail. `zhat/t1n/chat`
+        /// are the representative canonical NTT-domain statement inputs (< q). Returns
+        /// (trace, placed Â[0..NM], ŵ_i[0..NM], pis).
+        pub fn generate<F: PrimeField64>(
+            stream: &[u8],
+            zhat: &[u64; NM],
+            t1n: &[u64; NM],
+            chat: &[u64; NM],
+        ) -> (RowMajorMatrix<F>, [u64; NM], [u64; NM], Vec<F>) {
+            assert_eq!(stream.len(), CBUDM * 3, "Leg M expects the {}-byte budget stream", CBUDM * 3);
+            let mut vals = F::zero_vec(HEIGHT_M * NUM_COLS_M);
+            let mut bank = [0u64; NM];
+
+            // candidate rows
+            let mut cnt = 0usize;
+            for rr in 0..CBUDM {
+                let base = rr * NUM_COLS_M;
+                // bank state BEFORE this row's candidate
+                for k in 0..NM {
+                    vals[base + BANK + k] = F::from_u64(bank[k]);
+                }
+                let ch = &stream[3 * rr..3 * rr + 3];
+                let v = ch[0] as u64 | (ch[1] as u64) << 8 | (ch[2] as u64) << 16;
+                let place = fill_cand(&mut vals[base..base + NUM_COLS_M], 0, v, cnt);
+                if place {
+                    bank[cnt] = v & 0x7F_FFFF;
+                    cnt += 1;
+                }
+                if rr == CBUDM - 1 {
+                    assert_eq!(cnt, NM, "entry: {NM}th acceptance must precede the last budget row");
+                    assert!(!place);
+                }
+                // valid zero fill of the coefficient block (mult gadgets are unconditional)
+                for g in 0..(LDIM_M + 2) {
+                    fill_mult(&mut vals[base..base + NUM_COLS_M], CB + g * MG_COLS, 0, 0);
+                }
+                fill_out(&mut vals[base..base + NUM_COLS_M], 0, 0, 0);
+            }
+            assert_eq!(cnt, NM);
+            let ahat = bank;
+
+            // coefficient rows: banks thread the final placed poly; compute ŵ_i per coefficient.
+            //   P[0] = Â[0][jj]·ẑ[0][jj] mod q ; t1s = 8192·t̂1[jj] mod q ; psub = ĉ[jj]·t1s mod q ;
+            //   ŵ_i[jj] = (Σ P − psub) mod q  (VERBATIM fill_mult / fill_out arithmetic).
+            let mut what = [0u64; NM];
+            for jj in 0..NM {
+                let base = (COEFF0_M + jj) * NUM_COLS_M;
+                for k in 0..NM {
+                    vals[base + BANK + k] = F::from_u64(bank[k]);
+                }
+                fill_cand_zero(&mut vals[base..base + NUM_COLS_M], 0);
+                let mut psum = 0u64;
+                for j in 0..LDIM_M {
+                    let p = fill_mult(&mut vals[base..base + NUM_COLS_M], MG_AZ0 + j * MG_COLS, zhat[jj], ahat[jj]);
+                    vals[base + PCOL + j] = F::from_u64(p);
+                    psum += p;
+                }
+                let t1sv = fill_mult(&mut vals[base..base + NUM_COLS_M], MG_T1S, D2, t1n[jj]);
+                let psv = fill_mult(&mut vals[base..base + NUM_COLS_M], MG_PSUB, chat[jj], t1sv);
+                vals[base + PSUBCOL] = F::from_u64(psv);
+                what[jj] = fill_out(&mut vals[base..base + NUM_COLS_M], 0, psum, psv);
+            }
+            // padding rows: valid zero fill everywhere, bank 0
+            for r in REAL_ROWS_M..HEIGHT_M {
+                let base = r * NUM_COLS_M;
+                fill_cand_zero(&mut vals[base..base + NUM_COLS_M], 0);
+                for g in 0..(LDIM_M + 2) {
+                    fill_mult(&mut vals[base..base + NUM_COLS_M], CB + g * MG_COLS, 0, 0);
+                }
+                fill_out(&mut vals[base..base + NUM_COLS_M], 0, 0, 0);
+            }
+
+            // publics: [pi_stream (320) ‖ ẑ (64) ‖ t̂1 (64) ‖ ĉ (64) ‖ ŵ_i (64)]
+            let mut pis: Vec<F> = Vec::with_capacity(NUM_PIS_M);
+            for rr in 0..CBUDM {
+                let ch = &stream[3 * rr..3 * rr + 3];
+                let v = ch[0] as u64 | (ch[1] as u64) << 8 | (ch[2] as u64) << 16;
+                pis.push(F::from_u64(v));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(zhat[k]));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(t1n[k]));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(chat[k]));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(what[k]));
+            }
+            assert_eq!(pis.len(), NUM_PIS_M);
+            (RowMajorMatrix::new(vals, NUM_COLS_M), ahat, what, pis)
+        }
+    }
+    fn libcrux_seed5_rho() -> [u8; 32] {
+        let seed: [u8; 32] = core::array::from_fn(|k| (0x1b_u8).wrapping_mul(k as u8 + 1) ^ 5);
+        let mut sh = Shake::v256(); // SHAKE256, DELIM 0x1F
+        sh.update(&seed);
+        sh.update(&[8u8, 7u8]); // [ROWS_IN_A, COLUMNS_IN_A] for ML-DSA-87
+        let mut expanded = [0u8; 128];
+        sh.finalize(&mut expanded);
+        let mut rho = [0u8; 32];
+        rho.copy_from_slice(&expanded[0..32]);
+        rho
+    }
+
+    /// Representative canonical NTT-domain statement inputs `ẑ[0] / t̂1_i / ĉ` (each < q), for the
+    /// matvec tail. The tail's job is the ARITHMETIC, not re-deriving ẑ/ĉ/t̂1 — those come from
+    /// their own stages/publics in the full composition. Deterministic SplitMix64 residues mod q,
+    /// so the run is reproducible and the ŵ_i diff-test is meaningful.
+    fn rep_ntt_inputs() -> ([u64; matvec::NM], [u64; matvec::NM], [u64; matvec::NM]) {
+        let mut s = 0x_C0FF_EE12_3456_789Au64;
+        let mut nextq = || {
+            s = s.wrapping_add(0x9E3779B97F4A7C15);
+            let mut z = s;
+            z = (z ^ (z >> 30)).wrapping_mul(0xBF58476D1CE4E5B9);
+            z = (z ^ (z >> 27)).wrapping_mul(0x94D049BB133111EB);
+            (z ^ (z >> 31)) % Q
+        };
+        let zhat: [u64; matvec::NM] = core::array::from_fn(|_| nextq());
+        let t1n: [u64; matvec::NM] = core::array::from_fn(|_| nextq());
+        let chat: [u64; matvec::NM] = core::array::from_fn(|_| nextq());
+        (zhat, t1n, chat)
+    }
+
+    /// The exact ExpandA byte source, SHAKE128(ρ ‖ s ‖ r), via an INDEPENDENT XOF (`tiny_keccak`).
+    fn shake128_stream(rho: &[u8; 32], s: u8, r: u8, outlen: usize) -> Vec<u8> {
+        let mut sh = Shake::v128();
+        sh.update(rho);
+        sh.update(&[s, r]);
+        let mut out = vec![0u8; outlen];
+        sh.finalize(&mut out);
+        out
+    }
+    // =======================================================================================
+    // Native batch-STARK leg provers (single-instance batch proofs)
+    // =======================================================================================
+    type LegProof = (
+        BatchProof<ConfigWithFriParams>,
+        ProverData<ConfigWithFriParams>,
+        Vec<F>,
+    );
+
+    /// Prove Leg M (ExpandA placement + matvec arithmetic tail); return (proof, placed Â, ŵ_i).
+    fn prove_matvec_leg(
+        config: &ConfigWithFriParams,
+        stream: &[u8],
+        zhat: &[u64; matvec::NM],
+        t1n: &[u64; matvec::NM],
+        chat: &[u64; matvec::NM],
+    ) -> (LegProof, [u64; matvec::NM], [u64; matvec::NM]) {
+        let air = matvec::ExpandaPlaceAir {};
+        let (trace, ahat, what, pis) = matvec::generate::<F>(stream, zhat, t1n, chat);
+        let instances = vec![StarkInstance { air: &air, trace: &trace, public_values: pis.clone() }];
+        let prover_data = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &prover_data);
+        verify_batch(config, core::slice::from_ref(&air), &proof, core::slice::from_ref(&pis), &prover_data.common)
+            .expect("native Leg M batch verify failed");
+        ((proof, prover_data, pis), ahat, what)
+    }
+
+    /// Prove Leg I (invNTT bridge) over the ŵ slice; return (proof, ..., publics) and the w output.
+    fn prove_invntt_leg(
+        config: &ConfigWithFriParams,
+        air: &invntt::InvNttAir,
+        what_in: &[u64; NJOIN],
+    ) -> (LegProof, [u64; NJOIN]) {
+        let (trace, w_out) = invntt::generate::<F>(what_in, &air.zetas, air.ninv);
+        let pis = invntt::build_pis::<F>(what_in, &w_out);
+        let instances = vec![StarkInstance { air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .expect("native Leg I batch verify failed");
+        ((proof, pd, pis), w_out)
+    }
+
+    /// Whether Leg I over a trace with a TAMPERED butterfly output is REJECTED by native verify
+    /// (the invNTT's own cross-layer routing catches it). Perturbs bf8's a-input limb (must equal
+    /// bf4.out0), an internally-consistent-looking change that violates only the routing.
+    fn invntt_tamper_rejects(config: &ConfigWithFriParams, air: &invntt::InvNttAir, what_in: &[u64; NJOIN]) -> bool {
+        let (mut trace, w_out) = invntt::generate::<F>(what_in, &air.zetas, air.ninv);
+        // bf8 base = 8 * 480; A0 = column 24. Flip the low limb of its a-input.
+        let a0 = 8 * 480 + 24;
+        trace.values[a0] += F::ONE;
+        let pis = invntt::build_pis::<F>(what_in, &w_out);
+        let instances = vec![StarkInstance { air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .is_err()
+    }
+
+    /// Prove Leg U (UseHint) over (w, h) pairs; return (proof, ..., publics) and the w1 vector.
+    fn prove_usehint_leg(
+        config: &ConfigWithFriParams,
+        air: &usehint::UseHintAir,
+        data: &[(i64, bool)],
+    ) -> (LegProof, Vec<i64>) {
+        let (trace, w1v) = usehint::generate::<F>(data);
+        let w: Vec<i64> = data.iter().map(|&(r, _)| r).collect();
+        let pis = usehint::build_pis::<F>(&w, &w1v);
+        let instances = vec![StarkInstance { air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .expect("native Leg U batch verify failed");
+        ((proof, pd, pis), w1v)
+    }
+
+    // =======================================================================================
+    // THREE-stage outer recursion: verify Leg M + Leg I + Leg U in ONE circuit, bind the TWO
+    // NEW cross-stage ties (M↔I ŵ, I↔U w), produce ONE outer proof = the joined verify tail.
+    // =======================================================================================
+    #[allow(clippy::too_many_arguments)]
+    fn build_and_prove_outer3(
+        config: &ConfigWithFriParams,
+        fvp: &FriVerifierParams,
+        fri_params: &FriParams,
+        air_m: &matvec::ExpandaPlaceAir,
+        leg_m: &LegProof,
+        air_i: &invntt::InvNttAir,
+        leg_i: &LegProof,
+        air_u: &usehint::UseHintAir,
+        leg_u: &LegProof,
+        do_connect: bool,
+    ) -> Result<(usize, u32), String> {
+        let (proof_m, pd_m, pub_m) = leg_m;
+        let (proof_i, pd_i, pub_i) = leg_i;
+        let (proof_u, pd_u, pub_u) = leg_u;
+        let perm = p3_koala_bear::default_koalabear_poseidon2_16();
+        let mut cb = CircuitBuilder::new();
+        cb.enable_poseidon2_perm::<p3_poseidon2_circuit_air::KoalaBearD4Width16, _>(
+            generate_poseidon2_trace::<Challenge, p3_poseidon2_circuit_air::KoalaBearD4Width16>,
+            perm,
+        );
+        cb.enable_recompose::<F>(generate_recompose_trace::<F, Challenge>);
+        let lookup_gadget = LogUpGadget::new();
+
+        macro_rules! verify_leg {
+            ($proof:expr, $pd:expr, $pub:expr, $air:expr, $what:literal) => {{
+                let vi = BatchStarkVerifierInputsBuilder::<
+                    ConfigWithFriParams,
+                    MerkleCapTargets<F, DIGEST_ELEMS>,
+                    InnerFri,
+                >::allocate(&mut cb, $proof, &$pd.common, &[$pub.len()]);
+                let op_ids = verify_batch_circuit::<_, _, _, _, _, _, _, WIDTH, RATE>(
+                    config,
+                    core::slice::from_ref($air),
+                    &mut cb,
+                    &vi.proof_targets,
+                    &vi.air_public_targets,
+                    fvp,
+                    &vi.common_data,
+                    &lookup_gadget,
+                    Poseidon2Config::KOALA_BEAR_D4_W16,
+                )
+                .map_err(|e| format!("build {} verify circuit: {e:?}", $what))?;
+                (vi, op_ids)
+            }};
+        }
+
+        let (vi_m, op_ids_m) = verify_leg!(proof_m, pd_m, pub_m, air_m, "Leg M");
+        let (vi_i, op_ids_i) = verify_leg!(proof_i, pd_i, pub_i, air_i, "Leg I");
+        let (vi_u, op_ids_u) = verify_leg!(proof_u, pd_u, pub_u, air_u, "Leg U");
+
+        // ---- TWO NEW cross-stage ties (each an ALU sub asserted zero — each public read once) ----
+        if do_connect {
+            // Tie 1 (M↔I): Leg-M ŵ_i[k] (OUTPUT) == Leg-I ŵ_in[k] (INPUT).
+            for k in 0..NJOIN {
+                let diff = cb.sub(
+                    vi_m.air_public_targets[0][matvec::PI_OUT_M + k],
+                    vi_i.air_public_targets[0][invntt::PI_WHAT + k],
+                );
+                cb.assert_zero(diff);
+            }
+            // Tie 2 (I↔U): Leg-I w_out[k] (OUTPUT) == Leg-U w_in[k] (INPUT, publics [0..NW1]).
+            for k in 0..NJOIN {
+                let diff = cb.sub(
+                    vi_i.air_public_targets[0][invntt::PI_W + k],
+                    vi_u.air_public_targets[0][k],
+                );
+                cb.assert_zero(diff);
+            }
+        }
+
+        let vc = cb.build().map_err(|e| format!("outer circuit build: {e:?}"))?;
+        let witness_count = vc.witness_count;
+        println!("  recursion circuit (3-leg M∘I∘U): witness_count={witness_count}, connect={do_connect}");
+
+        // Pack public/private inputs in allocation order (M, I, U).
+        let (pub_in_m, priv_in_m) = vi_m.pack_values(core::slice::from_ref(pub_m), proof_m, &pd_m.common);
+        let (pub_in_i, priv_in_i) = vi_i.pack_values(core::slice::from_ref(pub_i), proof_i, &pd_i.common);
+        let (pub_in_u, priv_in_u) = vi_u.pack_values(core::slice::from_ref(pub_u), proof_u, &pd_u.common);
+        let mut public_inputs = pub_in_m;
+        public_inputs.extend(pub_in_i);
+        public_inputs.extend(pub_in_u);
+        let mut private_inputs = priv_in_m;
+        private_inputs.extend(priv_in_i);
+        private_inputs.extend(priv_in_u);
+
+        let mut runner = vc.runner();
+        runner.set_public_inputs(&public_inputs).map_err(|e| format!("set publics: {e:?}"))?;
+        runner.set_private_inputs(&private_inputs).map_err(|e| format!("set privates: {e:?}"))?;
+        for (op_ids, proof) in [(&op_ids_m, proof_m), (&op_ids_i, proof_i), (&op_ids_u, proof_u)] {
+            set_fri_mmcs_private_data::<F, Challenge, ChallengeMmcs, MyMmcs, MyHash, MyCompress, DIGEST_ELEMS>(
+                &mut runner,
+                op_ids,
+                &proof.opening_proof,
+                Poseidon2Config::KOALA_BEAR_D4_W16,
+            )
+            .map_err(|e| format!("mmcs private data: {e}"))?;
+        }
+
+        // NEGATIVE cases fail HERE (aliased cross-stage public with a conflicting value).
+        let traces = runner.run().map_err(|e| format!("recursion circuit run rejected: {e:?}"))?;
+
+        // ---- Prove the outer (aggregated) proof ----
+        let l1_packing = TablePacking::new(1, 2)
+            .with_fri_params(fri_params.log_final_poly_len, fri_params.log_blowup);
+        let npo_prep: Vec<Box<dyn NpoPreprocessor<F>>> =
+            vec![Box::new(Poseidon2Preprocessor), Box::new(RecomposePreprocessor::default())];
+        let mut air_builders = poseidon2_air_builders::<ConfigWithFriParams, D>();
+        air_builders.extend(recompose_air_builders::<ConfigWithFriParams, D>(1, false));
+        let (airs_degrees, prim_cols, non_prim_cols) =
+            get_airs_and_degrees_with_prep::<ConfigWithFriParams, Challenge, D>(
+                &vc,
+                &l1_packing,
+                &npo_prep,
+                &air_builders,
+                ConstraintProfile::Standard,
+            )
+            .map_err(|e| format!("outer airs/degrees: {e:?}"))?;
+        let (airs, degrees): (Vec<_>, Vec<usize>) = airs_degrees.into_iter().unzip();
+        let prover_data = ProverData::from_airs_and_degrees(config, &airs, &degrees);
+        let cpd = CircuitProverData::new(prover_data, prim_cols, non_prim_cols);
+        let mut prover = BatchStarkProver::new(config.clone())
+            .with_table_packing(l1_packing)
+            .with_alu_variant(AirVariant::Baseline);
+        prover.register_poseidon2_table::<D>(Poseidon2Config::KOALA_BEAR_D4_W16);
+        prover.register_recompose_table::<D>(false);
+        let proof = prover.prove_all_tables(&traces, &cpd).map_err(|e| format!("prove outer: {e:?}"))?;
+        prover.verify_all_tables::<Challenge>(&proof).map_err(|e| format!("verify outer: {e:?}"))?;
+        let bytes = postcard::to_allocvec(&proof).map_err(|e| format!("serialize outer: {e:?}"))?.len();
+        Ok((bytes, witness_count))
+    }
+
+    /// Representative (w, h) for the untied UseHint remainder [NJOIN..NW1]: deterministic residues
+    /// < q with a hint-bit pattern exercising both ±1 branches. The FIRST NJOIN coefficients are
+    /// OVERWRITTEN by the invNTT bridge output w in `run()`.
+    fn representative_w_h() -> Vec<(i64, bool)> {
+        let mut s = 0xACCE_7741_1234_5678u64;
+        let mut nextu = || {
+            s = s.wrapping_add(0x9E3779B97F4A7C15);
+            let mut z = s;
+            z = (z ^ (z >> 30)).wrapping_mul(0xBF58476D1CE4E5B9);
+            z = (z ^ (z >> 27)).wrapping_mul(0x94D049BB133111EB);
+            z ^ (z >> 31)
+        };
+        (0..NW1)
+            .map(|_| {
+                let r = (nextu() % Q) as i64;
+                let h = (nextu() & 1) == 1;
+                (r, h)
+            })
+            .collect()
+    }
+
+    pub fn run() {
+        let fri_params = FriParams {
+            log_blowup: 2,
+            max_log_arity: 2,
+            cap_height: 0,
+            log_final_poly_len: 5,
+            commit_pow_bits: 0,
+            query_pow_bits: 15,
+        };
+        let config = config_with_fri_params(&fri_params, SECURITY, false);
+        let fvp = create_fri_verifier_params(&fri_params, SECURITY);
+
+        let (zetas8, ninv8) = invntt::params();
+        let air_m = matvec::ExpandaPlaceAir {};
+        let air_i = invntt::InvNttAir { zetas: zetas8, ninv: ninv8 };
+        let air_u = usehint::UseHintAir {};
+
+        info!(
+            "verify-tail JOIN: Leg M (matvec {}×{}, {} pubs), Leg I (invNTT n=8 {}×{}, {} pubs), \
+             Leg U (UseHint {}×{}, {} pubs); NM={}, NW1={NW1}, NJOIN={NJOIN}, security={SECURITY}",
+            matvec::NUM_COLS_M, matvec::HEIGHT_M, matvec::NUM_PIS_M,
+            invntt::NUM_COLS, invntt::height(), invntt::num_pis(),
+            usehint::NUM_COLS, usehint::height(), usehint::num_pis(),
+            matvec::NM,
+        );
+
+        // ================= GATE 0: invNTT gadget correctness (round-trip vs ntt_zq reference) =====
+        {
+            // invNTT(NTT(x)) == x, coefficient-exact, over deterministic random x (the ntt_zq oracle).
+            let mut s = 0x9151_C0DE_2718_2818u64;
+            let mut nextq = || {
+                s = s.wrapping_add(0x9E3779B97F4A7C15);
+                let mut z = s;
+                z = (z ^ (z >> 30)).wrapping_mul(0xBF58476D1CE4E5B9);
+                z = (z ^ (z >> 27)).wrapping_mul(0x94D049BB133111EB);
+                (z ^ (z >> 31)) % Q
+            };
+            for _ in 0..200 {
+                let x: [u64; NJOIN] = std::array::from_fn(|_| nextq());
+                let rt = invntt::invntt8_scaled(&invntt::ntt8(&x, &zetas8), &zetas8, ninv8);
+                assert_eq!(rt, x, "invNTT(NTT(x)) must recover x (n=8, scaled)");
+            }
+        }
+        println!("GATE 0 ok — invNTT gadget: invNTT(NTT(x)) == x coefficient-exact over 200 random x (n=8, inv(8) scaled), the ntt_zq round-trip oracle.");
+
+        // ================= build the REAL front: matvec ŵ_i from libcrux seed-5 ρ ================
+        let rho = libcrux_seed5_rho();
+        let stream0 = shake128_stream(&rho, 0, I_ROW as u8, STREAM_BYTES); // the ExpandA candidate bytes
+        let (zhat_m, t1n_m, chat_m) = rep_ntt_inputs();
+        let t = Instant::now();
+        let (leg_m, _ahat_m, what_m) = prove_matvec_leg(&config, &stream0, &zhat_m, &t1n_m, &chat_m);
+        println!(
+            "Leg M (matvec front) batch proof: {} bytes, {} pubs, real seed-5 ρ, {:.1?}",
+            postcard::to_allocvec(&leg_m.0).unwrap().len(), leg_m.2.len(), t.elapsed()
+        );
+        // The ŵ slice the bridge consumes = matvec's REAL output ŵ_i[0..NJOIN].
+        let what8: [u64; NJOIN] = std::array::from_fn(|k| what_m[k]);
+        for k in 0..NJOIN {
+            assert_eq!(leg_m.2[matvec::PI_OUT_M + k], F::from_u64(what8[k]), "Leg M public ŵ[{k}] != trace ŵ");
+        }
+
+        // ================= Leg I: the invNTT bridge over matvec's ŵ slice ================
+        let t = Instant::now();
+        let (leg_i, w8) = prove_invntt_leg(&config, &air_i, &what8);
+        // GATE 1: Leg I output w == reference invNTT(ŵ), coefficient-exact.
+        let w_ref = invntt::invntt8_scaled(&what8, &zetas8, ninv8);
+        assert_eq!(w8, w_ref, "Leg I trace w != reference invNTT(ŵ)");
+        for k in 0..NJOIN {
+            assert_eq!(leg_i.2[invntt::PI_WHAT + k], F::from_u64(what8[k]), "Leg I public ŵ_in[{k}] != ŵ");
+            assert_eq!(leg_i.2[invntt::PI_W + k], F::from_u64(w8[k]), "Leg I public w_out[{k}] != w");
+        }
+        println!(
+            "Leg I (invNTT bridge) batch proof: {} bytes, {} pubs, {} cols × {} rows, w == invNTT(ŵ) exact, {:.1?}",
+            postcard::to_allocvec(&leg_i.0).unwrap().len(), leg_i.2.len(), invntt::NUM_COLS, invntt::height(), t.elapsed()
+        );
+
+        // ================= Leg U: UseHint consuming the bridge output w ================
+        // First NJOIN w := the invNTT bridge output; the untied remainder is representative.
+        let mut data = representative_w_h();
+        for k in 0..NJOIN {
+            data[k].0 = w8[k] as i64;
+        }
+        let t = Instant::now();
+        let (leg_u, _w1v) = prove_usehint_leg(&config, &air_u, &data);
+        for k in 0..NJOIN {
+            assert_eq!(leg_u.2[k], F::from_u64(w8[k]), "Leg U public w_in[{k}] != bridge w");
+        }
+        println!(
+            "Leg U (UseHint) batch proof: {} bytes, {} pubs, {:.1?}",
+            postcard::to_allocvec(&leg_u.0).unwrap().len(), leg_u.2.len(), t.elapsed()
+        );
+
+        // ================= [1] HONEST: M∘I∘U, both ties → the whole tail composes ================
+        let t = Instant::now();
+        let (bytes, wc) = build_and_prove_outer3(
+            &config, &fvp, &fri_params, &air_m, &leg_m, &air_i, &leg_i, &air_u, &leg_u, true,
+        )
+        .expect("HONEST join must succeed");
+        println!(
+            "[1] HONEST  (ŵ_i →invNTT→ w →UseHint, Tie1 M↔I + Tie2 I↔U): outer proof OK = the WHOLE \
+             verify tail composes, {bytes} bytes, witness_count={wc}, {:.1?}",
+            t.elapsed()
+        );
+
+        // ================= [2] NEG-W (w inconsistent with invNTT(ŵ) fed to UseHint) ================
+        // UseHint over a w' whose first coeff != the bridge output → Tie 2 (I↔U) mismatch → REJECT.
+        let mut data_bad = data.clone();
+        data_bad[0].0 = (w8[0] as i64 + 1).rem_euclid(QI); // a different valid residue
+        assert_ne!(data_bad[0].0, w8[0] as i64);
+        let (leg_u_bad, _) = prove_usehint_leg(&config, &air_u, &data_bad);
+        let t = Instant::now();
+        match build_and_prove_outer3(
+            &config, &fvp, &fri_params, &air_m, &leg_m, &air_i, &leg_i, &air_u, &leg_u_bad, true,
+        ) {
+            Err(e) => println!(
+                "[2] NEG-W (UseHint w[0] != invNTT(ŵ)[0]; Tie 2 I↔U): REJECTED at prove, {:.1?} -- {e}",
+                t.elapsed()
+            ),
+            Ok(_) => panic!("NEG-W must NOT produce an outer proof"),
+        }
+
+        // ================= [3] NEG-BF (tamper one invNTT butterfly output) ================
+        // Perturb bf8's a-input (must equal bf4.out0): Leg I's cross-layer routing catches it.
+        let neg_bf = invntt_tamper_rejects(&config, &air_i, &what8);
+        assert!(neg_bf, "NEG-BF: a tampered invNTT butterfly must be REJECTED by native Leg I verify");
+        println!(
+            "[3] NEG-BF (bf8 a-input tampered, breaks layer2→layer3 routing): Leg I batch proof \
+             REJECTED at native verify = the invNTT's in-AIR cross-layer routing genuinely gates."
+        );
+
+        // ================= [4] NEG-WH (ŵ slice fed to invNTT != matvec's real ŵ) ================
+        // Build the bridge over ŵ' (first coeff bumped) — internally a valid invNTT, but Tie 1
+        // (M↔I) against matvec's REAL ŵ fails.
+        let mut what8_bad = what8;
+        what8_bad[0] = (what8_bad[0] + 1) % Q;
+        assert_ne!(what8_bad[0], what8[0]);
+        let (leg_i_bad, _w8_bad) = prove_invntt_leg(&config, &air_i, &what8_bad);
+        let t = Instant::now();
+        match build_and_prove_outer3(
+            &config, &fvp, &fri_params, &air_m, &leg_m, &air_i, &leg_i_bad, &air_u, &leg_u, true,
+        ) {
+            Err(e) => println!(
+                "[4] NEG-WH (invNTT ŵ_in[0] != matvec ŵ[0]; Tie 1 M↔I): REJECTED at prove, {:.1?} -- {e}",
+                t.elapsed()
+            ),
+            Ok(_) => panic!("NEG-WH must NOT produce an outer proof"),
+        }
+
+        println!(
+            "VERIFY-TAIL JOIN demonstrated: matvec ŵ_i → invNTT → w → UseHint composed as ONE \
+             recursion tree over THREE HETEROGENEOUS gadgets (ExpandaPlaceAir ∘ InvNttAir ∘ \
+             UseHintAir), the invNTT bridge landed as a real batch-STARK leg (complete GS n=8 \
+             inverse + inv(8) scaling, round-trip-checked vs ntt_zq), and the TWO NEW cross-stage \
+             ties (ŵ M↔I, w I↔U) PROVEN in-circuit — the invNTT is the missing link that welds the \
+             ExpandA INPUT end (ρ→ŵ) to the accept OUTPUT end (w→…→c̃'==c̃) into ONE continuous \
+             recursion chain for the whole ML-DSA-87 verify tail."
+        );
+    }
+}
