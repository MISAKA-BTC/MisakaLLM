+++ b/circuit/src/ops/public_surface.rs
@@ -0,0 +1,275 @@
+//! Public-surface non-primitive operation: re-exposes already-constrained circuit
+//! witnesses as the proof's own (batch-level) public values.
+//!
+//! Motivation (recursive statement surfacing): a batch-STARK proof of a circuit keeps the
+//! circuit's "public inputs" inside the committed Public-table trace — they are witness
+//! data, existentially quantified from the outer verifier's point of view. A recursion
+//! chain built from such proofs therefore proves "there EXISTS a statement the inner proof
+//! verifies against", which is not enough for a consensus verifier that must bind the
+//! proof to an on-chain statement. This op closes that gap:
+//!
+//! - the circuit CONSUMES the selected witnesses on the `WitnessChecks` bus (one LogUp
+//!   receive per value, multiplicity −1), so the table's committed cells are forced to
+//!   equal the circuit's witness values, and
+//! - the paired AIR (`PublicSurfaceAir` in `p3-circuit-prover`) constrains those cells,
+//!   on the first trace row, to equal the instance's STARK public values — the
+//!   `non_primitives[k].public_values` field of `BatchStarkProof` that a native verifier
+//!   checks via `verify_batch`.
+//!
+//! Soundness therefore does NOT rest on the prover-supplied `public_values` bytes: claimed
+//! values that differ from the committed (bus-bound) cells fail the first-row constraint,
+//! and committed cells that differ from the circuit's witness values unbalance the bus.
+//!
+//! All surfaced values are read via a `[idx, v, 0, …, 0]` bus message (like the recompose
+//! coefficient reads), which additionally forces each surfaced witness to be a BASE-field
+//! value (extension coefficients 1..D must be zero for the bus to balance).
+
+use alloc::boxed::Box;
+use alloc::string::ToString;
+use alloc::vec::Vec;
+use alloc::{format, vec};
+use core::any::Any;
+use core::fmt::Debug;
+
+use p3_field::{ExtensionField, Field, PrimeField64};
+
+use crate::CircuitError;
+use crate::builder::{CircuitBuilderError, NpoCircuitPlugin, NpoLoweringContext};
+use crate::ops::{ExecutionContext, NonPrimitiveExecutor, NpoTypeId, Op, PreprocessedWriter};
+use crate::tables::{NonPrimitiveTrace, TraceGeneratorFn};
+use crate::types::{ExprId, WitnessId};
+
+// ============================================================================
+// Configuration
+// ============================================================================
+
+/// Config payload stored in `NpoConfig` for the public-surface table.
+#[derive(Debug, Clone)]
+pub(crate) struct PublicSurfaceConfig;
+
+// ============================================================================
+// Execution State
+// ============================================================================
+
+/// Execution state collecting the surfaced `(witness id, value)` pairs across all
+/// `add_public_surface` calls, in call order.
+#[derive(Debug, Default)]
+pub struct PublicSurfaceExecutionState<F> {
+    pub entries: Vec<(WitnessId, F)>,
+}
+
+// ============================================================================
+// Executor
+// ============================================================================
+
+/// Executor for public-surface operations: reads the input witnesses and records
+/// them for trace generation. Produces no outputs.
+#[derive(Debug, Clone)]
+pub struct PublicSurfaceExecutor {
+    op_type: NpoTypeId,
+}
+
+impl PublicSurfaceExecutor {
+    pub const fn new(op_type: NpoTypeId) -> Self {
+        Self { op_type }
+    }
+}
+
+impl<F: Field + Send + Sync + 'static> NonPrimitiveExecutor<F> for PublicSurfaceExecutor {
+    fn execute(
+        &self,
+        inputs: &[Vec<WitnessId>],
+        outputs: &[Vec<WitnessId>],
+        ctx: &mut ExecutionContext<'_, F>,
+    ) -> Result<(), CircuitError> {
+        if inputs.len() != 1 || inputs[0].is_empty() {
+            return Err(CircuitError::NonPrimitiveOpLayoutMismatch {
+                op: self.op_type.clone(),
+                expected: "1 non-empty input group".to_string(),
+                got: inputs.len(),
+            });
+        }
+        if !outputs.is_empty() {
+            return Err(CircuitError::NonPrimitiveOpLayoutMismatch {
+                op: self.op_type.clone(),
+                expected: "0 output groups".to_string(),
+                got: outputs.len(),
+            });
+        }
+
+        let mut entries = Vec::with_capacity(inputs[0].len());
+        for &wid in &inputs[0] {
+            entries.push((wid, ctx.get_witness(wid)?));
+        }
+
+        let state = ctx.get_op_state_mut::<PublicSurfaceExecutionState<F>>(&self.op_type);
+        state.entries.extend(entries);
+        Ok(())
+    }
+
+    fn op_type(&self) -> &NpoTypeId {
+        &self.op_type
+    }
+
+    fn preprocess(
+        &self,
+        inputs: &[Vec<WitnessId>],
+        _outputs: &[Vec<WitnessId>],
+        preprocessed: &mut dyn PreprocessedWriter<F>,
+    ) -> Result<(), CircuitError> {
+        // Per lane: [witness_idx (D-scaled), mult]. The table is a pure READER on the
+        // WitnessChecks bus, so its multiplicity is a constant −1 for every real lane
+        // (padding lanes stay all-zero); `register_non_primitive_witness_reads` also
+        // increments the creator-side read count so the bus stays balanced.
+        let neg_one = F::ZERO - F::ONE;
+        for &wid in &inputs[0] {
+            preprocessed.register_non_primitive_witness_reads(&self.op_type, &[wid])?;
+            preprocessed.register_non_primitive_preprocessed_no_read(&self.op_type, &[neg_one]);
+        }
+        Ok(())
+    }
+
+    fn num_exposed_outputs(&self) -> Option<usize> {
+        Some(0)
+    }
+
+    fn boxed(&self) -> Box<dyn NonPrimitiveExecutor<F>> {
+        Box::new(self.clone())
+    }
+}
+
+// ============================================================================
+// Circuit Plugin
+// ============================================================================
+
+/// Circuit-layer plugin for public-surface non-primitive operations.
+pub(crate) struct PublicSurfaceCircuitPlugin<F: Field> {
+    trace_gen: TraceGeneratorFn<F>,
+}
+
+impl<F: Field> PublicSurfaceCircuitPlugin<F> {
+    pub const fn new(trace_gen: TraceGeneratorFn<F>) -> Self {
+        Self { trace_gen }
+    }
+}
+
+impl<F: Field> Debug for PublicSurfaceCircuitPlugin<F> {
+    fn fmt(&self, f: &mut core::fmt::Formatter<'_>) -> core::fmt::Result {
+        f.debug_struct("PublicSurfaceCircuitPlugin").finish()
+    }
+}
+
+impl<F: Field> NpoCircuitPlugin<F> for PublicSurfaceCircuitPlugin<F> {
+    fn type_id(&self) -> NpoTypeId {
+        NpoTypeId::public_surface()
+    }
+
+    fn lower(
+        &self,
+        data: &crate::builder::NonPrimitiveOperationData<F>,
+        _output_exprs: &[(u32, ExprId)],
+        ctx: &mut NpoLoweringContext<'_, F>,
+    ) -> Result<Op<F>, CircuitBuilderError> {
+        if data.input_exprs.len() != 1 || data.input_exprs[0].is_empty() {
+            return Err(CircuitBuilderError::NonPrimitiveOpArity {
+                op: "PublicSurface",
+                expected: "1 non-empty input group".to_string(),
+                got: data.input_exprs.len(),
+            });
+        }
+
+        let input_wids: Vec<WitnessId> = data.input_exprs[0]
+            .iter()
+            .enumerate()
+            .map(|(i, &expr)| {
+                ctx.resolve_witness_id(expr, || format!("PublicSurface input {i}"))
+            })
+            .collect::<Result<_, _>>()?;
+
+        Ok(Op::NonPrimitiveOpWithExecutor {
+            inputs: vec![input_wids],
+            outputs: vec![],
+            executor: Box::new(PublicSurfaceExecutor::new(NpoTypeId::public_surface())),
+            op_id: data.op_id,
+        })
+    }
+
+    fn trace_generator(&self) -> TraceGeneratorFn<F> {
+        self.trace_gen
+    }
+
+    fn config(&self) -> crate::ops::NpoConfig {
+        crate::ops::NpoConfig::new(PublicSurfaceConfig)
+    }
+}
+
+// SAFETY: the only field is `trace_gen: TraceGeneratorFn<F>`, a bare `fn` pointer
+// (always `Send + Sync`); no `F` value is stored.
+unsafe impl<F: Field> Send for PublicSurfaceCircuitPlugin<F> {}
+unsafe impl<F: Field> Sync for PublicSurfaceCircuitPlugin<F> {}
+
+// ============================================================================
+// Trace
+// ============================================================================
+
+/// Trace for public-surface operations: the surfaced witness ids and their
+/// BASE-field values (extension coefficient 0), in surfacing order.
+#[derive(Debug, Clone)]
+pub struct PublicSurfaceTrace<F> {
+    pub input_wids: Vec<WitnessId>,
+    pub values: Vec<F>,
+}
+
+impl<TraceF: Clone + Send + Sync + 'static, CF> NonPrimitiveTrace<CF> for PublicSurfaceTrace<TraceF> {
+    fn op_type(&self) -> NpoTypeId {
+        NpoTypeId::public_surface()
+    }
+
+    fn rows(&self) -> usize {
+        self.input_wids.len()
+    }
+
+    fn as_any(&self) -> &dyn Any {
+        self
+    }
+
+    fn boxed_clone(&self) -> Box<dyn NonPrimitiveTrace<CF>> {
+        Box::new(self.clone())
+    }
+}
+
+// ============================================================================
+// Trace Generation
+// ============================================================================
+
+/// Generate the public-surface trace from execution state.
+///
+/// Each recorded value is an EF element that MUST be base-valued `(v, 0, …, 0)` for the
+/// bus to balance (the AIR reads it as `[idx, v, 0, …, 0]`); only coefficient 0 is kept.
+pub fn generate_public_surface_trace<BF, EF>(
+    op_states: &crate::ops::OpStateMap,
+) -> Result<Option<Box<dyn NonPrimitiveTrace<EF>>>, CircuitError>
+where
+    BF: PrimeField64,
+    EF: Field + ExtensionField<BF>,
+{
+    let Some(state) = op_states
+        .get(&NpoTypeId::public_surface())
+        .and_then(|s| s.downcast_ref::<PublicSurfaceExecutionState<EF>>())
+    else {
+        return Ok(None);
+    };
+
+    if state.entries.is_empty() {
+        return Ok(None);
+    }
+
+    let mut input_wids = Vec::with_capacity(state.entries.len());
+    let mut values: Vec<BF> = Vec::with_capacity(state.entries.len());
+    for (wid, ef_val) in &state.entries {
+        input_wids.push(*wid);
+        values.push(ef_val.as_basis_coefficients_slice()[0]);
+    }
+
+    Ok(Some(Box::new(PublicSurfaceTrace { input_wids, values })))
+}
