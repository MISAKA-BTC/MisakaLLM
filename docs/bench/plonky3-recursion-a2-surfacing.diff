+//! [`PublicSurfaceAir`] — the AIR for the public-surface NPO table (statement surfacing).
+//!
+//! The table re-exposes already-constrained circuit witnesses as the batch proof's own
+//! per-instance STARK public values, closing the "existential statement" gap of recursive
+//! verification (see `p3_circuit::ops::public_surface`).
+//!
+//! # Layout
+//!
+//! All `N` surfaced values live in ONE logical row (`lanes = N`), so the public-value
+//! binding is expressible as a uniform first-row constraint:
+//!
+//! **Main columns** (1 per lane): `v_0, …, v_{N-1}` — the surfaced base-field values.
+//!
+//! **Preprocessed columns** (2 per lane): `witness_idx`, `mult` (−1 on the active row,
+//! 0 on padding rows).
+//!
+//! # Constraints and CTL lookups (the soundness chain)
+//!
+//! 1. `is_first_row · (v_j − pv_j) = 0` for every lane `j` — the proof's CLAIMED
+//!    `public_values` must equal the COMMITTED trace cells.
+//! 2. **Receive** `[witness_idx_j, v_j, 0, …, 0]` with multiplicity `mult_j` on the
+//!    `WitnessChecks` bus — the committed cells must equal the circuit's witness values
+//!    (and those witnesses must be base-valued: extension coefficients 1..D are matched
+//!    against literal zeros).
+//!
+//! Together: `public_values == the circuit's witness values`, with no prover freedom.
+
+use alloc::vec;
+use alloc::vec::Vec;
+use core::marker::PhantomData;
+
+use p3_air::{Air, AirBuilder, BaseAir, WindowAccess};
+use p3_field::{Field, PrimeCharacteristicRing};
+use p3_lookup::{Count, InteractionBuilder};
+use p3_matrix::dense::RowMajorMatrix;
+use tracing::instrument;
+
+/// AIR for the public-surface (statement re-exposure) table.
+#[derive(Debug, Clone)]
+pub struct PublicSurfaceAir<F, const D: usize> {
+    /// Number of surfaced values; all packed into one logical row.
+    pub(crate) lanes: usize,
+    /// Flattened preprocessed values: `[witness_idx, mult]` per lane (row 0), zeros after.
+    pub(crate) preprocessed: Vec<F>,
+    pub(crate) min_height: usize,
+    _phantom: PhantomData<F>,
+}
+
+impl<F: Field + PrimeCharacteristicRing, const D: usize> PublicSurfaceAir<F, D> {
+    /// Main trace width per lane: 1 column (the surfaced base-field value).
+    pub const fn lane_width() -> usize {
+        1
+    }
+
+    /// Preprocessed width per lane: `[witness_idx, mult]`.
+    pub const fn preprocessed_lane_width() -> usize {
+        2
+    }
+
+    /// Create a new `PublicSurfaceAir`.
+    pub fn new_with_preprocessed(lanes: usize, preprocessed: Vec<F>, min_height: usize) -> Self {
+        Self {
+            lanes: lanes.max(1),
+            preprocessed,
+            min_height,
+            _phantom: PhantomData,
+        }
+    }
+
+    /// Build the main trace matrix: one active row carrying all surfaced values.
+    #[instrument(skip_all, name = "PublicSurfaceAir::build_trace")]
+    pub fn trace_to_matrix(values: &[F]) -> RowMajorMatrix<F> {
+        let mut mat = RowMajorMatrix::new(values.to_vec(), values.len().max(1));
+        mat.pad_to_power_of_two_height(F::ZERO);
+        mat
+    }
+}
+
+impl<F: Field, const D: usize> BaseAir<F> for PublicSurfaceAir<F, D> {
+    fn width(&self) -> usize {
+        self.lanes * Self::lane_width()
+    }
+
+    fn num_public_values(&self) -> usize {
+        self.lanes
+    }
+
+    fn preprocessed_width(&self) -> usize {
+        self.lanes * Self::preprocessed_lane_width()
+    }
+
+    fn preprocessed_trace(&self) -> Option<RowMajorMatrix<F>> {
+        let width = self.lanes * Self::preprocessed_lane_width();
+        let mut mat = RowMajorMatrix::from_flat_padded(self.preprocessed.to_vec(), width, F::ZERO);
+        mat.pad_to_min_power_of_two_height(self.min_height, F::ZERO);
+        Some(mat)
+    }
+
+    fn main_next_row_columns(&self) -> Vec<usize> {
+        vec![]
+    }
+
+    fn preprocessed_next_row_columns(&self) -> Vec<usize> {
+        vec![]
+    }
+}
+
+impl<AB: AirBuilder + InteractionBuilder, const D: usize> Air<AB> for PublicSurfaceAir<AB::F, D>
+where
+    AB::F: Field,
+{
+    fn eval(&self, builder: &mut AB) {
+        let pvs: Vec<AB::Expr> = (0..self.lanes)
+            .map(|j| builder.public_values()[j].into())
+            .collect();
+        let main = builder.main();
+        let main_local = main.current_slice();
+        let prep = builder.preprocessed().clone();
+        let prep_local = prep.current_slice();
+
+        let lane_w = Self::lane_width();
+        let prep_lane_w = Self::preprocessed_lane_width();
+
+        for lane in 0..self.lanes {
+            let main_off = lane * lane_w;
+            let prep_off = lane * prep_lane_w;
+
+            // (1) claimed public value == committed cell, on the (single) active row.
+            let v: AB::Expr = main_local[main_off].into();
+            builder
+                .when_first_row()
+                .assert_eq(v.clone(), pvs[lane].clone());
+
+            // (2) receive [witness_idx, v, 0, …, 0] on the WitnessChecks bus. The literal
+            // zeros force the surfaced witness to be base-valued.
+            let witness_idx: AB::Expr = prep_local[prep_off].into();
+            let mult: AB::Expr = prep_local[prep_off + 1].into();
+            let mut fields: Vec<AB::Expr> = Vec::with_capacity(1 + D);
+            fields.push(witness_idx);
+            fields.push(v);
+            for _ in 1..D {
+                fields.push(AB::Expr::ZERO);
+            }
+            builder.push_interaction("WitnessChecks", fields, Count::bounded(mult, 1));
+        }
+    }
+}
