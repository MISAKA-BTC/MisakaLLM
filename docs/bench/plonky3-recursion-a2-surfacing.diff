 use crate::ops::poseidon_perm::PoseidonPermExec;
 use crate::ops::poseidon1_perm::{Poseidon1CircuitPlugin, Poseidon1PermCallBase};
 use crate::ops::poseidon2_perm::{Poseidon2CircuitPlugin, Poseidon2PermCallBase};
+use crate::ops::public_surface::PublicSurfaceCircuitPlugin;
 use crate::ops::recompose::RecomposeCircuitPlugin;
 use crate::ops::{
     HintExecutor, NpoConfig, NpoRegistry, NpoTypeId, Poseidon1Params, Poseidon1PermCall,
@@ -424,6 +425,37 @@ where
     {
     }
 
+    /// Enables the public-surface NPO table, which re-exposes already-constrained circuit
+    /// witnesses as the batch proof's own per-instance public values (statement surfacing
+    /// for recursive verification; see `crate::ops::public_surface`).
+    pub fn enable_public_surface(&mut self, trace_generator: TraceGeneratorFn<F>) {
+        self.register_npo(PublicSurfaceCircuitPlugin::new(trace_generator));
+    }
+
+    /// Re-exposes `values` (already-constrained witnesses, in order) as this circuit's
+    /// surfaced public values. The paired `PublicSurfaceAir` binds the batch proof's
+    /// `non_primitives[k].public_values` to exactly these witness values (first trace row),
+    /// and the WitnessChecks bus binds the table cells to the circuit's witnesses — so the
+    /// proof carries the surfaced statement non-malleably. Every surfaced value must be a
+    /// BASE-field value (extension coefficients 1..D are forced to zero by the bus read).
+    ///
+    /// Requires `enable_public_surface` to have been called on this builder.
+    pub fn add_public_surface(
+        &mut self,
+        values: &[ExprId],
+    ) -> Result<NonPrimitiveOpId, CircuitBuilderError> {
+        let op_type = NpoTypeId::public_surface();
+        self.ensure_op_enabled(&op_type)?;
