diff --git a/circuit-prover/src/batch_stark_prover/public_surface.rs b/circuit-prover/src/batch_stark_prover/public_surface.rs
new file mode 100644
index 00000000..fa99861
--- /dev/null
+++ b/circuit-prover/src/batch_stark_prover/public_surface.rs
@@ -0,0 +1,322 @@
+//! Public-surface table prover: builds `PublicSurfaceAir` instances for the batch
+//! STARK prover (statement surfacing; see `p3_circuit::ops::public_surface`).
+
+use alloc::boxed::Box;
+use alloc::format;
+use alloc::string::String;
+use alloc::vec::Vec;
+
+use hashbrown::HashMap;
+use p3_baby_bear::BabyBear;
+use p3_batch_stark::{StarkGenericConfig, Val};
+use p3_circuit::ops::{NonPrimitivePreprocessedMap, NpoTypeId, PublicSurfaceTrace};
+use p3_circuit::tables::Traces;
+use p3_circuit::{CircuitError, PreprocessedColumns};
+use p3_field::extension::{BinomialExtensionField, QuinticTrinomialExtensionField};
+use p3_field::{Algebra, ExtensionField, Field, PrimeCharacteristicRing, PrimeField64};
+use p3_goldilocks::Goldilocks;
+use p3_koala_bear::KoalaBear;
+use p3_uni_stark::{SymbolicExpression, SymbolicExpressionExt};
+use p3_util::log2_ceil_usize;
+
+use super::dynamic_air::{
+    BatchAir, BatchTableInstance, DynamicAirEntry, TableProver, transmute_traces,
+};
+use super::{NonPrimitiveTableEntry, TablePacking};
+use crate::air::PublicSurfaceAir;
+use crate::common::{CircuitTableAir, NpoAirBuilder, NpoPreprocessor};
+use crate::config::StarkField;
+use crate::{ConstraintProfile, impl_table_prover_batch_instances_from_base};
+
+impl<SC, const D: usize> BatchAir<SC> for PublicSurfaceAir<Val<SC>, D>
+where
+    SC: StarkGenericConfig + Send + Sync,
+    Val<SC>: StarkField,
+    SymbolicExpressionExt<Val<SC>, SC::Challenge>:
+        Algebra<SymbolicExpression<Val<SC>>> + Algebra<SC::Challenge>,
+{
+}
+
+/// Table prover for the public-surface (statement re-exposure) NPO.
+///
+/// The lane count is always the number of surfaced values (all packed into one active
+/// row so the public-value binding is a uniform first-row constraint); `TablePacking`
+/// lane overrides are deliberately ignored.
+pub struct PublicSurfaceProver<const D: usize>;
+
+impl<const D: usize> PublicSurfaceProver<D> {
+    pub const fn new() -> Self {
+        Self
+    }
+
+    fn batch_instance_base<SC>(
+        &self,
+        _config: &SC,
+        packing: &TablePacking,
+        traces: &Traces<Val<SC>>,
+    ) -> Option<BatchTableInstance<SC>>
+    where
+        SC: StarkGenericConfig + 'static + Send + Sync,
+        Val<SC>: StarkField,
+        SymbolicExpressionExt<Val<SC>, SC::Challenge>:
+            Algebra<SymbolicExpression<Val<SC>>> + Algebra<SC::Challenge>,
+    {
+        let op_type = NpoTypeId::public_surface();
+        let trace = traces.non_primitive_traces.get(&op_type)?;
+        if trace.rows() == 0 {
+            return None;
+        }
+
+        let t = trace.as_any().downcast_ref::<PublicSurfaceTrace<Val<SC>>>()?;
+
+        let num_ops = t.input_wids.len();
+        let lanes = num_ops; // one active row carrying every surfaced value
+        let min_height = packing.min_trace_height();
+
+        let prep_lane_width = PublicSurfaceAir::<Val<SC>, D>::preprocessed_lane_width();
+        let neg_one = Val::<SC>::ZERO - Val::<SC>::ONE;
+        let mut preprocessed = Val::<SC>::zero_vec(num_ops * prep_lane_width);
+        for (i, wid) in t.input_wids.iter().enumerate() {
+            let base = i * prep_lane_width;
+            preprocessed[base] = wid.base_field_index::<Val<SC>, D>();
+            preprocessed[base + 1] = neg_one;
+        }
+
+        let air = PublicSurfaceAir::<Val<SC>, D>::new_with_preprocessed(
+            lanes,
+            preprocessed,
+            min_height,
+        );
+        let matrix = PublicSurfaceAir::<Val<SC>, D>::trace_to_matrix(&t.values);
+
+        Some(BatchTableInstance {
+            op_type,
+            air: DynamicAirEntry::new(Box::new(air)),
+            trace: matrix,
+            // The surfaced statement: bound to the committed trace by the AIR's
+            // first-row constraint, and to the circuit's witnesses by the bus.
+            public_values: t.values.clone(),
+            rows: num_ops,
+            lanes,
+        })
+    }
+}
+
+impl<const D: usize> Default for PublicSurfaceProver<D> {
+    fn default() -> Self {
+        Self::new()
+    }
+}
+
+impl<SC, const D: usize> TableProver<SC> for PublicSurfaceProver<D>
+where
+    SC: StarkGenericConfig + 'static + Send + Sync,
+    Val<SC>: StarkField,
+    SymbolicExpressionExt<Val<SC>, SC::Challenge>:
+        Algebra<SymbolicExpression<Val<SC>>> + Algebra<SC::Challenge>,
+{
+    fn op_type(&self) -> NpoTypeId {
+        NpoTypeId::public_surface()
+    }
+
+    fn lanes(&self) -> usize {
+        1
+    }
+
+    impl_table_prover_batch_instances_from_base!(batch_instance_base);
+
+    fn batch_air_from_table_entry(
+        &self,
+        _config: &SC,
+        _degree: usize,
+        _circuit_extension_degree: u32,
+        table_entry: &NonPrimitiveTableEntry<SC>,
+    ) -> Result<DynamicAirEntry<SC>, String> {
+        // Shape invariants of the surface table: lanes == rows == public_values.len()
+        // (one active row, one public value per lane). Reject malformed metadata before
+        // reconstruction so a forged entry cannot desynchronize the pv-binding layout.
+        if table_entry.lanes != table_entry.public_values.len()
+            || table_entry.rows != table_entry.lanes
+        {
+            return Err(format!(
+                "public_surface entry shape mismatch: rows={}, lanes={}, public_values={}",
+                table_entry.rows,
+                table_entry.lanes,
+                table_entry.public_values.len()
+            ));
+        }
+        let air = PublicSurfaceAir::<Val<SC>, D>::new_with_preprocessed(
+            table_entry.lanes,
+            Vec::new(),
+            1,
+        );
+        Ok(DynamicAirEntry::new(Box::new(air)))
+    }
+
+    fn air_with_committed_preprocessed(
+        &self,
+        committed_prep: Vec<Val<SC>>,
+        min_height: usize,
+        lanes: usize,
+        _circuit_extension_degree: u32,
+    ) -> Option<DynamicAirEntry<SC>> {
+        let air = PublicSurfaceAir::<Val<SC>, D>::new_with_preprocessed(
+            lanes,
+            committed_prep,
+            min_height,
+        );
+        Some(DynamicAirEntry::new(Box::new(air)))
+    }
+}
+
+// ============================================================================
+// Preprocessor
+// ============================================================================
+
+/// NpoPreprocessor for the public-surface table: converts the circuit-registered EF
+/// preprocessed values (`[witness_idx, −1]` per lane) to the base field. Multiplicities
+/// are already final (a pure reader is always −1 per active lane).
+#[derive(Default, Clone)]
+pub struct PublicSurfacePreprocessor;
+
+fn public_surface_preprocess_impl<F, EF, const D: usize>(
+    prep: &PreprocessedColumns<EF, D>,
+) -> Result<NonPrimitivePreprocessedMap<F>, CircuitError>
+where
+    F: StarkField + PrimeField64,
+    EF: Field + ExtensionField<F> + 'static,
+{
+    let op_type = NpoTypeId::public_surface();
+    let ef_data = match prep.non_primitive.get(&op_type) {
+        Some(d) if !d.is_empty() => d,
+        _ => return Ok(HashMap::new()),
+    };
+
+    let prep_base: Vec<F> = ef_data
+        .iter()
+        .map(|v| v.as_base().ok_or(CircuitError::InvalidPreprocessedValues))
+        .collect::<Result<Vec<_>, CircuitError>>()?;
+
+    if !prep_base.len().is_multiple_of(2) {
+        return Err(CircuitError::InvalidPreprocessedValues);
+    }
+
+    let mut result = HashMap::new();
+    result.insert(op_type, prep_base);
+    Ok(result)
+}
+
+impl NpoPreprocessor<BabyBear> for PublicSurfacePreprocessor {
+    fn preprocess(
+        &self,
+        _circuit: &dyn core::any::Any,
+        preprocessed: &mut dyn core::any::Any,
+    ) -> Result<NonPrimitivePreprocessedMap<BabyBear>, CircuitError> {
+        type F = BabyBear;
+        if let Some(prep) =
+            preprocessed.downcast_mut::<PreprocessedColumns<BinomialExtensionField<F, 4>, 4>>()
+        {
+            return public_surface_preprocess_impl::<F, _, 4>(prep);
+        }
+        if let Some(prep) = preprocessed.downcast_mut::<PreprocessedColumns<F, 1>>() {
+            return public_surface_preprocess_impl::<F, _, 1>(prep);
+        }
+        Ok(HashMap::new())
+    }
+}
+
+impl NpoPreprocessor<KoalaBear> for PublicSurfacePreprocessor {
+    fn preprocess(
+        &self,
+        _circuit: &dyn core::any::Any,
+        preprocessed: &mut dyn core::any::Any,
+    ) -> Result<NonPrimitivePreprocessedMap<KoalaBear>, CircuitError> {
+        type F = KoalaBear;
+        if let Some(prep) =
+            preprocessed.downcast_mut::<PreprocessedColumns<BinomialExtensionField<F, 4>, 4>>()
+        {
+            return public_surface_preprocess_impl::<F, _, 4>(prep);
+        }
+        if let Some(prep) =
+            preprocessed.downcast_mut::<PreprocessedColumns<QuinticTrinomialExtensionField<F>, 5>>()
+        {
+            return public_surface_preprocess_impl::<F, _, 5>(prep);
+        }
+        if let Some(prep) = preprocessed.downcast_mut::<PreprocessedColumns<F, 1>>() {
+            return public_surface_preprocess_impl::<F, _, 1>(prep);
+        }
+        Ok(HashMap::new())
+    }
+}
+
+impl NpoPreprocessor<Goldilocks> for PublicSurfacePreprocessor {
+    fn preprocess(
+        &self,
+        _circuit: &dyn core::any::Any,
+        preprocessed: &mut dyn core::any::Any,
+    ) -> Result<NonPrimitivePreprocessedMap<Goldilocks>, CircuitError> {
+        type F = Goldilocks;
+        if let Some(prep) =
+            preprocessed.downcast_mut::<PreprocessedColumns<BinomialExtensionField<F, 2>, 2>>()
+        {
+            return public_surface_preprocess_impl::<F, _, 2>(prep);
+        }
+        if let Some(prep) = preprocessed.downcast_mut::<PreprocessedColumns<F, 1>>() {
+            return public_surface_preprocess_impl::<F, _, 1>(prep);
+        }
+        Ok(HashMap::new())
+    }
+}
+
+// ============================================================================
+// AIR Builder
+// ============================================================================
+
+/// NpoAirBuilder for the public-surface table. Lanes are derived from the preprocessed
+/// data (one lane per surfaced value); `TablePacking` overrides are ignored.
+#[derive(Clone, Default)]
+pub struct PublicSurfaceAirBuilder<const D: usize>;
+
+impl<SC, const D: usize> NpoAirBuilder<SC, D> for PublicSurfaceAirBuilder<D>
+where
+    SC: StarkGenericConfig + 'static + Send + Sync,
+    Val<SC>: StarkField,
+    SymbolicExpressionExt<Val<SC>, SC::Challenge>:
+        Algebra<SymbolicExpression<Val<SC>>> + Algebra<SC::Challenge>,
+{
+    fn lanes(&self) -> usize {
+        1
+    }
+
+    fn try_build(
+        &self,
+        op_type: &NpoTypeId,
+        prep_base: &[Val<SC>],
+        min_height: usize,
+        _lanes: usize,
+        _constraint_profile: ConstraintProfile,
+    ) -> Option<(CircuitTableAir<SC, D>, usize)> {
+        if op_type.as_str() != "public_surface" {
+            return None;
+        }
+
+        let prep_lane_width = PublicSurfaceAir::<Val<SC>, D>::preprocessed_lane_width();
+        let num_ops = prep_base.len() / prep_lane_width;
+        // All values live on one active row.
+        let lanes = num_ops.max(1);
+
+        let air = PublicSurfaceAir::<Val<SC>, D>::new_with_preprocessed(
+            lanes,
+            prep_base.to_vec(),
+            min_height,
+        );
+
+        let padded_rows = 1usize.max(min_height.next_power_of_two());
+        let degree = log2_ceil_usize(padded_rows);
+
+        Some((
+            CircuitTableAir::Dynamic(DynamicAirEntry::new(Box::new(air))),
+            degree,
+        ))
+    }
+}
