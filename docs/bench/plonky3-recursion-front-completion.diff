+                // one-hot placement: Σ sel = place, Σ k·sel = cnt·place  (⇒ slot = cnt exactly)
+                let mut sel_sum = AB::Expr::ZERO;
+                let mut sel_idx = AB::Expr::ZERO;
+                for k in 0..NM {
+                    sel_sum = sel_sum + Into::<AB::Expr>::into(row[CSEL + k]);
+                    sel_idx =
+                        sel_idx + Into::<AB::Expr>::into(row[CSEL + k]) * AB::Expr::from_u64(k as u64);
+                }
+                builder.assert_eq(sel_sum, e(CPLACE));
+                builder.assert_eq(sel_idx, e(CCNT) * e(CPLACE));
+                // gated counter bookkeeping
+                let f_cand: AB::Expr = prep[PF_CAND].into();
+                builder.assert_zero(f_cand * (e(CCNT) + e(CU) - AB::Expr::from_u64(NM as u64)));
+                let f_step: AB::Expr = prep[PF_STEP].into();
+                builder.assert_zero(f_step * (Into::<AB::Expr>::into(nxt[CCNT]) - e(CCNT) - e(CPLACE)));
+                let f_first: AB::Expr = prep[PF_EFIRST].into();
+                builder.assert_zero(f_first * e(CCNT));
+                let f_last: AB::Expr = prep[PF_ELAST].into();
+                builder.assert_zero(f_last * (e(CCNT) - AB::Expr::from_u64(NM as u64)));
+                // stream binding: candidate value (all 24 bits incl. the dropped one) == its public
+                let mut in_val = AB::Expr::ZERO;
+                let mut w4 = AB::Expr::ONE;
+                for j in 0..24 {
+                    in_val = in_val + Into::<AB::Expr>::into(row[CIN + j]) * w4.clone();
+                    w4 = w4.clone() + w4.clone();
+                }
+                for h in 0..SHI_M {
+                    let fh: AB::Expr = prep[PF_SHI + h].into();
+                    for o in 0..SLO_M {
+                        let fo: AB::Expr = prep[PF_SLO + o].into();
+                        builder.assert_zero(
+                            fh.clone() * fo * (in_val.clone() - pis[PI_STREAM_M + h * SLO_M + o].clone()),
+                        );
+                    }
+                }
+
+                // ---- A-bank: write (placement) xor thread (identity), every transition ---------
+                let f_row0: AB::Expr = prep[PF_ROW0].into();
+                let wf: AB::Expr = prep[PF_ENTRY].into();
+                let tf: AB::Expr = prep[PF_THREAD].into();
+                for k in 0..NM {
+                    let a: AB::Expr = row[BANK + k].into();
+                    let an: AB::Expr = nxt[BANK + k].into();
+                    let sel: AB::Expr = row[CSEL + k].into();
+                    // placement transition: next.A = A + sel·(t − A)  (degree 3 with the gate)
+                    builder.assert_zero(wf.clone() * (an.clone() - a.clone() - sel * (e(CT) - a.clone())));
+                    // identity thread
+                    builder.assert_zero(tf.clone() * (an - a.clone()));
+                    // bank starts at 0
+                    builder.assert_zero(f_row0.clone() * a);
+                }
+
+                // ---- mult gadgets (unconditional, valid zero instance elsewhere) --------------
+                // VERBATIM ntt_mul_air.rs base-2^12 limb-carry mod-q multiply, one per gadget:
+                //   g = 0..LDIM_M : az_j = Â[0][k]·ẑ[0][k]   (LDIM_M=1)
+                //   g = LDIM_M    : t1s  = 8192·t̂1[k]        (2^d scale)
+                //   g = LDIM_M+1  : psub = ĉ[k]·t1s          (the ĉ∘t̂1 leg)
+                for g in 0..(LDIM_M + 2) {
+                    let base = CB + g * MG_COLS;
+                    // bind + range-check every primary column via its bits
+                    for c in 0..MG_NP {
+                        let bo = base + mg_bit_off(c);
+                        let mut acc = AB::Expr::ZERO;
+                        let mut wg = AB::Expr::ONE;
+                        for j in 0..MG_WIDTHS[c] {
+                            let bit: AB::Expr = row[bo + j].into();
+                            builder.assert_zero(bit.clone() * (bit.clone() - one.clone()));
+                            acc = acc + bit * wg.clone();
+                            wg = wg.clone() + wg.clone();
+                        }
+                        builder.assert_eq(e(base + c), acc);
+                    }
+                    let q1 = AB::Expr::from_u64(Q1);
+                    // LHS = ζ·b limbified with carries (each partial product < 2^24 < p)
+                    builder.assert_eq(
+                        e(base + MG_Z0) * e(base + MG_B0),
+                        e(base + MG_L0) + beta.clone() * e(base + MG_KL0),
+                    );
+                    builder.assert_eq(
+                        e(base + MG_Z0) * e(base + MG_B1) + e(base + MG_Z1) * e(base + MG_B0) + e(base + MG_KL0),
+                        e(base + MG_L1) + beta.clone() * e(base + MG_KL1),
+                    );
+                    builder.assert_eq(
+                        e(base + MG_Z1) * e(base + MG_B1) + e(base + MG_KL1),
+                        e(base + MG_L2) + beta.clone() * e(base + MG_KL2),
+                    );
+                    // RHS = m·q + t limbified (Q0 = 1, Q1 = 2046)
+                    builder.assert_eq(
+                        e(base + MG_M0) + e(base + MG_T0),
+                        e(base + MG_MM0) + beta.clone() * e(base + MG_KR0),
+                    );
+                    builder.assert_eq(
+                        e(base + MG_M0) * q1.clone() + e(base + MG_M1) + e(base + MG_T1) + e(base + MG_KR0),
+                        e(base + MG_MM1) + beta.clone() * e(base + MG_KR1),
+                    );
+                    builder.assert_eq(
+                        e(base + MG_M1) * q1 + e(base + MG_KR1),
+                        e(base + MG_MM2) + beta.clone() * e(base + MG_KR2),
+                    );
+                    builder.assert_eq(e(base + MG_L0), e(base + MG_MM0));
+                    builder.assert_eq(e(base + MG_L1), e(base + MG_MM1));
+                    builder.assert_eq(e(base + MG_L2), e(base + MG_MM2));
+                    builder.assert_eq(e(base + MG_KL2), e(base + MG_KR2));
+                    // canonical residues: t < q, m < q
+                    builder.assert_eq(
+                        e(base + MG_T0) + beta.clone() * e(base + MG_T1) + e(base + MG_GT0) + beta.clone() * e(base + MG_GT1),
+                        qm1.clone(),
+                    );
+                    builder.assert_eq(
+                        e(base + MG_M0) + beta.clone() * e(base + MG_M1) + e(base + MG_GM0) + beta.clone() * e(base + MG_GM1),
+                        qm1.clone(),
+                    );
+                }
+
+                // ---- stage wiring on coefficient rows -----------------------------------------
+                // accumulate inputs are MATERIALIZED and ==-bound to the mult outputs (the tamper
+                // surface); the psub b-input is ==-bound to the t1s output (the ĉ∘t̂1 wire).
+                for j in 0..LDIM_M {
+                    builder.assert_eq(e(PCOL + j), mgv(MG_AZ0 + j * MG_COLS, MG_T0, MG_T1));
+                }
+                builder.assert_eq(e(PSUBCOL), mgv(MG_PSUB, MG_T0, MG_T1));
+                builder.assert_eq(mgv(MG_PSUB, MG_B0, MG_B1), mgv(MG_T1S, MG_T0, MG_T1));
+                let f_coeff: AB::Expr = prep[PF_COEFF].into();
+                builder.assert_zero(f_coeff * (mgv(MG_T1S, MG_Z0, MG_Z1) - AB::Expr::from_u64(D2)));
+
+                // out block bits
+                let ow = [12usize, 11, 12, 11, 3];
+                let ocols = [O0, O1, GO0, GO1, KKC];
+                let mut off = OBITS;
+                for (ci, &col) in ocols.iter().enumerate() {
+                    let mut acc = AB::Expr::ZERO;
+                    let mut wo = AB::Expr::ONE;
+                    for j in 0..ow[ci] {
+                        let bit: AB::Expr = row[off + j].into();
+                        builder.assert_zero(bit.clone() * (bit.clone() - one.clone()));
+                        acc = acc + bit * wo.clone();
+                        wo = wo.clone() + wo.clone();
+                    }
+                    builder.assert_eq(e(col), acc);
+                    off += ow[ci];
+                }
+                // accumulation-reduction: Σ P − PSUB + q = out + k·q  (in-field: LDIM_M·q < 2^26 < p),
+                // out < q by slack (VERBATIM ntt_accumulate_air.rs).
+                let out_val = e(O0) + beta.clone() * e(O1);
+                builder.assert_eq(out_val.clone() + e(GO0) + beta.clone() * e(GO1), qm1);
+                let mut acc_sum = AB::Expr::ZERO;
+                for j in 0..LDIM_M {
+                    acc_sum = acc_sum + e(PCOL + j);
+                }
+                builder.assert_eq(acc_sum - e(PSUBCOL) + q.clone(), out_val.clone() + e(KKC) * q);
+
+                // ---- diagonal reads (factored one-hot): banks + publics -----------------------
+                // The placed bank feeds the az b-input DIRECTLY (the reference bank→mult wire);
+                // ẑ/t̂1/ĉ are pinned to INPUT publics and ŵ_i = out_val to the OUTPUT public.
+                for a in 0..CHI_M {
+                    let fa: AB::Expr = prep[PF_CHI + a].into();
+                    for b in 0..CLO_M {
+                        let fb: AB::Expr = prep[PF_CLO + b].into();
+                        let g = fa.clone() * fb;
+                        let k = a * CLO_M + b;
+                        for j in 0..LDIM_M {
+                            // mult b-input == the PLACED bank coefficient (the sampling→mult wire)
+                            builder.assert_zero(
+                                g.clone()
+                                    * (mgv(MG_AZ0 + j * MG_COLS, MG_B0, MG_B1)
+                                        - Into::<AB::Expr>::into(row[BANK + j * NM + k])),
+                            );
+                            // mult ζ-input == ẑ[j][k] public
+                            builder.assert_zero(
+                                g.clone() * (mgv(MG_AZ0 + j * MG_COLS, MG_Z0, MG_Z1) - pis[PI_Z_M + j * NM + k].clone()),
+                            );
+                        }
+                        builder.assert_zero(g.clone() * (mgv(MG_T1S, MG_B0, MG_B1) - pis[PI_T1_M + k].clone()));
+                        builder.assert_zero(g.clone() * (mgv(MG_PSUB, MG_Z0, MG_Z1) - pis[PI_C_M + k].clone()));
+                        builder.assert_zero(g * (out_val.clone() - pis[PI_OUT_M + k].clone()));
+                    }
+                }
+            }
+        }
+
+        // ---- trace generation (verbatim structure; reduced counts) ----
+        /// Fill the candidate gadget for a 24-bit value with counter state (verbatim, N=NM).
+        /// Returns place.
+        fn fill_cand<F: PrimeField64>(vals: &mut [F], base: usize, v: u64, cnt: usize) -> bool {
+            assert!(v < TWO24);
+            let t = v & 0x7F_FFFF;
+            let lt = if t < Q { 1u64 } else { 0 };
+            let diff = t + lt * TWO24 - Q;
+            for j in 0..24 {
+                vals[base + CIN + j] = F::from_u64((v >> j) & 1);
+                vals[base + CDIFFB + j] = F::from_u64((diff >> j) & 1);
+            }
+            vals[base + CT] = F::from_u64(t);
+            vals[base + CLT] = F::from_u64(lt);
+            vals[base + CDIFF] = F::from_u64(diff);
+            let u = (NM - cnt) as u64;
+            let act = if u != 0 { 1u64 } else { 0 };
+            let place = lt == 1 && act == 1;
+            vals[base + CCNT] = F::from_u64(cnt as u64);
+            vals[base + CU] = F::from_u64(u);
+            for j in 0..9 {
+                vals[base + CUB + j] = F::from_u64((u >> j) & 1);
+            }
+            vals[base + CINVU] = if u != 0 { F::from_u64(u).inverse() } else { F::ZERO };
+            vals[base + CACT] = F::from_u64(act);
+            vals[base + CPLACE] = F::from_u64(place as u64);
+            if place {
+                vals[base + CSEL + cnt] = F::ONE;
+            }
+            place
+        }
+
+        /// Valid zero fill of the candidate gadget (readout + padding rows): v=0 ⇒ t=0<q ⇒ lt=1,
+        /// diff=2^24−q; cnt=u=act=place=0 (the f_cand/f_step/... gates are off on these rows).
+        fn fill_cand_zero<F: PrimeField64>(vals: &mut [F], base: usize) {
+            let diff = TWO24 - Q;
+            for j in 0..24 {
+                vals[base + CDIFFB + j] = F::from_u64((diff >> j) & 1);
+            }
+            vals[base + CLT] = F::ONE;
+            vals[base + CDIFF] = F::from_u64(diff);
+        }
+
+        fn split(v: u64) -> (u64, u64) {
+            (v % BETA, v / BETA)
+        }
+
+        /// Fill one mod-q mult gadget (VERBATIM arithmetic from ntt_mul_air.rs). Returns t = ζ·b mod q.
+        fn fill_mult<F: PrimeField64>(vals: &mut [F], off: usize, zeta: u64, b: u64) -> u64 {
+            assert!(zeta < (1 << 23) && b < (1 << 23));
+            let (z0, z1) = split(zeta);
+            let (b0, b1) = split(b);
+            let prod = (zeta as u128) * (b as u128);
+            let t = (prod % Q as u128) as u64;
+            let mm = (prod / Q as u128) as u64;
+            let (m0, m1) = split(mm);
+            let (t0, t1) = split(t);
+            let s0 = z0 * b0;
+            let (l0, kl0) = (s0 % BETA, s0 / BETA);
+            let s1 = z0 * b1 + z1 * b0 + kl0;
+            let (l1, kl1) = (s1 % BETA, s1 / BETA);
+            let s2 = z1 * b1 + kl1;
+            let (l2, kl2) = (s2 % BETA, s2 / BETA);
+            let u0 = m0 + t0;
+            let (mm0, kr0) = (u0 % BETA, u0 / BETA);
+            let u1 = m0 * Q1 + m1 + t1 + kr0;
+            let (mm1, kr1) = (u1 % BETA, u1 / BETA);
+            let u2 = m1 * Q1 + kr1;
+            let (mm2, kr2) = (u2 % BETA, u2 / BETA);
+            assert_eq!((l0, l1, l2, kl2), (mm0, mm1, mm2, kr2), "limb mismatch (zeta={zeta}, b={b})");
+            let (gt0, gt1) = split((Q - 1) - t);
+            let (gm0, gm1) = split((Q - 1) - mm);
+            let prim = [
+                (MG_Z0, z0), (MG_Z1, z1), (MG_B0, b0), (MG_B1, b1),
+                (MG_M0, m0), (MG_M1, m1), (MG_T0, t0), (MG_T1, t1),
+                (MG_KL0, kl0), (MG_KL1, kl1), (MG_KL2, kl2),
+                (MG_KR0, kr0), (MG_KR1, kr1), (MG_KR2, kr2),
+                (MG_L0, l0), (MG_L1, l1), (MG_L2, l2),
+                (MG_MM0, mm0), (MG_MM1, mm1), (MG_MM2, mm2),
+                (MG_GT0, gt0), (MG_GT1, gt1), (MG_GM0, gm0), (MG_GM1, gm1),
+            ];
+            for (col, v) in prim {
+                vals[off + col] = F::from_u64(v);
+                let bo = off + mg_bit_off(col);
+                for j in 0..MG_WIDTHS[col] {
+                    vals[bo + j] = F::from_u64((v >> j) & 1);
+                }
+            }
+            t
+        }
+
+        /// Valid zero fill of the out block: Σ0 − 0 + q = 0 + 1·q ⇒ out = 0, kk = 1, slack = q−1.
+        /// (VERBATIM ntt_accumulate_air.rs reduction.) Returns out.
+        fn fill_out<F: PrimeField64>(vals: &mut [F], base: usize, psum: u64, psub: u64) -> u64 {
+            let s = psum + Q - psub;
+            let out = s % Q;
+            let kk = s / Q;
+            assert!(kk < 8);
+            let (o0, o1) = split(out);
+            let (g0, g1) = split(Q - 1 - out);
+            let prim = [(O0, o0), (O1, o1), (GO0, g0), (GO1, g1), (KKC, kk)];
+            let ow = [12usize, 11, 12, 11, 3];
+            let mut off = OBITS;
+            for (ci, &(col, v)) in prim.iter().enumerate() {
+                vals[base + col] = F::from_u64(v);
+                for j in 0..ow[ci] {
+                    vals[base + off + j] = F::from_u64((v >> j) & 1);
+                }
+                off += ow[ci];
+            }
+            out
+        }
+
+        /// Build the full Leg-M trace + pis: placement core + matvec arithmetic tail. `zhat/t1n/chat`
+        /// are the representative canonical NTT-domain statement inputs (< q). Returns
+        /// (trace, placed Â[0..NM], ŵ_i[0..NM], pis).
+        pub fn generate<F: PrimeField64>(
+            stream: &[u8],
+            zhat: &[u64; NM],
+            t1n: &[u64; NM],
+            chat: &[u64; NM],
+        ) -> (RowMajorMatrix<F>, [u64; NM], [u64; NM], Vec<F>) {
+            assert_eq!(stream.len(), CBUDM * 3, "Leg M expects the {}-byte budget stream", CBUDM * 3);
+            let mut vals = F::zero_vec(HEIGHT_M * NUM_COLS_M);
+            let mut bank = [0u64; NM];
+
+            // candidate rows
+            let mut cnt = 0usize;
+            for rr in 0..CBUDM {
+                let base = rr * NUM_COLS_M;
+                // bank state BEFORE this row's candidate
+                for k in 0..NM {
+                    vals[base + BANK + k] = F::from_u64(bank[k]);
+                }
+                let ch = &stream[3 * rr..3 * rr + 3];
+                let v = ch[0] as u64 | (ch[1] as u64) << 8 | (ch[2] as u64) << 16;
+                let place = fill_cand(&mut vals[base..base + NUM_COLS_M], 0, v, cnt);
+                if place {
+                    bank[cnt] = v & 0x7F_FFFF;
+                    cnt += 1;
+                }
+                if rr == CBUDM - 1 {
+                    assert_eq!(cnt, NM, "entry: {NM}th acceptance must precede the last budget row");
+                    assert!(!place);
+                }
+                // valid zero fill of the coefficient block (mult gadgets are unconditional)
+                for g in 0..(LDIM_M + 2) {
+                    fill_mult(&mut vals[base..base + NUM_COLS_M], CB + g * MG_COLS, 0, 0);
+                }
+                fill_out(&mut vals[base..base + NUM_COLS_M], 0, 0, 0);
+            }
+            assert_eq!(cnt, NM);
+            let ahat = bank;
+
+            // coefficient rows: banks thread the final placed poly; compute ŵ_i per coefficient.
+            //   P[0] = Â[0][jj]·ẑ[0][jj] mod q ; t1s = 8192·t̂1[jj] mod q ; psub = ĉ[jj]·t1s mod q ;
+            //   ŵ_i[jj] = (Σ P − psub) mod q  (VERBATIM fill_mult / fill_out arithmetic).
+            let mut what = [0u64; NM];
+            for jj in 0..NM {
+                let base = (COEFF0_M + jj) * NUM_COLS_M;
+                for k in 0..NM {
+                    vals[base + BANK + k] = F::from_u64(bank[k]);
+                }
+                fill_cand_zero(&mut vals[base..base + NUM_COLS_M], 0);
+                let mut psum = 0u64;
+                for j in 0..LDIM_M {
+                    let p = fill_mult(&mut vals[base..base + NUM_COLS_M], MG_AZ0 + j * MG_COLS, zhat[jj], ahat[jj]);
+                    vals[base + PCOL + j] = F::from_u64(p);
+                    psum += p;
+                }
+                let t1sv = fill_mult(&mut vals[base..base + NUM_COLS_M], MG_T1S, D2, t1n[jj]);
+                let psv = fill_mult(&mut vals[base..base + NUM_COLS_M], MG_PSUB, chat[jj], t1sv);
+                vals[base + PSUBCOL] = F::from_u64(psv);
+                what[jj] = fill_out(&mut vals[base..base + NUM_COLS_M], 0, psum, psv);
+            }
+            // padding rows: valid zero fill everywhere, bank 0
+            for r in REAL_ROWS_M..HEIGHT_M {
+                let base = r * NUM_COLS_M;
+                fill_cand_zero(&mut vals[base..base + NUM_COLS_M], 0);
+                for g in 0..(LDIM_M + 2) {
+                    fill_mult(&mut vals[base..base + NUM_COLS_M], CB + g * MG_COLS, 0, 0);
+                }
+                fill_out(&mut vals[base..base + NUM_COLS_M], 0, 0, 0);
+            }
+
+            // publics: [pi_stream (320) ‖ ẑ (64) ‖ t̂1 (64) ‖ ĉ (64) ‖ ŵ_i (64)]
+            let mut pis: Vec<F> = Vec::with_capacity(NUM_PIS_M);
+            for rr in 0..CBUDM {
+                let ch = &stream[3 * rr..3 * rr + 3];
+                let v = ch[0] as u64 | (ch[1] as u64) << 8 | (ch[2] as u64) << 16;
+                pis.push(F::from_u64(v));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(zhat[k]));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(t1n[k]));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(chat[k]));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(what[k]));
+            }
+            assert_eq!(pis.len(), NUM_PIS_M);
+            (RowMajorMatrix::new(vals, NUM_COLS_M), ahat, what, pis)
+        }
+    }
+    fn libcrux_seed5_rho() -> [u8; 32] {
+        let seed: [u8; 32] = core::array::from_fn(|k| (0x1b_u8).wrapping_mul(k as u8 + 1) ^ 5);
+        let mut sh = Shake::v256(); // SHAKE256, DELIM 0x1F
+        sh.update(&seed);
+        sh.update(&[8u8, 7u8]); // [ROWS_IN_A, COLUMNS_IN_A] for ML-DSA-87
+        let mut expanded = [0u8; 128];
+        sh.finalize(&mut expanded);
+        let mut rho = [0u8; 32];
+        rho.copy_from_slice(&expanded[0..32]);
+        rho
+    }
+
+    /// Representative canonical NTT-domain statement inputs `ẑ[0] / t̂1_i / ĉ` (each < q), for the
+    /// matvec tail. The tail's job is the ARITHMETIC, not re-deriving ẑ/ĉ/t̂1 — those come from
+    /// their own stages/publics in the full composition. Deterministic SplitMix64 residues mod q,
+    /// so the run is reproducible and the ŵ_i diff-test is meaningful.
+    fn rep_ntt_inputs() -> ([u64; matvec::NM], [u64; matvec::NM], [u64; matvec::NM]) {
+        let mut s = 0x_C0FF_EE12_3456_789Au64;
+        let mut nextq = || {
+            s = s.wrapping_add(0x9E3779B97F4A7C15);
+            let mut z = s;
+            z = (z ^ (z >> 30)).wrapping_mul(0xBF58476D1CE4E5B9);
+            z = (z ^ (z >> 27)).wrapping_mul(0x94D049BB133111EB);
+            (z ^ (z >> 31)) % Q
+        };
+        let zhat: [u64; matvec::NM] = core::array::from_fn(|_| nextq());
+        let t1n: [u64; matvec::NM] = core::array::from_fn(|_| nextq());
+        let chat: [u64; matvec::NM] = core::array::from_fn(|_| nextq());
+        (zhat, t1n, chat)
+    }
+
+    /// The exact ExpandA byte source, SHAKE128(ρ ‖ s ‖ r), via an INDEPENDENT XOF (`tiny_keccak`).
+    fn shake128_stream(rho: &[u8; 32], s: u8, r: u8, outlen: usize) -> Vec<u8> {
+        let mut sh = Shake::v128();
+        sh.update(rho);
+        sh.update(&[s, r]);
+        let mut out = vec![0u8; outlen];
+        sh.finalize(&mut out);
+        out
+    }
+    // =======================================================================================
+    // Native batch-STARK leg provers (single-instance batch proofs)
+    // =======================================================================================
+    type LegProof = (
+        BatchProof<ConfigWithFriParams>,
+        ProverData<ConfigWithFriParams>,
+        Vec<F>,
+    );
+
+    /// Prove Leg M (ExpandA placement + matvec arithmetic tail); return (proof, placed Â, ŵ_i).
+    fn prove_matvec_leg(
+        config: &ConfigWithFriParams,
+        stream: &[u8],
+        zhat: &[u64; matvec::NM],
+        t1n: &[u64; matvec::NM],
+        chat: &[u64; matvec::NM],
+    ) -> (LegProof, [u64; matvec::NM], [u64; matvec::NM]) {
+        let air = matvec::ExpandaPlaceAir {};
+        let (trace, ahat, what, pis) = matvec::generate::<F>(stream, zhat, t1n, chat);
+        let instances = vec![StarkInstance { air: &air, trace: &trace, public_values: pis.clone() }];
+        let prover_data = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &prover_data);
+        verify_batch(config, core::slice::from_ref(&air), &proof, core::slice::from_ref(&pis), &prover_data.common)
+            .expect("native Leg M batch verify failed");
+        ((proof, prover_data, pis), ahat, what)
+    }
+    /// Prove Leg F (forward NTT front) over the coefficient-domain z; return (proof, ..., publics)
+    /// and the NTT-domain output ẑ.
+    fn prove_ntt_leg(
+        config: &ConfigWithFriParams,
+        air: &ntt::NttAir,
+        z_in: &[u64; NJOIN],
+    ) -> (LegProof, [u64; NJOIN]) {
+        let (trace, zhat_out) = ntt::generate::<F>(z_in, &air.zetas);
+        let pis = ntt::build_pis::<F>(z_in, &zhat_out);
+        let instances = vec![StarkInstance { air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .expect("native Leg F batch verify failed");
+        ((proof, pd, pis), zhat_out)
+    }
+
+    /// Whether Leg F over a trace with a TAMPERED butterfly output is REJECTED by native verify
+    /// (the forward NTT's own cross-layer routing catches it). Perturbs bf8's a-input limb (must
+    /// equal bf4.out0), an internally-consistent-looking change that violates only the routing.
+    fn ntt_tamper_rejects(config: &ConfigWithFriParams, air: &ntt::NttAir, z_in: &[u64; NJOIN]) -> bool {
+        let (mut trace, zhat_out) = ntt::generate::<F>(z_in, &air.zetas);
+        // bf8 base = 8 * 460; A0 = column 24. Flip the low limb of its a-input.
+        let a0 = 8 * 460 + 24;
+        trace.values[a0] += F::ONE;
+        let pis = ntt::build_pis::<F>(z_in, &zhat_out);
+        let instances = vec![StarkInstance { air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .is_err()
+    }
+
+    // =======================================================================================
+    // TWO-stage outer recursion: verify Leg F + Leg M in ONE circuit, bind the ONE cross-stage tie
+    // (F↔M ẑ), produce ONE outer proof = the forward-NTT front stage joined into the matvec's ẑ input.
+    // =======================================================================================
+    #[allow(clippy::too_many_arguments)]
+    #[allow(clippy::too_many_arguments)]
+    fn build_and_prove_outer4(
+        config: &ConfigWithFriParams,
+        fvp: &FriVerifierParams,
+        fri_params: &FriParams,
+        air_f: &ntt::NttAir,
+        leg_z: &LegProof,
+        leg_c: &LegProof,
+        leg_t1: &LegProof,
+        air_m: &matvec::ExpandaPlaceAir,
+        leg_m: &LegProof,
+        do_connect: bool,
+    ) -> Result<(usize, u32), String> {
+        let (proof_z, pd_z, pub_z) = leg_z;
+        let (proof_c, pd_c, pub_c) = leg_c;
+        let (proof_t1, pd_t1, pub_t1) = leg_t1;
+        let (proof_m, pd_m, pub_m) = leg_m;
+        let perm = p3_koala_bear::default_koalabear_poseidon2_16();
+        let mut cb = CircuitBuilder::new();
+        cb.enable_poseidon2_perm::<p3_poseidon2_circuit_air::KoalaBearD4Width16, _>(
+            generate_poseidon2_trace::<Challenge, p3_poseidon2_circuit_air::KoalaBearD4Width16>,
+            perm,
+        );
+        cb.enable_recompose::<F>(generate_recompose_trace::<F, Challenge>);
+        let lookup_gadget = LogUpGadget::new();
+
+        macro_rules! verify_leg {
+            ($proof:expr, $pd:expr, $pub:expr, $air:expr, $what:literal) => {{
+                let vi = BatchStarkVerifierInputsBuilder::<
+                    ConfigWithFriParams,
+                    MerkleCapTargets<F, DIGEST_ELEMS>,
+                    InnerFri,
+                >::allocate(&mut cb, $proof, &$pd.common, &[$pub.len()]);
+                let op_ids = verify_batch_circuit::<_, _, _, _, _, _, _, WIDTH, RATE>(
+                    config,
+                    core::slice::from_ref($air),
+                    &mut cb,
+                    &vi.proof_targets,
+                    &vi.air_public_targets,
+                    fvp,
+                    &vi.common_data,
+                    &lookup_gadget,
+                    Poseidon2Config::KOALA_BEAR_D4_W16,
+                )
+                .map_err(|e| format!("build {} verify circuit: {e:?}", $what))?;
+                (vi, op_ids)
+            }};
+        }
+
+        let (vi_z, op_ids_z) = verify_leg!(proof_z, pd_z, pub_z, air_f, "Leg F_z");
+        let (vi_c, op_ids_c) = verify_leg!(proof_c, pd_c, pub_c, air_f, "Leg F_c");
+        let (vi_t1, op_ids_t1) = verify_leg!(proof_t1, pd_t1, pub_t1, air_f, "Leg F_t1");
+        let (vi_m, op_ids_m) = verify_leg!(proof_m, pd_m, pub_m, air_m, "Leg M");
+
+        // ---- the THREE cross-stage ties (each an ALU sub asserted zero — each public read once).
+        // Tie_z : F_z.ẑ  == M.PI_Z_M ;  Tie_c : F_c.ĉ == M.PI_C_M ;  Tie_t1 : F_t1.t̂1 == M.PI_T1_M.
+        // Each forward-NTT leg surfaces its NTT-domain OUTPUT at ntt::PI_ZHAT (same NttAir layout). ----
+        if do_connect {
+            for (vi_src, dst_off) in
+                [(&vi_z, matvec::PI_Z_M), (&vi_c, matvec::PI_C_M), (&vi_t1, matvec::PI_T1_M)]
+            {
+                for k in 0..NJOIN {
+                    let diff = cb.sub(
+                        vi_src.air_public_targets[0][ntt::PI_ZHAT + k],
+                        vi_m.air_public_targets[0][dst_off + k],
+                    );
+                    cb.assert_zero(diff);
+                }
+            }
+        }
+
+        let vc = cb.build().map_err(|e| format!("outer circuit build: {e:?}"))?;
+        let witness_count = vc.witness_count;
+        println!(
+            "  recursion circuit (4-leg F_z∘F_c∘F_t1∘M): witness_count={witness_count}, connect={do_connect}"
+        );
+
+        // Pack public/private inputs in allocation order (F_z, F_c, F_t1, M).
+        let mut public_inputs: Vec<Challenge> = Vec::new();
+        let mut private_inputs: Vec<Challenge> = Vec::new();
+        for (vi, pubv, proof, pd) in [
+            (&vi_z, pub_z, proof_z, pd_z),
+            (&vi_c, pub_c, proof_c, pd_c),
+            (&vi_t1, pub_t1, proof_t1, pd_t1),
+            (&vi_m, pub_m, proof_m, pd_m),
+        ] {
+            let (pin, prin) = vi.pack_values(core::slice::from_ref(pubv), proof, &pd.common);
+            public_inputs.extend(pin);
+            private_inputs.extend(prin);
+        }
+
+        let mut runner = vc.runner();
+        runner.set_public_inputs(&public_inputs).map_err(|e| format!("set publics: {e:?}"))?;
+        runner.set_private_inputs(&private_inputs).map_err(|e| format!("set privates: {e:?}"))?;
+        for (op_ids, proof) in
+            [(&op_ids_z, proof_z), (&op_ids_c, proof_c), (&op_ids_t1, proof_t1), (&op_ids_m, proof_m)]
+        {
+            set_fri_mmcs_private_data::<F, Challenge, ChallengeMmcs, MyMmcs, MyHash, MyCompress, DIGEST_ELEMS>(
+                &mut runner,
+                op_ids,
+                &proof.opening_proof,
+                Poseidon2Config::KOALA_BEAR_D4_W16,
+            )
+            .map_err(|e| format!("mmcs private data: {e}"))?;
+        }
+
+        // NEGATIVE case fails HERE (aliased cross-stage public with a conflicting value).
+        let traces = runner.run().map_err(|e| format!("recursion circuit run rejected: {e:?}"))?;
+
+        // ---- Prove the outer (aggregated) proof ----
+        let l1_packing = TablePacking::new(1, 2)
+            .with_fri_params(fri_params.log_final_poly_len, fri_params.log_blowup);
+        let npo_prep: Vec<Box<dyn NpoPreprocessor<F>>> =
+            vec![Box::new(Poseidon2Preprocessor), Box::new(RecomposePreprocessor::default())];
+        let mut air_builders = poseidon2_air_builders::<ConfigWithFriParams, D>();
+        air_builders.extend(recompose_air_builders::<ConfigWithFriParams, D>(1, false));
+        let (airs_degrees, prim_cols, non_prim_cols) =
+            get_airs_and_degrees_with_prep::<ConfigWithFriParams, Challenge, D>(
+                &vc,
+                &l1_packing,
+                &npo_prep,
+                &air_builders,
+                ConstraintProfile::Standard,
+            )
+            .map_err(|e| format!("outer airs/degrees: {e:?}"))?;
+        let (airs, degrees): (Vec<_>, Vec<usize>) = airs_degrees.into_iter().unzip();
+        let prover_data = ProverData::from_airs_and_degrees(config, &airs, &degrees);
+        let cpd = CircuitProverData::new(prover_data, prim_cols, non_prim_cols);
+        let mut prover = BatchStarkProver::new(config.clone())
+            .with_table_packing(l1_packing)
+            .with_alu_variant(AirVariant::Baseline);
+        prover.register_poseidon2_table::<D>(Poseidon2Config::KOALA_BEAR_D4_W16);
+        prover.register_recompose_table::<D>(false);
+        let proof = prover.prove_all_tables(&traces, &cpd).map_err(|e| format!("prove outer: {e:?}"))?;
+        prover.verify_all_tables::<Challenge>(&proof).map_err(|e| format!("verify outer: {e:?}"))?;
+        let bytes = postcard::to_allocvec(&proof).map_err(|e| format!("serialize outer: {e:?}"))?.len();
+        Ok((bytes, witness_count))
+    }
+
+    pub fn run() {
+        let fri_params = FriParams {
+            log_blowup: 2,
+            max_log_arity: 2,
+            cap_height: 0,
+            log_final_poly_len: 5,
+            commit_pow_bits: 0,
+            query_pow_bits: 15,
+        };
+        let config = config_with_fri_params(&fri_params, SECURITY, false);
+        let fvp = create_fri_verifier_params(&fri_params, SECURITY);
+
+        let zetas8 = ntt::params();
+        let air_f = ntt::NttAir { zetas: zetas8 };
+        let air_m = matvec::ExpandaPlaceAir {};
+
+        info!(
+            "front-NTT CT JOIN: 3× Leg F (forward NTT n=8 {}×{}, {} pubs each: over z, c, t1), \
+             Leg M (matvec {}×{}, {} pubs); NM={}, NJOIN={NJOIN}, security={SECURITY}",
+            ntt::NUM_COLS, ntt::height(), ntt::num_pis(),
+            matvec::NUM_COLS_M, matvec::HEIGHT_M, matvec::NUM_PIS_M,
+            matvec::NM,
+        );
+
+        // ============ GATE 0: forward-NTT gadget correctness — the ntt_zq oracle at n=8 ============
+        {
+            let mut s = 0x9151_C0DE_2718_2818u64;
+            let mut nextq = || {
+                s = s.wrapping_add(0x9E3779B97F4A7C15);
+                let mut z = s;
+                z = (z ^ (z >> 30)).wrapping_mul(0xBF58476D1CE4E5B9);
+                z = (z ^ (z >> 27)).wrapping_mul(0x94D049BB133111EB);
+                (z ^ (z >> 31)) % Q
+            };
+            for _ in 0..200 {
+                let f: [u64; NJOIN] = std::array::from_fn(|_| nextq());
+                let g: [u64; NJOIN] = std::array::from_fn(|_| nextq());
+                // (a) convolution theorem: NTT(f)∘NTT(g) == NTT(f·g mod x^8+1), coefficient-exact.
+                let nf = ntt::ntt8(&f, &zetas8);
+                let ng = ntt::ntt8(&g, &zetas8);
+                let nc = ntt::ntt8(&ntt::schoolbook8(&f, &g), &zetas8);
+                for i in 0..NJOIN {
+                    let prod = ((nf[i] as u128 * ng[i] as u128) % Q as u128) as u64;
+                    assert_eq!(prod, nc[i], "convolution theorem failed at {i} (n=8 zetas/schedule)");
+                }
+                // (b) forward/inverse round-trip vs the ntt_zq reference: invNTT(NTT(x)) == x.
+                assert_eq!(ntt::invntt8_scaled(&nf, &zetas8), f, "invNTT(NTT(x)) must recover x (n=8)");
+            }
+        }
+        println!(
+            "GATE 0 ok — forward NTT gadget: convolution theorem NTT(f)∘NTT(g)==NTT(f·g mod x^8+1) AND \
+             round-trip invNTT(NTT(x))==x, coefficient-exact over 200 random (f,g) — the ntt_zq oracle at n=8."
+        );
+
+        // ============ pick coefficient-domain z (residues), c (τ-sparse ternary), t1 ([0,2^10)) ====
+        // z: random residues < q (a signature z slice). c: a ternary challenge slice — a few ±1
+        // (−1 ≡ q−1) among zeros (the SampleInBall output shape). t1: raw pkDecode values in [0,2^10).
+        let z8: [u64; NJOIN] = {
+            let mut s = 0x2718_2818_2845_9045u64;
+            let mut nextq = || {
+                s = s.wrapping_add(0x9E3779B97F4A7C15);
+                let mut z = s;
+                z = (z ^ (z >> 30)).wrapping_mul(0xBF58476D1CE4E5B9);
+                z = (z ^ (z >> 27)).wrapping_mul(0x94D049BB133111EB);
+                (z ^ (z >> 31)) % Q
+            };
+            std::array::from_fn(|_| nextq())
+        };
+        // c: ternary challenge slice {+1, 0, −1, 0, 0, +1, −1, 0} → residues (−1 ≡ q−1).
+        let c8: [u64; NJOIN] = {
+            let tern: [i64; NJOIN] = [1, 0, -1, 0, 0, 1, -1, 0];
+            std::array::from_fn(|k| tern[k].rem_euclid(Q as i64) as u64)
+        };
+        // t1: raw 10-bit pkDecode values in [0, 2^10).
+        let t1_8: [u64; NJOIN] = {
+            let mut s = 0x0A17_11CE_D06E_5EEDu64;
+            std::array::from_fn(|_| {
+                s = s.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);
+                (s >> 40) & 0x3FF
+            })
+        };
+        let zhat_ref = ntt::ntt8(&z8, &zetas8);
+        let chat_ref = ntt::ntt8(&c8, &zetas8);
+        let t1hat_ref = ntt::ntt8(&t1_8, &zetas8);
+
+        // ============ three forward-NTT legs: F_z (ẑ=NTT(z)), F_c (ĉ=NTT(c)), F_t1 (t̂1=NTT(t1)) ===
+        let t = Instant::now();
+        let (leg_z, zhat8) = prove_ntt_leg(&config, &air_f, &z8);
+        let (leg_c, chat8) = prove_ntt_leg(&config, &air_f, &c8);
+        let (leg_t1, t1hat8) = prove_ntt_leg(&config, &air_f, &t1_8);
+        // GATE 1: each leg's NTT-domain output == the ntt_zq reference, coefficient-exact.
+        assert_eq!(zhat8, zhat_ref, "Leg F_z ẑ != reference NTT(z)");
+        assert_eq!(chat8, chat_ref, "Leg F_c ĉ != reference NTT(c)");
+        assert_eq!(t1hat8, t1hat_ref, "Leg F_t1 t̂1 != reference NTT(t1)");
+        for (leg, inp, out, nm) in [
+            (&leg_z, &z8, &zhat8, "z"),
+            (&leg_c, &c8, &chat8, "c"),
+            (&leg_t1, &t1_8, &t1hat8, "t1"),
+        ] {
+            for k in 0..NJOIN {
+                assert_eq!(leg.2[ntt::PI_Z + k], F::from_u64(inp[k]), "Leg F_{nm} input[{k}]");
+                assert_eq!(leg.2[ntt::PI_ZHAT + k], F::from_u64(out[k]), "Leg F_{nm} output[{k}]");
+            }
+        }
+        println!(
+            "GATE 1 ok — three forward-NTT legs proven (each {} cols × {} rows, {} pubs): ẑ==NTT(z), \
+             ĉ==NTT(c), t̂1==NTT(t1) all coefficient-exact vs ntt_zq, {:.1?}",
+            ntt::NUM_COLS, ntt::height(), ntt::num_pis(), t.elapsed()
+        );
+
+        // ============ Leg M: matvec consuming ẑ/ĉ/t̂1 as INPUT (first n=8 slice = REAL NTTs) ========
+        let rho = libcrux_seed5_rho();
+        let stream0 = shake128_stream(&rho, 0, I_ROW as u8, STREAM_BYTES);
+        let (mut zhat_m, mut t1n_m, mut chat_m) = rep_ntt_inputs();
+        // Overwrite the first NJOIN of each NTT-domain input with the REAL forward NTTs (ties bind these).
+        for k in 0..NJOIN {
+            zhat_m[k] = zhat8[k];
+            chat_m[k] = chat8[k];
+            t1n_m[k] = t1hat8[k];
+        }
+        let t = Instant::now();
+        let (leg_m, _ahat_m, _what_m) = prove_matvec_leg(&config, &stream0, &zhat_m, &t1n_m, &chat_m);
+        for k in 0..NJOIN {
+            assert_eq!(leg_m.2[matvec::PI_Z_M + k], F::from_u64(zhat8[k]), "Leg M ẑ_in[{k}]");
+            assert_eq!(leg_m.2[matvec::PI_C_M + k], F::from_u64(chat8[k]), "Leg M ĉ_in[{k}]");
+            assert_eq!(leg_m.2[matvec::PI_T1_M + k], F::from_u64(t1hat8[k]), "Leg M t̂1_in[{k}]");
+        }
+        println!(
+            "Leg M (matvec front) batch proof: {} bytes, {} pubs, real seed-5 ρ, \
+             ẑ/ĉ/t̂1[0..{NJOIN}] := REAL forward NTTs, {:.1?}",
+            postcard::to_allocvec(&leg_m.0).unwrap().len(), leg_m.2.len(), t.elapsed()
+        );
+
+        // ============ [1] HONEST: F_z∘F_c∘F_t1∘M — all three ties → all three NTT inputs REAL ======
+        let t = Instant::now();
+        let (bytes, wc) = build_and_prove_outer4(
+            &config, &fvp, &fri_params, &air_f, &leg_z, &leg_c, &leg_t1, &air_m, &leg_m, true,
+        )
+        .expect("HONEST 3-NTT front join must succeed");
+        println!(
+            "[1] HONEST  (z/c/t1 →forwardNTT→ ẑ/ĉ/t̂1 →matvec inputs, Ties z+c+t1): outer proof OK = \
+             all THREE forward-NTT front legs recursion-composed and BOUND into the matvec's \
+             ẑ/ĉ/t̂1 inputs (all REAL forward NTTs), {bytes} bytes, witness_count={wc}, {:.1?}",
+            t.elapsed()
+        );
+
+        // ============ [2] NEG-CH (ĉ fed to matvec != NTT(c)) → Tie_c fails → REJECT ================
+        let mut chat_m_bad = chat_m;
+        chat_m_bad[0] = (chat8[0] + 1) % Q;
+        assert_ne!(chat_m_bad[0], chat8[0]);
+        let (leg_m_bad_c, _a, _w) = prove_matvec_leg(&config, &stream0, &zhat_m, &t1n_m, &chat_m_bad);
+        let t = Instant::now();
+        match build_and_prove_outer4(
+            &config, &fvp, &fri_params, &air_f, &leg_z, &leg_c, &leg_t1, &air_m, &leg_m_bad_c, true,
+        ) {
+            Err(e) => println!(
+                "[2] NEG-CH (matvec ĉ[0] != NTT(c)[0]; Tie_c): REJECTED at prove, {:.1?} -- {e}",
+                t.elapsed()
+            ),
+            Ok(_) => panic!("NEG-CH must NOT produce an outer proof"),
+        }
+
+        // ============ [3] NEG-T1 (t̂1 fed to matvec != NTT(t1)) → Tie_t1 fails → REJECT ============
+        let mut t1n_m_bad = t1n_m;
+        t1n_m_bad[0] = (t1hat8[0] + 1) % Q;
+        assert_ne!(t1n_m_bad[0], t1hat8[0]);
+        let (leg_m_bad_t1, _a, _w) = prove_matvec_leg(&config, &stream0, &zhat_m, &t1n_m_bad, &chat_m);
+        let t = Instant::now();
+        match build_and_prove_outer4(
+            &config, &fvp, &fri_params, &air_f, &leg_z, &leg_c, &leg_t1, &air_m, &leg_m_bad_t1, true,
+        ) {
+            Err(e) => println!(
+                "[3] NEG-T1 (matvec t̂1[0] != NTT(t1)[0]; Tie_t1): REJECTED at prove, {:.1?} -- {e}",
+                t.elapsed()
+            ),
+            Ok(_) => panic!("NEG-T1 must NOT produce an outer proof"),
+        }
+
+        // ============ [4] NEG-BF (tamper one F_c butterfly output) → native leg verify REJECTS =====
+        let neg_bf = ntt_tamper_rejects(&config, &air_f, &c8);
+        assert!(neg_bf, "NEG-BF: a tampered forward-NTT butterfly (F_c) must be REJECTED natively");
+        println!(
+            "[4] NEG-BF (F_c bf8 a-input tampered, breaks layer2→layer3 routing): batch proof \
+             REJECTED at native verify = the forward NTT's in-AIR cross-layer routing genuinely gates."
+        );
+
+        println!(
+            "FRONT-NTT CT JOIN demonstrated: z/c/t1 →forward NTT→ ẑ/ĉ/t̂1 →matvec composed as ONE \
+             recursion tree over FOUR HETEROGENEOUS legs (3× NttAir ∘ ExpandaPlaceAir), all three \
+             forward-NTT front legs landed as real batch-STARK legs (complete CT n=8, exact vs \
+             ntt_zq), and all three cross-stage ties (ẑ, ĉ, t̂1) PROVEN in-circuit — the matvec's \
+             ẑ AND ĉ AND t̂1 are now REAL forward NTTs, none representative. This completes the \
+             forward-NTT front for the reduced n=8 scope; the 256-pt scale-up is the same wiring \
+             generalized by the multi-row lookup."
+        );
+    }
+}
