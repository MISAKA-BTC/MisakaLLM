+            t.elapsed()
+        );
+
+        // ============ [2] NEG-STEP (tamper one placement step output → wrong c) → native REJECT ======
+        let neg_step = sib_tamper_step_rejects(&config, &steps);
+        assert!(neg_step, "NEG-STEP: a tampered placement step must be REJECTED by native Leg S verify");
+        println!(
