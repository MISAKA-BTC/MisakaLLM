+//! **ML-DSA-87 verify FRONT sub-chain: c = SampleInBall(c̃) → ĉ = NTT(c), composed into recursion.**
+//! This lands the CONCEPTUALLY-NEW front stage — the challenge-polynomial construction — and BINDS it
+//! to the forward-NTT leg that consumes it, so `c = SampleInBall(c̃)` then `ĉ = NTT(c)` is proven as
+//! ONE 2-stage recursion sub-chain over two heterogeneous gadgets:
+//!
+//! ```text
+//!   c̃ ──SampleInBall──▶ c  ──Tie──▶  c ──forwardNTT──▶ ĉ
+//!   (Leg S: FIPS-204 Alg.29        (Leg F: NttAir, ntt_wired8_air.rs
+//!    Fisher-Yates placement)        forward CT n=8 — same as front_ntt_join)
+//! ```
+//!
+//!   - **Leg S — SampleInBall** (NEW; the FIPS-204 Algorithm 29 Fisher-Yates placement, ported
+//!     VERBATIM in structure from `docs/bench/plonky3-shield-air/sample_in_ball_air.rs` — witnessed
+//!     one-hot index selectors `sel=[k==j]`/`indi=[k==i]` (boolean, one-hot, index-bound), the read
+//!     `a_j = Σ sel·a`, `j ≤ i` by slack bits, and the exact swap `c[i]←c[j]; c[j]←±1`) PLUS the
+//!     `sampleinball_air.rs` **ball-membership** check on the output c (`cₖ = posₖ − negₖ`,
+//!     `posₖ·negₖ=0`, `Σ(posₖ+negₖ)=τ`). The whole τ-step Fisher-Yates run is unrolled in ONE row
+//!     (steps threaded `next_s == a_{s+1}`, `a_0 = 0`), exactly as the NttAir carries a whole
+//!     transform per row. Exposes the challenge polynomial **c OUTPUT** publics [0..8].
+//!   - **Leg F — forward NTT** (`NttAir`, VERBATIM from `ntt_wired8_air.rs` / `front_ntt_join.rs`):
+//!     the complete CT n=8 forward NTT, `ĉ = NTT(c)`, exposing coefficient-domain **c INPUT** [0..8]
+//!     and NTT-domain **ĉ OUTPUT** [8..16].
+//!   - **Tie (S↔F)**: `Leg-S c[k] (OUTPUT) == Leg-F c_in[k] (INPUT, PI_Z)` for k in 0..8 — an ALU
+//!     `sub` asserted zero (each surfaced public read once, as the sibling chains).
+//!
+//! ## Representation (why residues, not signed −1)
+//! The downstream NTT is mod-q and needs canonical residues < q; a coefficient `−1` is `q−1`. So the
+//! SampleInBall leg carries the challenge in the **mod-q residue alphabet {0, 1, q−1}** rather than
+//! the signed {−1,0,1}: the ternary check is `a·(a−1)·(a−(q−1))=0` (the SAME polynomial identity
+//! `a∈{0,1,−1}` in the residue system) and the placed sign is `1 + sgn·(q−2) ∈ {1, q−1}`. This is a
+//! representation choice, not a structural change — it is exactly what the forward NTT consumes, so
+//! the two stages compose by a direct field-equality tie.
+//!
+//! ## Scope (REDUCED-BUT-REAL)
+//!   - Reduced to **n=8, τ=4** (the array/weight the n=8 NTT leg blessed); the real ML-DSA-87 is
+//!     n=256, τ=60. The Fisher-Yates STRUCTURE is complete (one-hot indexed swap, j≤i slack, a_j
+//!     read, threading, ball-membership) — a genuine reduced instance, not a proxy.
+//!   - The (i,j,sign) placement sequence is derived from the REAL `SHAKE256(c̃)` stream (tiny-keccak)
+//!     of a representative 64-byte c̃, exactly as `mldsa_verify_ref::sample_in_ball` — the placement
+//!     AIR proves the swap structure; the stream source is the separately-proven SHAKE AIR.
+//!   - Leg S's output c is diff-tested coefficient-exact vs a reduced (n=8,τ=4) reference
+//!     `sample_in_ball` (VERBATIM from `mldsa_verify_ref.rs`).
+//!
+//! ## Cases (all in one run)
+//!   1. HONEST (c = SampleInBall(c̃), ĉ = NTT(c), Tie S↔F): outer prove+verify SUCCEEDS.
+//!   2. NEG-STEP (tamper one placement step's output → wrong c): Leg S native verify REJECTS.
+//!   3. NEG-WEIGHT (force a τ+1 non-ball challenge): Leg S ball-membership REJECTS.
+//!   4. NEG-TIE (feed the NTT leg a c ≠ SampleInBall's c): the Tie S↔F mismatch → REJECTS at prove.
+//!
+//! ```bash
+//! cargo run --release --example sampleinball_join
+//! ```
+
+#[macro_use]
+mod common;
+use common::*;
+
+use p3_air::{Air, AirBuilder, BaseAir, WindowAccess};
+use p3_batch_stark::{BatchProof, ProverData, StarkInstance, prove_batch, verify_batch};
+use p3_circuit_prover::{AirVariant, RecomposePreprocessor, recompose_air_builders};
+use p3_field::PrimeField64;
+use std::time::Instant;
+use tiny_keccak::{Hasher, Shake};
+
+fn main() {
+    init_logger();
+    kb::run();
+}
+
+mod kb {
+    // The matvec / usehint modules are copied VERBATIM from the sibling examples; a few of their
+    // host reference helpers (matvec_ref / m / mulq / ahat_read_cell / psum_cell / QI_M) are the
+    // diff-test oracles those files use but this join does not — kept for byte-fidelity.
+    #![allow(dead_code)]
+    use super::*;
+
+    // KoalaBear, D=4, W=16 Poseidon2 — same field/hash plumbing as `expanda_chain_matvec` /
+    // `accept_tail` (the GS invNTT gadget is generic over PrimeField64; q < 2^23 ≪ KoalaBear p,
+    // so every limb/product value stores exactly and the BabyBear-authored gadget is byte-for-byte
+    // the same constraint system over KoalaBear).
+    define_field_module_types!(
+        p3_koala_bear::KoalaBear,
+        p3_koala_bear::Poseidon2KoalaBear<16>,
+        p3_koala_bear::default_koalabear_poseidon2_16,
+        Poseidon2Config::KOALA_BEAR_D4_W16,
+        p3_poseidon2_circuit_air::KoalaBearD4Width16,
+        4,
+        16,
+        8,
+        8,
+        enable_poseidon2_perm,
+        p3_koala_bear::default_koalabear_poseidon2_16,
+        16,
+        8,
+        enable_recompose,
+        generate_poseidon2_trace,
+        p3_circuit::ops::Poseidon2Params
+    );
+
+    // ---- shared constants ----
+    const Q: u64 = 8380417; // ML-DSA / Dilithium modulus (matvec uses u64 form)
+    const QI: i64 = Q as i64; // i64 form (UseHint / invNTT reference arithmetic)
+    const N: usize = 256; // coefficients per poly (matvec candidate placement)
+    const CBUD: usize = 320; // per-entry candidate budget (matvec Leg-B pack tie)
+    const STREAM_BYTES: usize = 3 * CBUD; // 960 candidate bytes per ExpandA entry
+    const I_ROW: usize = 0; // shipped ExpandA output row index i
+
+    // UseHint / Decompose constants (FIPS-204 ML-DSA-87)
+    const GAMMA2: i64 = (QI - 1) / 32; // 261888
+    const G2: i64 = 2 * GAMMA2; // 523776
+    const MM: i64 = 16; // (q-1)/(2γ2)
+    const KB_P: i64 = 2130706433; // KoalaBear prime (is-zero-witness modulus for Leg U)
+    const NW1: usize = 256; // one poly's worth of w / w1 (reduced-but-real)
+
+    const NJOIN: usize = 8; // coefficients carried matvec→invNTT→UseHint (= the n=8 invNTT width)
+    const SECURITY: usize = 100;
+    // =======================================================================================
+    // LEG F — forward NTT (the FRONT stage). COMPLETE Cooley-Tukey n=8 forward NTT over Z_q with
+    // FULL in-AIR cross-layer routing (CT constraints VERBATIM from ntt_wired8_air.rs, the reduced
+    // partner of the proven 256-pt ntt_wired256_air.rs). Exposes z INPUT publics [0..8] and the
+    // ẑ = NTT(z) OUTPUT publics [8..16]. No n⁻¹ scaling (that belongs to the inverse transform).
+    // =======================================================================================
+    pub mod ntt {
+        use super::*;
+
+        const BETA: u64 = 4096;
+        const Q1: u64 = 2046;
+
+        // one CT butterfly's 38 primary columns (VERBATIM layout from ntt_wired8_air.rs) then bits.
+        const Z0: usize = 0;
+        const Z1: usize = 1;
+        const B0: usize = 2;
+        const B1: usize = 3;
+        const MC0: usize = 4;
+        const MC1: usize = 5;
+        const T0: usize = 6;
+        const T1: usize = 7;
+        const KL0: usize = 8;
+        const KL1: usize = 9;
+        const KL2: usize = 10;
+        const KR0: usize = 11;
+        const KR1: usize = 12;
+        const KR2: usize = 13;
+        const L0: usize = 14;
+        const L1: usize = 15;
+        const L2: usize = 16;
+        const M0: usize = 17;
+        const M1: usize = 18;
+        const M2: usize = 19;
+        const GT0: usize = 20;
+        const GT1: usize = 21;
+        const GM0: usize = 22;
+        const GM1: usize = 23;
+        const A0: usize = 24;
+        const A1: usize = 25;
+        const O00: usize = 26;
+        const O01: usize = 27;
+        const O10: usize = 28;
+        const O11: usize = 29;
+        const KO0: usize = 30;
+        const KO1: usize = 31;
+        const GA0: usize = 32;
+        const GA1: usize = 33;
+        const GO00: usize = 34;
+        const GO01: usize = 35;
+        const GO10: usize = 36;
+        const GO11: usize = 37;
+        const NP: usize = 38;
+        const WIDTHS: [usize; NP] = [
+            12, 11, 12, 11, 12, 11, 12, 11, 12, 13, 11, 2, 13, 11, 12, 12, 12, 12, 12, 12, 12, 11, 12, 11, 12, 11, 12, 11,
+            12, 11, 1, 1, 12, 11, 12, 11, 12, 11,
+        ];
+        const BF_COLS: usize = 460; // 38 primary + 422 bits
+        // 12 CT butterflies of the n=8 forward (3 layers × 4). No scaling stage (forward has no n⁻¹).
+        const NBF: usize = 12;
+        pub const NUM_COLS: usize = NBF * BF_COLS; // 5520
+        // butterfly bases in schedule order:
+        //   layer1 (len=4): bf0=(0,4) bf1=(1,5) bf2=(2,6) bf3=(3,7)
+        //   layer2 (len=2): bf4=(0,2) bf5=(1,3) bf6=(4,6) bf7=(5,7)
+        //   layer3 (len=1): bf8=(0,1) bf9=(2,3) bf10=(4,5) bf11=(6,7)
+        const BASE: [usize; NBF] = {
+            let mut b = [0usize; NBF];
+            let mut i = 0;
+            while i < NBF {
+                b[i] = i * BF_COLS;
+                i += 1;
+            }
+            b
+        };
+
+        fn bit_off(col: usize) -> usize {
+            NP + WIDTHS[..col].iter().sum::<usize>()
+        }
+
+        // ---- public values: z INPUT [0..8] then ẑ OUTPUT [8..16] ----
+        pub const PI_Z: usize = 0;
+        pub const PI_ZHAT: usize = NJOIN;
+        pub const NUM_PIS: usize = 2 * NJOIN;
+
+        pub fn height() -> usize {
+            64 // ≥ 2^6 FRI foldability floor; every row carries the same full transform
+        }
+        pub fn num_pis() -> usize {
+            NUM_PIS
+        }
+
+        /// The 8 layer-1 INPUT ports (z position p) as (butterfly, is_b):
+        /// bf0=(pos0,pos4) bf1=(pos1,pos5) bf2=(pos2,pos6) bf3=(pos3,pos7) — so p<4 is bf_p.a,
+        /// p≥4 is bf_{p-4}.b.
+        fn in_port(p: usize) -> (usize, bool) {
+            if p < 4 { (p, false) } else { (p - 4, true) }
+        }
+        /// The layer-3 OUTPUT at natural position p as (butterfly, is_out1):
+        /// pos0=bf8.out0,pos1=bf8.out1,…,pos6=bf11.out0,pos7=bf11.out1.
+        fn out_port(p: usize) -> (usize, bool) {
+            (8 + p / 2, p % 2 == 1)
+        }
+
+        /// The AIR carries the seven canonical n=8 twiddles ζ[k]=ψ^brv3(k), ψ=1753^32.
+        #[derive(Clone)]
+        pub struct NttAir {
+            pub zetas: [u64; 7],
+        }
+
+        impl<F: PrimeField64> BaseAir<F> for NttAir {
+            fn width(&self) -> usize {
+                NUM_COLS
+            }
+            fn num_public_values(&self) -> usize {
+                num_pis()
+            }
+            fn max_constraint_degree(&self) -> Option<usize> {
+                Some(2)
+            }
+        }
+
+        impl<AB: AirBuilder> Air<AB> for NttAir
+        where
+            AB::F: PrimeField64,
+        {
+            fn eval(&self, builder: &mut AB) {
+                let one = AB::Expr::ONE;
+                let beta = AB::Expr::from_u64(BETA);
+                let q1 = AB::Expr::from_u64(Q1);
+                let q = AB::Expr::from_u64(Q);
+                let qm1 = AB::Expr::from_u64(Q - 1);
+                let pis: Vec<AB::Expr> =
+                    (0..num_pis()).map(|k| builder.public_values()[k].into()).collect();
+                let main = builder.main();
+                let row = main.current_slice();
+                let e = |i: usize| -> AB::Expr { row[i].into() };
+
+                // ---- each CT butterfly (all 12): the proven gadget, VERBATIM from ntt_wired8_air.rs ----
+                for &b in BASE.iter() {
+                    for c in 0..NP {
+                        let bo = b + bit_off(c);
+                        let mut acc = AB::Expr::ZERO;
+                        let mut w = AB::Expr::ONE;
+                        for j in 0..WIDTHS[c] {
+                            let bit: AB::Expr = row[bo + j].into();
+                            builder.assert_zero(bit.clone() * (bit.clone() - one.clone()));
+                            acc = acc + bit * w.clone();
+                            w = w.clone() + w.clone();
+                        }
+                        builder.assert_eq(e(b + c), acc);
+                    }
+                    // mod-q multiply t = ζ·b (limb carry chain)
+                    builder.assert_eq(e(b + Z0) * e(b + B0), e(b + L0) + beta.clone() * e(b + KL0));
+                    builder.assert_eq(
+                        e(b + Z0) * e(b + B1) + e(b + Z1) * e(b + B0) + e(b + KL0),
+                        e(b + L1) + beta.clone() * e(b + KL1),
+                    );
+                    builder.assert_eq(e(b + Z1) * e(b + B1) + e(b + KL1), e(b + L2) + beta.clone() * e(b + KL2));
+                    builder.assert_eq(e(b + MC0) + e(b + T0), e(b + M0) + beta.clone() * e(b + KR0));
+                    builder.assert_eq(
+                        e(b + MC0) * q1.clone() + e(b + MC1) + e(b + T1) + e(b + KR0),
+                        e(b + M1) + beta.clone() * e(b + KR1),
+                    );
+                    builder.assert_eq(e(b + MC1) * q1.clone() + e(b + KR1), e(b + M2) + beta.clone() * e(b + KR2));
+                    builder.assert_eq(e(b + L0), e(b + M0));
+                    builder.assert_eq(e(b + L1), e(b + M1));
+                    builder.assert_eq(e(b + L2), e(b + M2));
+                    builder.assert_eq(e(b + KL2), e(b + KR2));
+
+                    let t_val = e(b + T0) + beta.clone() * e(b + T1);
+                    let a_val = e(b + A0) + beta.clone() * e(b + A1);
+                    let out0 = e(b + O00) + beta.clone() * e(b + O01);
+                    let out1 = e(b + O10) + beta.clone() * e(b + O11);
+                    let m_val = e(b + MC0) + beta.clone() * e(b + MC1);
+                    // add/sub: out0 = a + t, out1 = a − t  (t = ζ·b)
+                    builder.assert_eq(a_val.clone() + t_val.clone(), out0.clone() + e(b + KO0) * q.clone());
+                    builder.assert_eq(a_val.clone() + e(b + KO1) * q.clone(), t_val.clone() + out1.clone());
+                    // ranges
+                    let slack = |lo: usize, hi: usize| -> AB::Expr { e(b + lo) + beta.clone() * e(b + hi) };
+                    builder.assert_eq(t_val + slack(GT0, GT1), qm1.clone());
+                    builder.assert_eq(m_val + slack(GM0, GM1), qm1.clone());
+                    builder.assert_eq(a_val + slack(GA0, GA1), qm1.clone());
+                    builder.assert_eq(out0 + slack(GO00, GO01), qm1.clone());
+                    builder.assert_eq(out1 + slack(GO10, GO11), qm1.clone());
+                }
+
+                // ---- pin each butterfly's twiddle to the canonical ζ (VERBATIM forward schedule) ----
+                // layer1 (k=1): ζ[0]; layer2 (k=2,3): ζ[1],ζ[2]; layer3 (k=4..7): ζ[3..7].
+                let pin = |builder: &mut AB, b: usize, zeta: u64| {
+                    builder.assert_eq(e(b + Z0) + beta.clone() * e(b + Z1), AB::Expr::from_u64(zeta));
+                };
+                pin(builder, BASE[0], self.zetas[0]);
+                pin(builder, BASE[1], self.zetas[0]);
+                pin(builder, BASE[2], self.zetas[0]);
+                pin(builder, BASE[3], self.zetas[0]);
+                pin(builder, BASE[4], self.zetas[1]);
+                pin(builder, BASE[5], self.zetas[1]);
+                pin(builder, BASE[6], self.zetas[2]);
+                pin(builder, BASE[7], self.zetas[2]);
+                pin(builder, BASE[8], self.zetas[3]);
+                pin(builder, BASE[9], self.zetas[4]);
+                pin(builder, BASE[10], self.zetas[5]);
+                pin(builder, BASE[11], self.zetas[6]);
+
+                // ---- CROSS-LAYER WIRING (VERBATIM ntt_wired8): each layer's inputs == prev layer's
+                // outputs. out0=(O00,O01), out1=(O10,O11); inputs a=(A0,A1), b=(B0,B1). ----
+                let wire = |builder: &mut AB, db: usize, d_lo: usize, d_hi: usize, sb: usize, s_lo: usize, s_hi: usize| {
+                    builder.assert_eq(e(db + d_lo), e(sb + s_lo));
+                    builder.assert_eq(e(db + d_hi), e(sb + s_hi));
+                };
+                let (bf0, bf1, bf2, bf3) = (BASE[0], BASE[1], BASE[2], BASE[3]);
+                let (bf4, bf5, bf6, bf7) = (BASE[4], BASE[5], BASE[6], BASE[7]);
+                let (bf8, bf9, bf10, bf11) = (BASE[8], BASE[9], BASE[10], BASE[11]);
+                // layer2 reads layer1 outputs:
+                wire(builder, bf4, A0, A1, bf0, O00, O01);
+                wire(builder, bf4, B0, B1, bf2, O00, O01);
+                wire(builder, bf5, A0, A1, bf1, O00, O01);
+                wire(builder, bf5, B0, B1, bf3, O00, O01);
+                wire(builder, bf6, A0, A1, bf0, O10, O11);
+                wire(builder, bf6, B0, B1, bf2, O10, O11);
+                wire(builder, bf7, A0, A1, bf1, O10, O11);
+                wire(builder, bf7, B0, B1, bf3, O10, O11);
+                // layer3 reads layer2 outputs:
+                wire(builder, bf8, A0, A1, bf4, O00, O01);
+                wire(builder, bf8, B0, B1, bf5, O00, O01);
+                wire(builder, bf9, A0, A1, bf4, O10, O11);
+                wire(builder, bf9, B0, B1, bf5, O10, O11);
+                wire(builder, bf10, A0, A1, bf6, O00, O01);
+                wire(builder, bf10, B0, B1, bf7, O00, O01);
+                wire(builder, bf11, A0, A1, bf6, O10, O11);
+                wire(builder, bf11, B0, B1, bf7, O10, O11);
+
+                // ---- IO binding on the first row: z INPUT and ẑ OUTPUT to the surfaced publics ----
+                let mut wf = builder.when_first_row();
+                for p in 0..NJOIN {
+                    let (ibf, is_b) = in_port(p);
+                    let ib = BASE[ibf];
+                    let (lo, hi) = if is_b { (B0, B1) } else { (A0, A1) };
+                    let v = Into::<AB::Expr>::into(row[ib + lo]) + beta.clone() * Into::<AB::Expr>::into(row[ib + hi]);
+                    wf.assert_eq(v, pis[PI_Z + p].clone());
+                }
+                for p in 0..NJOIN {
+                    let (obf, is_out1) = out_port(p);
+                    let ob = BASE[obf];
+                    let (lo, hi) = if is_out1 { (O10, O11) } else { (O00, O01) };
+                    let v = Into::<AB::Expr>::into(row[ob + lo]) + beta.clone() * Into::<AB::Expr>::into(row[ob + hi]);
+                    wf.assert_eq(v, pis[PI_ZHAT + p].clone());
+                }
+            }
+        }
+
+        fn split(v: u64) -> (u64, u64) {
+            (v % BETA, v / BETA)
+        }
+
+        /// Fill one CT butterfly's 460 columns for (a, b, ζ) → (out0=a+ζb, out1=a−ζb) mod q.
+        /// Returns (out0, out1). VERBATIM from ntt_wired8_air.rs::fill_bf.
+        fn fill_bf<F: PrimeField64>(vals: &mut [F], base: usize, a: u64, b: u64, zeta: u64) -> (u64, u64) {
+            let (z0, z1) = split(zeta);
+            let (b0, b1) = split(b);
+            let prod = (zeta as u128) * (b as u128);
+            let t = (prod % Q as u128) as u64;
+            let m = (prod / Q as u128) as u64;
+            let (m0, m1) = split(m);
+            let (t0, t1) = split(t);
+            let s0 = z0 * b0;
+            let (l0, kl0) = (s0 % BETA, s0 / BETA);
+            let s1 = z0 * b1 + z1 * b0 + kl0;
+            let (l1, kl1) = (s1 % BETA, s1 / BETA);
+            let s2 = z1 * b1 + kl1;
+            let (l2, kl2) = (s2 % BETA, s2 / BETA);
+            let u0 = m0 + t0;
+            let (mm0, kr0) = (u0 % BETA, u0 / BETA);
+            let u1 = m0 * Q1 + m1 + t1 + kr0;
+            let (mm1, kr1) = (u1 % BETA, u1 / BETA);
+            let u2 = m1 * Q1 + kr1;
+            let (mm2, kr2) = (u2 % BETA, u2 / BETA);
+            assert_eq!((l0, l1, l2, kl2), (mm0, mm1, mm2, kr2), "limb mismatch");
+            let sum = a + t;
+            let ko0 = if sum >= Q { 1u64 } else { 0 };
+            let out0 = sum - ko0 * Q;
+            let ko1 = if a >= t { 0u64 } else { 1 };
+            let out1 = a + ko1 * Q - t;
+            assert!(out0 < Q && out1 < Q);
+            let (a0, a1) = split(a);
+            let (o00, o01) = split(out0);
+            let (o10, o11) = split(out1);
+            let (gt0, gt1) = split((Q - 1) - t);
+            let (gm0, gm1) = split((Q - 1) - m);
+            let (ga0, ga1) = split((Q - 1) - a);
+            let (go00, go01) = split((Q - 1) - out0);
+            let (go10, go11) = split((Q - 1) - out1);
+            let prim = [
+                (Z0, z0), (Z1, z1), (B0, b0), (B1, b1), (MC0, m0), (MC1, m1), (T0, t0), (T1, t1),
+                (KL0, kl0), (KL1, kl1), (KL2, kl2), (KR0, kr0), (KR1, kr1), (KR2, kr2),
+                (L0, l0), (L1, l1), (L2, l2), (M0, mm0), (M1, mm1), (M2, mm2),
+                (GT0, gt0), (GT1, gt1), (GM0, gm0), (GM1, gm1),
+                (A0, a0), (A1, a1), (O00, o00), (O01, o01), (O10, o10), (O11, o11),
+                (KO0, ko0), (KO1, ko1),
+                (GA0, ga0), (GA1, ga1), (GO00, go00), (GO01, go01), (GO10, go10), (GO11, go11),
+            ];
+            for (col, v) in prim {
+                vals[base + col] = F::from_u64(v);
+                let bo = base + bit_off(col);
+                for j in 0..WIDTHS[col] {
+                    vals[bo + j] = F::from_u64((v >> j) & 1);
+                }
+            }
+            (out0, out1)
+        }
+
+        /// Fill the full-height trace: every row holds the complete forward n=8 CT NTT (12 butterflies,
+        /// threaded in-place exactly as ntt_wired8_air.rs). Returns the trace and the NTT-domain output
+        /// ẑ (natural position order = the in-place array after layer3).
+        pub fn generate<F: PrimeField64>(z_in: &[u64; NJOIN], zetas: &[u64; 7]) -> (RowMajorMatrix<F>, [u64; NJOIN]) {
+            let h = height();
+            let mut vals = F::zero_vec(h * NUM_COLS);
+            let mut zhat_out = [0u64; NJOIN];
+            for r in 0..h {
+                let o = r * NUM_COLS;
+                let seg = &mut vals[o..o + NUM_COLS];
+                let mut a = *z_in;
+                let mut bf = 0usize;
+                let mut k = 0usize;
+                let mut len = 4;
+                while len >= 1 {
+                    let mut start = 0;
+                    while start < 8 {
+                        k += 1;
+                        let zeta = zetas[k - 1];
+                        for j in start..start + len {
+                            let (o0, o1) = fill_bf(seg, BASE[bf], a[j], a[j + len], zeta);
+                            a[j] = o0;
+                            a[j + len] = o1;
+                            bf += 1;
+                        }
+                        start += 2 * len;
+                    }
+                    if len == 1 {
+                        break;
+                    }
+                    len /= 2;
+                }
+                // a[] now holds ẑ in natural position order (the in-place CT output = the reference ntt8).
+                zhat_out = a;
+            }
+            (RowMajorMatrix::new(vals, NUM_COLS), zhat_out)
+        }
+
+        pub fn build_pis<F: PrimeField64>(z_in: &[u64; NJOIN], zhat_out: &[u64; NJOIN]) -> Vec<F> {
+            z_in.iter().chain(zhat_out.iter()).map(|&v| F::from_u64(v)).collect()
+        }
+
+        // ---- reference oracles (VERBATIM ntt8 / schoolbook8 from ntt_wired8_air.rs, + a GS inverse
+        // for the round-trip gate) ----
+        fn modpow(base: u64, mut e: u64) -> u64 {
+            let mut r = 1u128;
+            let mut b = base as u128 % Q as u128;
+            while e > 0 {
+                if e & 1 == 1 {
+                    r = r * b % Q as u128;
+                }
+                b = b * b % Q as u128;
+                e >>= 1;
+            }
+            r as u64
+        }
+
+        /// Canonical n=8 twiddles ζ[k] (k=1..7): ζ[k]=ψ^brv3(k), ψ=1753^32 (a primitive 16th root,
+        /// ψ⁸ = −1) — the exact n=8 reduction of the Dilithium forward-NTT twiddle table.
+        pub fn params() -> [u64; 7] {
+            let psi = modpow(1753, 32);
+            let brv3 = |x: u64| -> u64 { ((x & 1) << 2) | (x & 2) | ((x >> 2) & 1) };
+            std::array::from_fn(|i| modpow(psi, brv3((i + 1) as u64)))
+        }
+
+        /// forward n=8 NTT (the exact schedule the AIR wires) → the NTT-domain array.
+        pub fn ntt8(x: &[u64; 8], z: &[u64; 7]) -> [u64; 8] {
+            let mut a = *x;
+            let mut k = 0usize;
+            let mut len = 4;
+            while len >= 1 {
+                let mut start = 0;
+                while start < 8 {
+                    k += 1;
+                    let zeta = z[k - 1];
+                    for j in start..start + len {
+                        let t = ((zeta as u128 * a[j + len] as u128) % Q as u128) as u64;
+                        a[j + len] = (a[j] + Q - t) % Q;
+                        a[j] = (a[j] + t) % Q;
+                    }
+                    start += 2 * len;
+                }
+                if len == 1 {
+                    break;
+                }
+                len /= 2;
+            }
+            a
+        }
+
+        /// Independent schoolbook negacyclic product `f · g mod (x⁸ + 1)` — the ground truth.
+        pub fn schoolbook8(f: &[u64; 8], g: &[u64; 8]) -> [u64; 8] {
+            let mut c = [0u128; 8];
+            for i in 0..8 {
+                for j in 0..8 {
+                    let p = (f[i] as u128) * (g[j] as u128);
+                    let k = i + j;
+                    if k < 8 {
+                        c[k] = (c[k] + p) % Q as u128;
+                    } else {
+                        c[k - 8] = (c[k - 8] + Q as u128 - (p % Q as u128)) % Q as u128; // x^8 = −1
+                    }
+                }
+            }
+            std::array::from_fn(|i| c[i] as u64)
+        }
+
+        /// reference GS inverse WITH the n⁻¹ normalization — for the round-trip gate invNTT(NTT(x))==x.
+        pub fn invntt8_scaled(input: &[u64; 8], z: &[u64; 7]) -> [u64; 8] {
+            let ninv = modpow(8, Q - 2);
+            let mut a = *input;
+            let mut k = 7usize;
+            let mut len = 1;
+            while len < 8 {
+                let mut start = 0;
+                while start < 8 {
+                    k -= 1;
+                    let zeta = z[k];
+                    for j in start..start + len {
+                        let aa = a[j];
+                        let bb = a[j + len];
+                        a[j] = (aa + bb) % Q;
+                        let d = (bb + Q - aa) % Q;
+                        a[j + len] = ((zeta as u128 * d as u128) % Q as u128) as u64;
+                    }
+                    start += 2 * len;
+                }
+                len *= 2;
+            }
+            std::array::from_fn(|i| ((a[i] as u128 * ninv as u128) % Q as u128) as u64)
+        }
+    }
+    // =======================================================================================
+    // LEG S — SampleInBall (the CHALLENGE-POLYNOMIAL front stage). FIPS-204 Algorithm 29
+    // Fisher-Yates placement, ported VERBATIM in structure from sample_in_ball_air.rs (witnessed
+    // one-hot index selectors, a_j read, j≤i slack) + the ball-membership check from
+    // sampleinball_air.rs (cₖ=posₖ−negₖ, posₖ·negₖ=0, Σ(posₖ+negₖ)=τ). The whole τ-step run is
+    // UNROLLED in ONE row (steps threaded next_s == a_{s+1}, a_0 = 0), exactly as NttAir carries a
+    // whole transform per row. Coefficients live in the mod-q residue alphabet {0, 1, q−1} so the
+    // output c composes directly with the forward NTT (a −1 is q−1). Exposes c OUTPUT publics [0..8].
+    // =======================================================================================
+    pub mod sib {
+        use super::*;
+
+        pub const NS: usize = 8; // reduced array size (= NJOIN, the n=8 NTT width)
+        pub const TAU_S: usize = 4; // reduced challenge weight (# nonzero ±1 coefficients / # steps)
+        const TBITS_S: usize = 3; // t = i − j ∈ [0, 8) needs 3 bits
+
+        // ---- per-step relative column layout (VERBATIM from sample_in_ball_air.rs, N→NS) ----
+        const SA: usize = 0; // a[0..NS]   (array before this step)
+        const SNEXT: usize = NS; // next[0..NS] (array after this step)
+        const SSEL: usize = 2 * NS; // sel[0..NS]  = [k==j]
+        const SINDI: usize = 3 * NS; // indi[0..NS] = [k==i]
+        const SI: usize = 4 * NS; // i
+        const SJ: usize = 4 * NS + 1; // j
+        const SSGN: usize = 4 * NS + 2; // sign bit (1 ⇒ −1)
+        const SAJ: usize = 4 * NS + 3; // a_j = a[j]
+        const ST: usize = 4 * NS + 4; // t = i − j
+        const SNP: usize = 4 * NS + 5;
+        const SBITS: usize = SNP; // TBITS_S slack bits start here
+        pub const STEP_COLS: usize = SNP + TBITS_S; // 40
+
+        // ---- ball-membership columns for the FINAL c (VERBATIM from sampleinball_air.rs) ----
+        pub const POS_C: usize = TAU_S * STEP_COLS; // pos[0..NS]
+        pub const NEG_C: usize = POS_C + NS; // neg[0..NS]
+        pub const NUM_COLS_SIB: usize = NEG_C + NS;
+
+        // ---- public values: c OUTPUT [0..NS] ----
+        pub const PI_C_OUT: usize = 0;
+        pub const NUM_PIS_SIB: usize = NS;
+
+        pub fn height() -> usize {
+            64 // ≥ 2^6 FRI foldability floor; every row carries the same full τ-step run
+        }
+        pub fn num_pis() -> usize {
+            NUM_PIS_SIB
+        }
+
+        #[derive(Clone)]
+        pub struct SibAir {}
+
+        impl<F: PrimeField64> BaseAir<F> for SibAir {
+            fn width(&self) -> usize {
+                NUM_COLS_SIB
+            }
+            fn num_public_values(&self) -> usize {
+                num_pis()
+            }
+            fn max_constraint_degree(&self) -> Option<usize> {
+                Some(3)
+            }
+        }
+
+        impl<AB: AirBuilder> Air<AB> for SibAir
+        where
+            AB::F: PrimeField64,
+        {
+            fn eval(&self, builder: &mut AB) {
+                let one = AB::Expr::ONE;
+                let qm1 = AB::Expr::from_u64(Q - 1);
+                let qm2 = AB::Expr::from_u64(Q - 2);
+                let pis: Vec<AB::Expr> =
+                    (0..num_pis()).map(|k| builder.public_values()[k].into()).collect();
+                let main = builder.main();
+                let row = main.current_slice();
+                let e = |i: usize| -> AB::Expr { row[i].into() };
+                let boolean = |b: AB::Expr, builder: &mut AB| {
+                    builder.assert_zero(b.clone() * (b - one.clone()))
+                };
+
+                // ---- each placement step (VERBATIM sample_in_ball_air.rs constraints, residue rep) ----
+                for s in 0..TAU_S {
+                    let b = s * STEP_COLS;
+                    // a[k] ∈ {0, 1, q−1}  (the residue-alphabet ternary: a·(a−1)·(a−(q−1)) = 0).
+                    for k in 0..NS {
+                        let a = e(b + SA + k);
+                        builder.assert_zero(a.clone() * (a.clone() - one.clone()) * (a - qm1.clone()));
+                    }
+                    // sel = [k==j] and indi = [k==i]: boolean, one-hot, Σ k·sel = j, Σ k·indi = i.
+                    let mut sum_sel = AB::Expr::ZERO;
+                    let mut idx_sel = AB::Expr::ZERO;
+                    let mut sum_indi = AB::Expr::ZERO;
+                    let mut idx_indi = AB::Expr::ZERO;
+                    for k in 0..NS {
+                        boolean(e(b + SSEL + k), builder);
+                        boolean(e(b + SINDI + k), builder);
+                        sum_sel = sum_sel + e(b + SSEL + k);
+                        idx_sel = idx_sel + e(b + SSEL + k) * AB::Expr::from_u64(k as u64);
+                        sum_indi = sum_indi + e(b + SINDI + k);
+                        idx_indi = idx_indi + e(b + SINDI + k) * AB::Expr::from_u64(k as u64);
+                    }
+                    builder.assert_eq(sum_sel, one.clone());
+                    builder.assert_eq(idx_sel, e(b + SJ));
+                    builder.assert_eq(sum_indi, one.clone());
+                    builder.assert_eq(idx_indi, e(b + SI));
+                    // j ≤ i: t = i − j ∈ [0, 8) via 3 bits.
+                    let mut tacc = AB::Expr::ZERO;
+                    let mut wt = AB::Expr::ONE;
+                    for bt in 0..TBITS_S {
+                        let bit: AB::Expr = row[b + SBITS + bt].into();
+                        boolean(bit.clone(), builder);
+                        tacc = tacc + bit * wt.clone();
+                        wt = wt.clone() + wt.clone();
+                    }
+                    builder.assert_eq(e(b + ST), tacc);
+                    builder.assert_eq(e(b + SI) - e(b + SJ), e(b + ST));
+                    // sign bit → placed value ∈ {1, q−1}:  sign = 1 + sgn·(q−2).
+                    boolean(e(b + SSGN), builder);
+                    let sign = one.clone() + e(b + SSGN) * qm2.clone();
+                    // a_j = Σ sel[k]·a[k]  (read c[j] before the step).
+                    let mut ajv = AB::Expr::ZERO;
+                    for k in 0..NS {
+                        ajv = ajv + e(b + SSEL + k) * e(b + SA + k);
+                    }
+                    builder.assert_eq(e(b + SAJ), ajv);
+                    // next[k] = a[k]·keep + indi·(1−sel)·a_j + sel·sign,
+                    //   keep = 1 − sel − indi + sel·indi.
+                    for k in 0..NS {
+                        let sk = e(b + SSEL + k);
+                        let dk = e(b + SINDI + k);
+                        let keep = one.clone() - sk.clone() - dk.clone() + sk.clone() * dk.clone();
+                        let put_i = dk.clone() * (one.clone() - sk.clone()) * e(b + SAJ);
+                        let put_j = sk * sign.clone();
+                        builder.assert_eq(e(b + SNEXT + k), e(b + SA + k) * keep + put_i + put_j);
+                    }
+                }
+
+                // ---- cross-step threading: step (s).a == step (s−1).next; a_0 = 0 ----
+                for s in 1..TAU_S {
+                    let bp = (s - 1) * STEP_COLS;
+                    let bc = s * STEP_COLS;
+                    for k in 0..NS {
+                        builder.assert_eq(e(bc + SA + k), e(bp + SNEXT + k));
+                    }
+                }
+                for k in 0..NS {
+                    builder.assert_zero(e(SA + k)); // step 0 base = 0: the empty initial poly
+                }
+
+                // ---- ball-membership on the FINAL c (last step's next): cₖ = posₖ − negₖ (residue),
+                //      posₖ·negₖ = 0, Σ(posₖ + negₖ) = τ (VERBATIM sampleinball_air.rs, residue rep) ----
+                let lb = (TAU_S - 1) * STEP_COLS;
+                let mut weight = AB::Expr::ZERO;
+                for k in 0..NS {
+                    let p = e(POS_C + k);
+                    let n = e(NEG_C + k);
+                    boolean(p.clone(), builder);
+                    boolean(n.clone(), builder);
+                    builder.assert_zero(p.clone() * n.clone());
+                    // residue decomposition: c = p·1 + n·(q−1)  (⇒ c ∈ {0, 1, q−1}).
+                    builder.assert_eq(e(lb + SNEXT + k), p.clone() + n.clone() * qm1.clone());
+                    weight = weight + p + n;
+                }
+                builder.assert_eq(weight, AB::Expr::from_u64(TAU_S as u64));
+
+                // ---- IO binding on the first row: c OUTPUT (last step's next) to the surfaced publics ----
+                let mut wf = builder.when_first_row();
+                for k in 0..NS {
+                    wf.assert_eq(Into::<AB::Expr>::into(row[lb + SNEXT + k]), pis[PI_C_OUT + k].clone());
+                }
+            }
+        }
+
+        fn res(v: i64) -> u64 {
+            v.rem_euclid(Q as i64) as u64
+        }
+
+        /// Fill the full-height trace: every row holds the complete τ-step Fisher-Yates run threaded
+        /// in place (VERBATIM swap semantics). `steps` are the (i, j, sign) placements. Returns the
+        /// trace and the challenge polynomial c in mod-q residues (natural coefficient order).
+        pub fn generate<F: PrimeField64>(steps: &[(usize, usize, i64)]) -> (RowMajorMatrix<F>, [u64; NS]) {
+            assert_eq!(steps.len(), TAU_S, "reduced SampleInBall expects {TAU_S} steps");
+            // simulate to recover a_before / next per step and the final c (signed).
+            let mut c = [0i64; NS];
+            let mut a_before: Vec<[i64; NS]> = Vec::with_capacity(TAU_S);
+            let mut nexts: Vec<[i64; NS]> = Vec::with_capacity(TAU_S);
+            for &(i, j, sign) in steps {
+                assert!(j <= i && i < NS && (sign == 1 || sign == -1));
+                a_before.push(c);
+                let aj = c[j];
+                c[i] = aj;
+                c[j] = sign;
+                nexts.push(c);
+            }
+            let c_final = c;
+            let c_res: [u64; NS] = core::array::from_fn(|k| res(c_final[k]));
+
+            // build ONE canonical row then replicate.
+            let mut rowvals = F::zero_vec(NUM_COLS_SIB);
+            for s in 0..TAU_S {
+                let b = s * STEP_COLS;
+                let (i, j, sign) = steps[s];
+                let ab = a_before[s];
+                let nx = nexts[s];
+                for k in 0..NS {
+                    rowvals[b + SA + k] = F::from_u64(res(ab[k]));
+                    rowvals[b + SNEXT + k] = F::from_u64(res(nx[k]));
+                    rowvals[b + SSEL + k] = F::from_u64((k == j) as u64);
+                    rowvals[b + SINDI + k] = F::from_u64((k == i) as u64);
+                }
+                rowvals[b + SI] = F::from_u64(i as u64);
+                rowvals[b + SJ] = F::from_u64(j as u64);
+                rowvals[b + SSGN] = F::from_u64((sign == -1) as u64);
+                rowvals[b + SAJ] = F::from_u64(res(ab[j]));
+                let t = (i - j) as u64;
+                rowvals[b + ST] = F::from_u64(t);
+                for bt in 0..TBITS_S {
+                    rowvals[b + SBITS + bt] = F::from_u64((t >> bt) & 1);
+                }
+            }
+            for k in 0..NS {
+                let (p, n) = match c_final[k] {
+                    1 => (1u64, 0u64),
+                    -1 => (0u64, 1u64),
+                    0 => (0u64, 0u64),
+                    _ => unreachable!("challenge coefficient must be ternary"),
+                };
+                rowvals[POS_C + k] = F::from_u64(p);
+                rowvals[NEG_C + k] = F::from_u64(n);
+            }
+            let h = height();
+            let mut vals = F::zero_vec(h * NUM_COLS_SIB);
+            for r in 0..h {
+                vals[r * NUM_COLS_SIB..(r + 1) * NUM_COLS_SIB].copy_from_slice(&rowvals);
+            }
+            (RowMajorMatrix::new(vals, NUM_COLS_SIB), c_res)
+        }
+
+        pub fn build_pis<F: PrimeField64>(c_res: &[u64; NS]) -> Vec<F> {
+            c_res.iter().map(|&v| F::from_u64(v)).collect()
+        }
+    }
+
+    /// Independent SHAKE256 XOF (tiny-keccak), `outlen` bytes of the stream — the source of the
+    /// SampleInBall (i, j, sign) placement sequence (the byte source is otherwise a separately-proven
+    /// SHAKE AIR; the placement leg is independent of it, exactly as `mldsa_verify_ref`).
+    fn shake256_xof(input: &[u8], outlen: usize) -> Vec<u8> {
+        let mut sh = Shake::v256();
+        sh.update(input);
+        let mut out = vec![0u8; outlen];
+        sh.finalize(&mut out);
+        out
+    }
+
+    /// Reduced (n=8, τ=4) reference `SampleInBall` — VERBATIM from `mldsa_verify_ref.rs::sample_in_ball`
+    /// (rejection j ≤ i, τ sign bits), driven by the REAL `SHAKE256(c̃)` stream. Returns the signed
+    /// challenge c AND the (i, j, sign) step sequence (the placement witness the leg proves).
+    fn ref_sample_in_ball(ctilde: &[u8]) -> ([i64; sib::NS], Vec<(usize, usize, i64)>) {
+        let stream = shake256_xof(ctilde, 2048);
+        let mut signs = u64::from_le_bytes(stream[0..8].try_into().unwrap());
+        let mut pos = 8usize;
+        let mut c = [0i64; sib::NS];
+        let mut steps = Vec::with_capacity(sib::TAU_S);
+        for i in (sib::NS - sib::TAU_S)..sib::NS {
+            let j = loop {
+                let b = stream[pos] as usize;
+                pos += 1;
+                assert!(pos < stream.len(), "SampleInBall rejection ran off the XOF buffer");
+                if b <= i {
+                    break b;
+                }
+            };
+            let sign = 1 - 2 * (signs & 1) as i64;
+            signs >>= 1;
+            c[i] = c[j];
+            c[j] = sign;
+            steps.push((i, j, sign));
+        }
+        assert_eq!(c.iter().filter(|&&x| x != 0).count(), sib::TAU_S, "reduced SampleInBall weight");
+        assert!(c.iter().all(|&x| x == -1 || x == 0 || x == 1));
+        (c, steps)
+    }
+
+    // =======================================================================================
+    // Native batch-STARK leg provers (single-instance batch proofs)
+    // =======================================================================================
+    type LegProof = (
+        BatchProof<ConfigWithFriParams>,
+        ProverData<ConfigWithFriParams>,
+        Vec<F>,
+    );
+
+    /// Prove Leg F (forward NTT front) over the coefficient-domain input; return (proof, ..., publics)
+    /// and the NTT-domain output.
+    fn prove_ntt_leg(
+        config: &ConfigWithFriParams,
+        air: &ntt::NttAir,
+        z_in: &[u64; NJOIN],
+    ) -> (LegProof, [u64; NJOIN]) {
+        let (trace, zhat_out) = ntt::generate::<F>(z_in, &air.zetas);
+        let pis = ntt::build_pis::<F>(z_in, &zhat_out);
+        let instances = vec![StarkInstance { air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .expect("native Leg F batch verify failed");
+        ((proof, pd, pis), zhat_out)
+    }
+
+    /// Whether Leg F over a trace with a TAMPERED butterfly output is REJECTED by native verify.
+    fn ntt_tamper_rejects(config: &ConfigWithFriParams, air: &ntt::NttAir, z_in: &[u64; NJOIN]) -> bool {
+        let (mut trace, zhat_out) = ntt::generate::<F>(z_in, &air.zetas);
+        let a0 = 8 * 460 + 24; // bf8 base = 8 * 460; A0 = column 24
+        trace.values[a0] += F::ONE;
+        let pis = ntt::build_pis::<F>(z_in, &zhat_out);
+        let instances = vec![StarkInstance { air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .is_err()
+    }
+
+    /// Prove Leg S (SampleInBall placement + ball membership) over a step sequence; return
+    /// (proof, ..., publics) and the challenge polynomial c in mod-q residues.
+    fn prove_sib_leg(
+        config: &ConfigWithFriParams,
+        steps: &[(usize, usize, i64)],
+    ) -> (LegProof, [u64; sib::NS]) {
+        let air = sib::SibAir {};
+        let (trace, c_res) = sib::generate::<F>(steps);
+        let pis = sib::build_pis::<F>(&c_res);
+        let instances = vec![StarkInstance { air: &air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(&air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .expect("native Leg S batch verify failed");
+        ((proof, pd, pis), c_res)
+    }
+
+    /// NEG-STEP: tamper one placement step's `next` output — the swap formula + the next step's
+    /// threading are violated → native Leg S verify REJECTS.
+    fn sib_tamper_step_rejects(config: &ConfigWithFriParams, steps: &[(usize, usize, i64)]) -> bool {
+        let air = sib::SibAir {};
+        let (mut trace, c_res) = sib::generate::<F>(steps);
+        let col = 1 * sib::STEP_COLS + sib::NS; // step 1, SNEXT[0]
+        trace.values[col] += F::ONE;
+        let pis = sib::build_pis::<F>(&c_res);
+        let instances = vec![StarkInstance { air: &air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(&air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .is_err()
+    }
+
+    /// NEG-WEIGHT: force a τ+1 non-ball challenge (set pos at a zero coefficient) — the ball
+    /// membership block (Σ(pos+neg)=τ AND the pos/neg decomposition) is violated → native REJECTS.
+    fn sib_weight_rejects(config: &ConfigWithFriParams, steps: &[(usize, usize, i64)]) -> bool {
+        let air = sib::SibAir {};
+        let (mut trace, c_res) = sib::generate::<F>(steps);
+        let z = (0..sib::NS).find(|&k| c_res[k] == 0).expect("a zero challenge coefficient to over-set");
+        let col = sib::POS_C + z;
+        trace.values[col] = F::ONE; // weight → τ+1, and c[z]=0 ≠ pos+neg·(q−1)=1
+        let pis = sib::build_pis::<F>(&c_res);
+        let instances = vec![StarkInstance { air: &air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(&air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .is_err()
+    }
+
+    // =======================================================================================
+    // TWO-stage outer recursion: verify Leg S (SampleInBall) + Leg F (forward NTT) in ONE circuit,
+    // bind the ONE cross-stage tie (S↔F: c OUTPUT == c INPUT), produce ONE outer proof = the
+    // challenge-polynomial front stage joined into the forward NTT that consumes it.
+    // =======================================================================================
+    #[allow(clippy::too_many_arguments)]
+    fn build_and_prove_outer2_sib(
+        config: &ConfigWithFriParams,
+        fvp: &FriVerifierParams,
+        fri_params: &FriParams,
+        air_s: &sib::SibAir,
+        leg_s: &LegProof,
+        air_f: &ntt::NttAir,
+        leg_f: &LegProof,
+        do_connect: bool,
+    ) -> Result<(usize, u32), String> {
+        let (proof_s, pd_s, pub_s) = leg_s;
+        let (proof_f, pd_f, pub_f) = leg_f;
+        let perm = p3_koala_bear::default_koalabear_poseidon2_16();
+        let mut cb = CircuitBuilder::new();
+        cb.enable_poseidon2_perm::<p3_poseidon2_circuit_air::KoalaBearD4Width16, _>(
+            generate_poseidon2_trace::<Challenge, p3_poseidon2_circuit_air::KoalaBearD4Width16>,
+            perm,
+        );
+        cb.enable_recompose::<F>(generate_recompose_trace::<F, Challenge>);
+        let lookup_gadget = LogUpGadget::new();
+
+        macro_rules! verify_leg {
+            ($proof:expr, $pd:expr, $pub:expr, $air:expr, $what:literal) => {{
+                let vi = BatchStarkVerifierInputsBuilder::<
+                    ConfigWithFriParams,
+                    MerkleCapTargets<F, DIGEST_ELEMS>,
+                    InnerFri,
+                >::allocate(&mut cb, $proof, &$pd.common, &[$pub.len()]);
+                let op_ids = verify_batch_circuit::<_, _, _, _, _, _, _, WIDTH, RATE>(
+                    config,
+                    core::slice::from_ref($air),
+                    &mut cb,
+                    &vi.proof_targets,
+                    &vi.air_public_targets,
+                    fvp,
+                    &vi.common_data,
+                    &lookup_gadget,
+                    Poseidon2Config::KOALA_BEAR_D4_W16,
+                )
+                .map_err(|e| format!("build {} verify circuit: {e:?}", $what))?;
+                (vi, op_ids)
+            }};
+        }
+
+        let (vi_s, op_ids_s) = verify_leg!(proof_s, pd_s, pub_s, air_s, "Leg S");
+        let (vi_f, op_ids_f) = verify_leg!(proof_f, pd_f, pub_f, air_f, "Leg F");
+
+        // ---- the ONE cross-stage tie (an ALU sub asserted zero — each public read once) ----
+        // Tie (S↔F): Leg-S c[k] (OUTPUT, PI_C_OUT) == Leg-F c_in[k] (INPUT, ntt::PI_Z) for k in 0..8.
+        if do_connect {
+            for k in 0..sib::NS {
+                let diff = cb.sub(
+                    vi_s.air_public_targets[0][sib::PI_C_OUT + k],
+                    vi_f.air_public_targets[0][ntt::PI_Z + k],
+                );
+                cb.assert_zero(diff);
+            }
+        }
+
+        let vc = cb.build().map_err(|e| format!("outer circuit build: {e:?}"))?;
+        let witness_count = vc.witness_count;
+        println!("  recursion circuit (2-leg S∘F): witness_count={witness_count}, connect={do_connect}");
+
+        // Pack public/private inputs in allocation order (S, F).
+        let (pub_in_s, priv_in_s) = vi_s.pack_values(core::slice::from_ref(pub_s), proof_s, &pd_s.common);
+        let (pub_in_f, priv_in_f) = vi_f.pack_values(core::slice::from_ref(pub_f), proof_f, &pd_f.common);
+        let mut public_inputs = pub_in_s;
+        public_inputs.extend(pub_in_f);
+        let mut private_inputs = priv_in_s;
+        private_inputs.extend(priv_in_f);
+
+        let mut runner = vc.runner();
+        runner.set_public_inputs(&public_inputs).map_err(|e| format!("set publics: {e:?}"))?;
+        runner.set_private_inputs(&private_inputs).map_err(|e| format!("set privates: {e:?}"))?;
+        for (op_ids, proof) in [(&op_ids_s, proof_s), (&op_ids_f, proof_f)] {
+            set_fri_mmcs_private_data::<F, Challenge, ChallengeMmcs, MyMmcs, MyHash, MyCompress, DIGEST_ELEMS>(
+                &mut runner,
+                op_ids,
+                &proof.opening_proof,
+                Poseidon2Config::KOALA_BEAR_D4_W16,
+            )
+            .map_err(|e| format!("mmcs private data: {e}"))?;
+        }
+
+        // NEGATIVE case fails HERE (aliased cross-stage public with a conflicting value).
+        let traces = runner.run().map_err(|e| format!("recursion circuit run rejected: {e:?}"))?;
+
+        // ---- Prove the outer (aggregated) proof ----
+        let l1_packing = TablePacking::new(1, 2)
+            .with_fri_params(fri_params.log_final_poly_len, fri_params.log_blowup);
+        let npo_prep: Vec<Box<dyn NpoPreprocessor<F>>> =
+            vec![Box::new(Poseidon2Preprocessor), Box::new(RecomposePreprocessor::default())];
+        let mut air_builders = poseidon2_air_builders::<ConfigWithFriParams, D>();
+        air_builders.extend(recompose_air_builders::<ConfigWithFriParams, D>(1, false));
+        let (airs_degrees, prim_cols, non_prim_cols) =
+            get_airs_and_degrees_with_prep::<ConfigWithFriParams, Challenge, D>(
+                &vc,
+                &l1_packing,
+                &npo_prep,
+                &air_builders,
+                ConstraintProfile::Standard,
+            )
+            .map_err(|e| format!("outer airs/degrees: {e:?}"))?;
+        let (airs, degrees): (Vec<_>, Vec<usize>) = airs_degrees.into_iter().unzip();
+        let prover_data = ProverData::from_airs_and_degrees(config, &airs, &degrees);
+        let cpd = CircuitProverData::new(prover_data, prim_cols, non_prim_cols);
+        let mut prover = BatchStarkProver::new(config.clone())
+            .with_table_packing(l1_packing)
+            .with_alu_variant(AirVariant::Baseline);
+        prover.register_poseidon2_table::<D>(Poseidon2Config::KOALA_BEAR_D4_W16);
+        prover.register_recompose_table::<D>(false);
+        let proof = prover.prove_all_tables(&traces, &cpd).map_err(|e| format!("prove outer: {e:?}"))?;
+        prover.verify_all_tables::<Challenge>(&proof).map_err(|e| format!("verify outer: {e:?}"))?;
+        let bytes = postcard::to_allocvec(&proof).map_err(|e| format!("serialize outer: {e:?}"))?.len();
+        Ok((bytes, witness_count))
+    }
+
+    pub fn run() {
+        let fri_params = FriParams {
+            log_blowup: 2,
+            max_log_arity: 2,
+            cap_height: 0,
+            log_final_poly_len: 5,
+            commit_pow_bits: 0,
+            query_pow_bits: 15,
+        };
+        let config = config_with_fri_params(&fri_params, SECURITY, false);
+        let fvp = create_fri_verifier_params(&fri_params, SECURITY);
+
+        let zetas8 = ntt::params();
+        let air_f = ntt::NttAir { zetas: zetas8 };
+        let air_s = sib::SibAir {};
+
+        info!(
+            "SampleInBall JOIN: Leg S (SampleInBall n={} τ={} {}×{}, {} pubs), Leg F (forward NTT n=8 \
+             {}×{}, {} pubs); NJOIN={NJOIN}, security={SECURITY}",
+            sib::NS, sib::TAU_S, sib::NUM_COLS_SIB, sib::height(), sib::num_pis(),
+            ntt::NUM_COLS, ntt::height(), ntt::num_pis(),
+        );
+
+        // ============ GATE 0: forward-NTT gadget correctness — the ntt_zq oracle at n=8 ============
+        {
+            let mut s = 0x9151_C0DE_2718_2818u64;
+            let mut nextq = || {
+                s = s.wrapping_add(0x9E3779B97F4A7C15);
+                let mut z = s;
+                z = (z ^ (z >> 30)).wrapping_mul(0xBF58476D1CE4E5B9);
+                z = (z ^ (z >> 27)).wrapping_mul(0x94D049BB133111EB);
+                (z ^ (z >> 31)) % Q
+            };
+            for _ in 0..200 {
+                let f: [u64; NJOIN] = std::array::from_fn(|_| nextq());
+                let g: [u64; NJOIN] = std::array::from_fn(|_| nextq());
+                let nf = ntt::ntt8(&f, &zetas8);
+                let ng = ntt::ntt8(&g, &zetas8);
+                let nc = ntt::ntt8(&ntt::schoolbook8(&f, &g), &zetas8);
+                for i in 0..NJOIN {
+                    let prod = ((nf[i] as u128 * ng[i] as u128) % Q as u128) as u64;
+                    assert_eq!(prod, nc[i], "convolution theorem failed at {i}");
+                }
+                assert_eq!(ntt::invntt8_scaled(&nf, &zetas8), f, "invNTT(NTT(x)) must recover x");
+            }
+        }
+        println!(
+            "GATE 0 ok — forward NTT gadget: convolution theorem + round-trip, coefficient-exact over \
+             200 random (f,g) — the ntt_zq oracle at n=8."
+        );
+
+        // ============ pick a representative 64-byte c̃; c = SampleInBall(c̃) via Leg S ============
+        let ctilde: [u8; 64] = core::array::from_fn(|k| (0x1b_u8).wrapping_mul(k as u8 + 1) ^ 0x5c);
+        let (c_signed, steps) = ref_sample_in_ball(&ctilde);
+        let c_res_ref: [u64; sib::NS] = core::array::from_fn(|k| c_signed[k].rem_euclid(Q as i64) as u64);
+
+        // ============ Leg S: the SampleInBall challenge-polynomial front stage ============
+        let t = Instant::now();
+        let (leg_s, c_res) = prove_sib_leg(&config, &steps);
+        // GATE 1: Leg S output c == reduced reference SampleInBall (mod-q residues), coefficient-exact.
+        assert_eq!(c_res, c_res_ref, "Leg S c != reference SampleInBall");
+        for k in 0..sib::NS {
+            assert_eq!(leg_s.2[sib::PI_C_OUT + k], F::from_u64(c_res[k]), "Leg S public c[{k}]");
+        }
+        let nz = c_res.iter().filter(|&&v| v != 0).count();
+        println!(
+            "Leg S (SampleInBall front) batch proof: {} bytes, {} pubs, {} cols × {} rows, real c̃-driven \
+             stream, c == reference SampleInBall exact (τ={nz} nonzeros, ±1 residues {{1, q−1}}), {:.1?}",
+            postcard::to_allocvec(&leg_s.0).unwrap().len(), leg_s.2.len(), sib::NUM_COLS_SIB, sib::height(),
+            t.elapsed()
+        );
+
+        // ============ Leg F: ĉ = NTT(c) over the SampleInBall output (first n=8 slice = REAL c) ======
