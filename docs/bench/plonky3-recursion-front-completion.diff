+        println!(
+            "Leg F (forward NTT front) batch proof: {} bytes, {} pubs, ĉ == NTT(c) exact, {:.1?}",
+            postcard::to_allocvec(&leg_f.0).unwrap().len(), leg_f.2.len(), t.elapsed()
