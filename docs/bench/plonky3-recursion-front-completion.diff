--- /dev/null
+++ b/recursion/examples/pkdecode_join.rs
@@ -0,0 +1,1045 @@
+//! **ML-DSA-87 verify FRONT sub-chain: t1 = pkDecode(pk) → t̂1 = NTT(t1), composed into recursion.**
+//! This lands the public-key-parse front stage and BINDS it to the forward-NTT leg that transforms
+//! t1, so `t1 = pkDecode(pk)` then `t̂1 = NTT(t1)` is proven as ONE 2-stage recursion sub-chain over
+//! two heterogeneous gadgets (the DECODE partner of the SampleInBall sub-chain, `sampleinball_join`):
+//!
+//! ```text
+//!   pk bytes ──pkDecode──▶ t1  ──Tie──▶  t1 ──forwardNTT──▶ t̂1
+//!   (Leg P: FIPS-204 SimpleBitPack     (Leg F: NttAir, ntt_wired8_air.rs
+//!    10-bit unpack)                     forward CT n=8 — same as front_ntt_join)
+//! ```
+//!
+//!   - **Leg P — pkDecode t1** (NEW; the FIPS-204 SimpleBitPack 10-bit unpack, ported VERBATIM from
+//!     `docs/bench/plonky3-shield-air/pkdecode_t1_air.rs`): one group = 4 coefficients (each
+//!     t1ₖ ∈ [0, 2¹⁰)) unpacked from 5 packed bytes via 40 shared bits regrouped 10-bit-per-coeff vs
+//!     8-bit-per-byte. NG=2 groups are unrolled per row → 8 coefficients (= the n=8 NTT width),
+//!     replicated across rows exactly as the NttAir carries a whole transform per row. Exposes the
+//!     unpacked **t1 OUTPUT** publics [0..8]; a wrong-endianness / off-by-a-bit unpack is rejected.
+//!   - **Leg F — forward NTT** (`NttAir`, VERBATIM from `ntt_wired8_air.rs` / `front_ntt_join.rs`):
+//!     the complete CT n=8 forward NTT, `t̂1 = NTT(t1)`, exposing coefficient-domain **t1 INPUT**
+//!     [0..8] and NTT-domain **t̂1 OUTPUT** [8..16]. (The matvec then scales t̂1 by 2^d.)
+//!   - **Tie (P↔F)**: `Leg-P t1[k] (OUTPUT) == Leg-F t1_in[k] (INPUT, PI_Z)` for k in 0..8 — an ALU
+//!     `sub` asserted zero (each surfaced public read once, as the sibling chains).
+//!
+//! ## Scope (REDUCED-BUT-REAL)
+//!   - Leg P is the COMPLETE SimpleBitPack 10-bit unpack (VERBATIM); NG=2 groups → 8 coefficients is
+//!     the reduced count the n=8 NTT leg blessed (real ML-DSA-87 packs N=256 per poly, 64 groups).
+//!   - The packed bytes are a representative packed-t1 slice — every 5-byte group is a valid
+//!     SimpleBitPack encoding of 4 coefficients in [0, 2^10). The recursion clone has no libcrux dep
+//!     to extract a specific key's bytes (see caveats); the unpack is exact regardless of provenance.
+//!   - Leg P's output t1 is diff-tested coefficient-exact vs the reference `unpack10`
+//!     (VERBATIM from `pkdecode_t1_air.rs`).
+//!
+//! ## Cases (all in one run)
+//!   1. HONEST (t1 = pkDecode(pk), t̂1 = NTT(t1), Tie P↔F): outer prove+verify SUCCEEDS.
+//!   2. NEG-UNPACK (tamper a coefficient off its 10-bit grouping): Leg P native verify REJECTS.
+//!   3. NEG-TIE (feed the NTT leg a t1 ≠ pkDecode's t1): the Tie P↔F mismatch → REJECTS at prove.
+//!
+//! ```bash
+//! cargo run --release --example pkdecode_join
+//! ```
+
+#[macro_use]
+mod common;
+use common::*;
+
+use p3_air::{Air, AirBuilder, BaseAir, WindowAccess};
+use p3_batch_stark::{BatchProof, ProverData, StarkInstance, prove_batch, verify_batch};
+use p3_circuit_prover::{AirVariant, RecomposePreprocessor, recompose_air_builders};
+use p3_field::PrimeField64;
+use std::time::Instant;
+
+fn main() {
+    init_logger();
+    kb::run();
+}
+
+mod kb {
+    // The matvec / usehint modules are copied VERBATIM from the sibling examples; a few of their
+    // host reference helpers (matvec_ref / m / mulq / ahat_read_cell / psum_cell / QI_M) are the
+    // diff-test oracles those files use but this join does not — kept for byte-fidelity.
+    #![allow(dead_code)]
+    use super::*;
+
+    // KoalaBear, D=4, W=16 Poseidon2 — same field/hash plumbing as `expanda_chain_matvec` /
+    // `accept_tail` (the GS invNTT gadget is generic over PrimeField64; q < 2^23 ≪ KoalaBear p,
+    // so every limb/product value stores exactly and the BabyBear-authored gadget is byte-for-byte
+    // the same constraint system over KoalaBear).
+    define_field_module_types!(
+        p3_koala_bear::KoalaBear,
+        p3_koala_bear::Poseidon2KoalaBear<16>,
+        p3_koala_bear::default_koalabear_poseidon2_16,
+        Poseidon2Config::KOALA_BEAR_D4_W16,
+        p3_poseidon2_circuit_air::KoalaBearD4Width16,
+        4,
+        16,
+        8,
+        8,
+        enable_poseidon2_perm,
+        p3_koala_bear::default_koalabear_poseidon2_16,
+        16,
+        8,
+        enable_recompose,
+        generate_poseidon2_trace,
+        p3_circuit::ops::Poseidon2Params
+    );
+
+    // ---- shared constants ----
+    const Q: u64 = 8380417; // ML-DSA / Dilithium modulus (matvec uses u64 form)
+    const QI: i64 = Q as i64; // i64 form (UseHint / invNTT reference arithmetic)
+    const N: usize = 256; // coefficients per poly (matvec candidate placement)
+    const CBUD: usize = 320; // per-entry candidate budget (matvec Leg-B pack tie)
+    const STREAM_BYTES: usize = 3 * CBUD; // 960 candidate bytes per ExpandA entry
+    const I_ROW: usize = 0; // shipped ExpandA output row index i
+
+    // UseHint / Decompose constants (FIPS-204 ML-DSA-87)
+    const GAMMA2: i64 = (QI - 1) / 32; // 261888
+    const G2: i64 = 2 * GAMMA2; // 523776
+    const MM: i64 = 16; // (q-1)/(2γ2)
+    const KB_P: i64 = 2130706433; // KoalaBear prime (is-zero-witness modulus for Leg U)
+    const NW1: usize = 256; // one poly's worth of w / w1 (reduced-but-real)
+
+    const NJOIN: usize = 8; // coefficients carried matvec→invNTT→UseHint (= the n=8 invNTT width)
+    const SECURITY: usize = 100;
+    // =======================================================================================
+    // LEG F — forward NTT (the FRONT stage). COMPLETE Cooley-Tukey n=8 forward NTT over Z_q with
+    // FULL in-AIR cross-layer routing (CT constraints VERBATIM from ntt_wired8_air.rs, the reduced
+    // partner of the proven 256-pt ntt_wired256_air.rs). Exposes z INPUT publics [0..8] and the
+    // ẑ = NTT(z) OUTPUT publics [8..16]. No n⁻¹ scaling (that belongs to the inverse transform).
+    // =======================================================================================
+    pub mod ntt {
+        use super::*;
+
+        const BETA: u64 = 4096;
+        const Q1: u64 = 2046;
+
+        // one CT butterfly's 38 primary columns (VERBATIM layout from ntt_wired8_air.rs) then bits.
+        const Z0: usize = 0;
+        const Z1: usize = 1;
+        const B0: usize = 2;
+        const B1: usize = 3;
+        const MC0: usize = 4;
+        const MC1: usize = 5;
+        const T0: usize = 6;
+        const T1: usize = 7;
+        const KL0: usize = 8;
+        const KL1: usize = 9;
+        const KL2: usize = 10;
+        const KR0: usize = 11;
+        const KR1: usize = 12;
+        const KR2: usize = 13;
+        const L0: usize = 14;
+        const L1: usize = 15;
+        const L2: usize = 16;
+        const M0: usize = 17;
+        const M1: usize = 18;
+        const M2: usize = 19;
+        const GT0: usize = 20;
+        const GT1: usize = 21;
+        const GM0: usize = 22;
+        const GM1: usize = 23;
+        const A0: usize = 24;
+        const A1: usize = 25;
+        const O00: usize = 26;
+        const O01: usize = 27;
+        const O10: usize = 28;
+        const O11: usize = 29;
+        const KO0: usize = 30;
+        const KO1: usize = 31;
+        const GA0: usize = 32;
+        const GA1: usize = 33;
+        const GO00: usize = 34;
+        const GO01: usize = 35;
+        const GO10: usize = 36;
+        const GO11: usize = 37;
+        const NP: usize = 38;
+        const WIDTHS: [usize; NP] = [
+            12, 11, 12, 11, 12, 11, 12, 11, 12, 13, 11, 2, 13, 11, 12, 12, 12, 12, 12, 12, 12, 11, 12, 11, 12, 11, 12, 11,
+            12, 11, 1, 1, 12, 11, 12, 11, 12, 11,
+        ];
+        const BF_COLS: usize = 460; // 38 primary + 422 bits
+        // 12 CT butterflies of the n=8 forward (3 layers × 4). No scaling stage (forward has no n⁻¹).
+        const NBF: usize = 12;
+        pub const NUM_COLS: usize = NBF * BF_COLS; // 5520
+        // butterfly bases in schedule order:
+        //   layer1 (len=4): bf0=(0,4) bf1=(1,5) bf2=(2,6) bf3=(3,7)
+        //   layer2 (len=2): bf4=(0,2) bf5=(1,3) bf6=(4,6) bf7=(5,7)
+        //   layer3 (len=1): bf8=(0,1) bf9=(2,3) bf10=(4,5) bf11=(6,7)
+        const BASE: [usize; NBF] = {
+            let mut b = [0usize; NBF];
+            let mut i = 0;
+            while i < NBF {
+                b[i] = i * BF_COLS;
+                i += 1;
+            }
+            b
+        };
+
+        fn bit_off(col: usize) -> usize {
+            NP + WIDTHS[..col].iter().sum::<usize>()
+        }
+
+        // ---- public values: z INPUT [0..8] then ẑ OUTPUT [8..16] ----
+        pub const PI_Z: usize = 0;
+        pub const PI_ZHAT: usize = NJOIN;
+        pub const NUM_PIS: usize = 2 * NJOIN;
+
+        pub fn height() -> usize {
+            64 // ≥ 2^6 FRI foldability floor; every row carries the same full transform
+        }
+        pub fn num_pis() -> usize {
+            NUM_PIS
+        }
+
+        /// The 8 layer-1 INPUT ports (z position p) as (butterfly, is_b):
+        /// bf0=(pos0,pos4) bf1=(pos1,pos5) bf2=(pos2,pos6) bf3=(pos3,pos7) — so p<4 is bf_p.a,
+        /// p≥4 is bf_{p-4}.b.
+        fn in_port(p: usize) -> (usize, bool) {
+            if p < 4 { (p, false) } else { (p - 4, true) }
+        }
+        /// The layer-3 OUTPUT at natural position p as (butterfly, is_out1):
+        /// pos0=bf8.out0,pos1=bf8.out1,…,pos6=bf11.out0,pos7=bf11.out1.
+        fn out_port(p: usize) -> (usize, bool) {
+            (8 + p / 2, p % 2 == 1)
+        }
+
+        /// The AIR carries the seven canonical n=8 twiddles ζ[k]=ψ^brv3(k), ψ=1753^32.
+        #[derive(Clone)]
+        pub struct NttAir {
+            pub zetas: [u64; 7],
+        }
+
+        impl<F: PrimeField64> BaseAir<F> for NttAir {
+            fn width(&self) -> usize {
+                NUM_COLS
+            }
+            fn num_public_values(&self) -> usize {
+                num_pis()
+            }
+            fn max_constraint_degree(&self) -> Option<usize> {
+                Some(2)
+            }
+        }
+
+        impl<AB: AirBuilder> Air<AB> for NttAir
+        where
+            AB::F: PrimeField64,
+        {
+            fn eval(&self, builder: &mut AB) {
+                let one = AB::Expr::ONE;
+                let beta = AB::Expr::from_u64(BETA);
+                let q1 = AB::Expr::from_u64(Q1);
+                let q = AB::Expr::from_u64(Q);
+                let qm1 = AB::Expr::from_u64(Q - 1);
+                let pis: Vec<AB::Expr> =
+                    (0..num_pis()).map(|k| builder.public_values()[k].into()).collect();
+                let main = builder.main();
+                let row = main.current_slice();
+                let e = |i: usize| -> AB::Expr { row[i].into() };
+
+                // ---- each CT butterfly (all 12): the proven gadget, VERBATIM from ntt_wired8_air.rs ----
+                for &b in BASE.iter() {
+                    for c in 0..NP {
+                        let bo = b + bit_off(c);
+                        let mut acc = AB::Expr::ZERO;
+                        let mut w = AB::Expr::ONE;
+                        for j in 0..WIDTHS[c] {
+                            let bit: AB::Expr = row[bo + j].into();
+                            builder.assert_zero(bit.clone() * (bit.clone() - one.clone()));
+                            acc = acc + bit * w.clone();
+                            w = w.clone() + w.clone();
+                        }
+                        builder.assert_eq(e(b + c), acc);
+                    }
+                    // mod-q multiply t = ζ·b (limb carry chain)
+                    builder.assert_eq(e(b + Z0) * e(b + B0), e(b + L0) + beta.clone() * e(b + KL0));
+                    builder.assert_eq(
+                        e(b + Z0) * e(b + B1) + e(b + Z1) * e(b + B0) + e(b + KL0),
+                        e(b + L1) + beta.clone() * e(b + KL1),
+                    );
+                    builder.assert_eq(e(b + Z1) * e(b + B1) + e(b + KL1), e(b + L2) + beta.clone() * e(b + KL2));
+                    builder.assert_eq(e(b + MC0) + e(b + T0), e(b + M0) + beta.clone() * e(b + KR0));
+                    builder.assert_eq(
+                        e(b + MC0) * q1.clone() + e(b + MC1) + e(b + T1) + e(b + KR0),
+                        e(b + M1) + beta.clone() * e(b + KR1),
+                    );
+                    builder.assert_eq(e(b + MC1) * q1.clone() + e(b + KR1), e(b + M2) + beta.clone() * e(b + KR2));
+                    builder.assert_eq(e(b + L0), e(b + M0));
+                    builder.assert_eq(e(b + L1), e(b + M1));
+                    builder.assert_eq(e(b + L2), e(b + M2));
+                    builder.assert_eq(e(b + KL2), e(b + KR2));
+
+                    let t_val = e(b + T0) + beta.clone() * e(b + T1);
+                    let a_val = e(b + A0) + beta.clone() * e(b + A1);
+                    let out0 = e(b + O00) + beta.clone() * e(b + O01);
+                    let out1 = e(b + O10) + beta.clone() * e(b + O11);
+                    let m_val = e(b + MC0) + beta.clone() * e(b + MC1);
+                    // add/sub: out0 = a + t, out1 = a − t  (t = ζ·b)
+                    builder.assert_eq(a_val.clone() + t_val.clone(), out0.clone() + e(b + KO0) * q.clone());
+                    builder.assert_eq(a_val.clone() + e(b + KO1) * q.clone(), t_val.clone() + out1.clone());
+                    // ranges
+                    let slack = |lo: usize, hi: usize| -> AB::Expr { e(b + lo) + beta.clone() * e(b + hi) };
+                    builder.assert_eq(t_val + slack(GT0, GT1), qm1.clone());
+                    builder.assert_eq(m_val + slack(GM0, GM1), qm1.clone());
+                    builder.assert_eq(a_val + slack(GA0, GA1), qm1.clone());
+                    builder.assert_eq(out0 + slack(GO00, GO01), qm1.clone());
+                    builder.assert_eq(out1 + slack(GO10, GO11), qm1.clone());
+                }
+
+                // ---- pin each butterfly's twiddle to the canonical ζ (VERBATIM forward schedule) ----
+                // layer1 (k=1): ζ[0]; layer2 (k=2,3): ζ[1],ζ[2]; layer3 (k=4..7): ζ[3..7].
+                let pin = |builder: &mut AB, b: usize, zeta: u64| {
+                    builder.assert_eq(e(b + Z0) + beta.clone() * e(b + Z1), AB::Expr::from_u64(zeta));
+                };
+                pin(builder, BASE[0], self.zetas[0]);
+                pin(builder, BASE[1], self.zetas[0]);
+                pin(builder, BASE[2], self.zetas[0]);
+                pin(builder, BASE[3], self.zetas[0]);
+                pin(builder, BASE[4], self.zetas[1]);
+                pin(builder, BASE[5], self.zetas[1]);
+                pin(builder, BASE[6], self.zetas[2]);
+                pin(builder, BASE[7], self.zetas[2]);
+                pin(builder, BASE[8], self.zetas[3]);
+                pin(builder, BASE[9], self.zetas[4]);
+                pin(builder, BASE[10], self.zetas[5]);
+                pin(builder, BASE[11], self.zetas[6]);
+
+                // ---- CROSS-LAYER WIRING (VERBATIM ntt_wired8): each layer's inputs == prev layer's
+                // outputs. out0=(O00,O01), out1=(O10,O11); inputs a=(A0,A1), b=(B0,B1). ----
+                let wire = |builder: &mut AB, db: usize, d_lo: usize, d_hi: usize, sb: usize, s_lo: usize, s_hi: usize| {
+                    builder.assert_eq(e(db + d_lo), e(sb + s_lo));
+                    builder.assert_eq(e(db + d_hi), e(sb + s_hi));
+                };
+                let (bf0, bf1, bf2, bf3) = (BASE[0], BASE[1], BASE[2], BASE[3]);
+                let (bf4, bf5, bf6, bf7) = (BASE[4], BASE[5], BASE[6], BASE[7]);
+                let (bf8, bf9, bf10, bf11) = (BASE[8], BASE[9], BASE[10], BASE[11]);
+                // layer2 reads layer1 outputs:
+                wire(builder, bf4, A0, A1, bf0, O00, O01);
+                wire(builder, bf4, B0, B1, bf2, O00, O01);
+                wire(builder, bf5, A0, A1, bf1, O00, O01);
+                wire(builder, bf5, B0, B1, bf3, O00, O01);
+                wire(builder, bf6, A0, A1, bf0, O10, O11);
+                wire(builder, bf6, B0, B1, bf2, O10, O11);
+                wire(builder, bf7, A0, A1, bf1, O10, O11);
+                wire(builder, bf7, B0, B1, bf3, O10, O11);
+                // layer3 reads layer2 outputs:
+                wire(builder, bf8, A0, A1, bf4, O00, O01);
+                wire(builder, bf8, B0, B1, bf5, O00, O01);
+                wire(builder, bf9, A0, A1, bf4, O10, O11);
+                wire(builder, bf9, B0, B1, bf5, O10, O11);
+                wire(builder, bf10, A0, A1, bf6, O00, O01);
+                wire(builder, bf10, B0, B1, bf7, O00, O01);
+                wire(builder, bf11, A0, A1, bf6, O10, O11);
+                wire(builder, bf11, B0, B1, bf7, O10, O11);
+
+                // ---- IO binding on the first row: z INPUT and ẑ OUTPUT to the surfaced publics ----
+                let mut wf = builder.when_first_row();
+                for p in 0..NJOIN {
+                    let (ibf, is_b) = in_port(p);
+                    let ib = BASE[ibf];
+                    let (lo, hi) = if is_b { (B0, B1) } else { (A0, A1) };
+                    let v = Into::<AB::Expr>::into(row[ib + lo]) + beta.clone() * Into::<AB::Expr>::into(row[ib + hi]);
+                    wf.assert_eq(v, pis[PI_Z + p].clone());
+                }
+                for p in 0..NJOIN {
+                    let (obf, is_out1) = out_port(p);
+                    let ob = BASE[obf];
+                    let (lo, hi) = if is_out1 { (O10, O11) } else { (O00, O01) };
+                    let v = Into::<AB::Expr>::into(row[ob + lo]) + beta.clone() * Into::<AB::Expr>::into(row[ob + hi]);
+                    wf.assert_eq(v, pis[PI_ZHAT + p].clone());
+                }
+            }
+        }
+
+        fn split(v: u64) -> (u64, u64) {
+            (v % BETA, v / BETA)
+        }
+
+        /// Fill one CT butterfly's 460 columns for (a, b, ζ) → (out0=a+ζb, out1=a−ζb) mod q.
+        /// Returns (out0, out1). VERBATIM from ntt_wired8_air.rs::fill_bf.
+        fn fill_bf<F: PrimeField64>(vals: &mut [F], base: usize, a: u64, b: u64, zeta: u64) -> (u64, u64) {
+            let (z0, z1) = split(zeta);
+            let (b0, b1) = split(b);
+            let prod = (zeta as u128) * (b as u128);
+            let t = (prod % Q as u128) as u64;
+            let m = (prod / Q as u128) as u64;
+            let (m0, m1) = split(m);
+            let (t0, t1) = split(t);
+            let s0 = z0 * b0;
+            let (l0, kl0) = (s0 % BETA, s0 / BETA);
+            let s1 = z0 * b1 + z1 * b0 + kl0;
+            let (l1, kl1) = (s1 % BETA, s1 / BETA);
+            let s2 = z1 * b1 + kl1;
+            let (l2, kl2) = (s2 % BETA, s2 / BETA);
+            let u0 = m0 + t0;
+            let (mm0, kr0) = (u0 % BETA, u0 / BETA);
+            let u1 = m0 * Q1 + m1 + t1 + kr0;
+            let (mm1, kr1) = (u1 % BETA, u1 / BETA);
+            let u2 = m1 * Q1 + kr1;
+            let (mm2, kr2) = (u2 % BETA, u2 / BETA);
+            assert_eq!((l0, l1, l2, kl2), (mm0, mm1, mm2, kr2), "limb mismatch");
+            let sum = a + t;
+            let ko0 = if sum >= Q { 1u64 } else { 0 };
+            let out0 = sum - ko0 * Q;
+            let ko1 = if a >= t { 0u64 } else { 1 };
+            let out1 = a + ko1 * Q - t;
+            assert!(out0 < Q && out1 < Q);
+            let (a0, a1) = split(a);
+            let (o00, o01) = split(out0);
+            let (o10, o11) = split(out1);
+            let (gt0, gt1) = split((Q - 1) - t);
+            let (gm0, gm1) = split((Q - 1) - m);
+            let (ga0, ga1) = split((Q - 1) - a);
+            let (go00, go01) = split((Q - 1) - out0);
+            let (go10, go11) = split((Q - 1) - out1);
+            let prim = [
+                (Z0, z0), (Z1, z1), (B0, b0), (B1, b1), (MC0, m0), (MC1, m1), (T0, t0), (T1, t1),
+                (KL0, kl0), (KL1, kl1), (KL2, kl2), (KR0, kr0), (KR1, kr1), (KR2, kr2),
+                (L0, l0), (L1, l1), (L2, l2), (M0, mm0), (M1, mm1), (M2, mm2),
+                (GT0, gt0), (GT1, gt1), (GM0, gm0), (GM1, gm1),
+                (A0, a0), (A1, a1), (O00, o00), (O01, o01), (O10, o10), (O11, o11),
+                (KO0, ko0), (KO1, ko1),
+                (GA0, ga0), (GA1, ga1), (GO00, go00), (GO01, go01), (GO10, go10), (GO11, go11),
+            ];
+            for (col, v) in prim {
+                vals[base + col] = F::from_u64(v);
+                let bo = base + bit_off(col);
+                for j in 0..WIDTHS[col] {
+                    vals[bo + j] = F::from_u64((v >> j) & 1);
+                }
+            }
+            (out0, out1)
+        }
+
+        /// Fill the full-height trace: every row holds the complete forward n=8 CT NTT (12 butterflies,
+        /// threaded in-place exactly as ntt_wired8_air.rs). Returns the trace and the NTT-domain output
+        /// ẑ (natural position order = the in-place array after layer3).
+        pub fn generate<F: PrimeField64>(z_in: &[u64; NJOIN], zetas: &[u64; 7]) -> (RowMajorMatrix<F>, [u64; NJOIN]) {
+            let h = height();
+            let mut vals = F::zero_vec(h * NUM_COLS);
+            let mut zhat_out = [0u64; NJOIN];
+            for r in 0..h {
+                let o = r * NUM_COLS;
+                let seg = &mut vals[o..o + NUM_COLS];
+                let mut a = *z_in;
+                let mut bf = 0usize;
+                let mut k = 0usize;
+                let mut len = 4;
+                while len >= 1 {
+                    let mut start = 0;
+                    while start < 8 {
+                        k += 1;
+                        let zeta = zetas[k - 1];
+                        for j in start..start + len {
+                            let (o0, o1) = fill_bf(seg, BASE[bf], a[j], a[j + len], zeta);
+                            a[j] = o0;
+                            a[j + len] = o1;
+                            bf += 1;
+                        }
+                        start += 2 * len;
+                    }
+                    if len == 1 {
+                        break;
+                    }
+                    len /= 2;
+                }
+                // a[] now holds ẑ in natural position order (the in-place CT output = the reference ntt8).
+                zhat_out = a;
+            }
+            (RowMajorMatrix::new(vals, NUM_COLS), zhat_out)
+        }
+
+        pub fn build_pis<F: PrimeField64>(z_in: &[u64; NJOIN], zhat_out: &[u64; NJOIN]) -> Vec<F> {
+            z_in.iter().chain(zhat_out.iter()).map(|&v| F::from_u64(v)).collect()
+        }
+
+        // ---- reference oracles (VERBATIM ntt8 / schoolbook8 from ntt_wired8_air.rs, + a GS inverse
+        // for the round-trip gate) ----
+        fn modpow(base: u64, mut e: u64) -> u64 {
+            let mut r = 1u128;
+            let mut b = base as u128 % Q as u128;
+            while e > 0 {
+                if e & 1 == 1 {
+                    r = r * b % Q as u128;
+                }
+                b = b * b % Q as u128;
+                e >>= 1;
+            }
+            r as u64
+        }
+
+        /// Canonical n=8 twiddles ζ[k] (k=1..7): ζ[k]=ψ^brv3(k), ψ=1753^32 (a primitive 16th root,
+        /// ψ⁸ = −1) — the exact n=8 reduction of the Dilithium forward-NTT twiddle table.
+        pub fn params() -> [u64; 7] {
+            let psi = modpow(1753, 32);
+            let brv3 = |x: u64| -> u64 { ((x & 1) << 2) | (x & 2) | ((x >> 2) & 1) };
+            std::array::from_fn(|i| modpow(psi, brv3((i + 1) as u64)))
+        }
+
+        /// forward n=8 NTT (the exact schedule the AIR wires) → the NTT-domain array.
+        pub fn ntt8(x: &[u64; 8], z: &[u64; 7]) -> [u64; 8] {
+            let mut a = *x;
+            let mut k = 0usize;
+            let mut len = 4;
+            while len >= 1 {
+                let mut start = 0;
+                while start < 8 {
+                    k += 1;
+                    let zeta = z[k - 1];
+                    for j in start..start + len {
+                        let t = ((zeta as u128 * a[j + len] as u128) % Q as u128) as u64;
+                        a[j + len] = (a[j] + Q - t) % Q;
+                        a[j] = (a[j] + t) % Q;
+                    }
+                    start += 2 * len;
+                }
+                if len == 1 {
+                    break;
+                }
+                len /= 2;
+            }
+            a
+        }
+
+        /// Independent schoolbook negacyclic product `f · g mod (x⁸ + 1)` — the ground truth.
+        pub fn schoolbook8(f: &[u64; 8], g: &[u64; 8]) -> [u64; 8] {
+            let mut c = [0u128; 8];
+            for i in 0..8 {
+                for j in 0..8 {
+                    let p = (f[i] as u128) * (g[j] as u128);
+                    let k = i + j;
+                    if k < 8 {
+                        c[k] = (c[k] + p) % Q as u128;
+                    } else {
+                        c[k - 8] = (c[k - 8] + Q as u128 - (p % Q as u128)) % Q as u128; // x^8 = −1
+                    }
+                }
+            }
+            std::array::from_fn(|i| c[i] as u64)
+        }
+
+        /// reference GS inverse WITH the n⁻¹ normalization — for the round-trip gate invNTT(NTT(x))==x.
+        pub fn invntt8_scaled(input: &[u64; 8], z: &[u64; 7]) -> [u64; 8] {
+            let ninv = modpow(8, Q - 2);
+            let mut a = *input;
+            let mut k = 7usize;
+            let mut len = 1;
+            while len < 8 {
+                let mut start = 0;
+                while start < 8 {
+                    k -= 1;
+                    let zeta = z[k];
+                    for j in start..start + len {
+                        let aa = a[j];
+                        let bb = a[j + len];
+                        a[j] = (aa + bb) % Q;
+                        let d = (bb + Q - aa) % Q;
+                        a[j + len] = ((zeta as u128 * d as u128) % Q as u128) as u64;
+                    }
+                    start += 2 * len;
+                }
+                len *= 2;
+            }
+            std::array::from_fn(|i| ((a[i] as u128 * ninv as u128) % Q as u128) as u64)
+        }
+    }
+    // =======================================================================================
+    // LEG P — pkDecode t1 (the PUBLIC-KEY-PARSE front stage). FIPS-204 SimpleBitPack 10-bit unpack,
+    // ported VERBATIM from pkdecode_t1_air.rs: one group = 4 coefficients (each t1ₖ ∈ [0, 2¹⁰))
+    // unpacked from 5 packed bytes via 40 shared bits regrouped 10-bit-per-coeff vs 8-bit-per-byte.
+    // NG=2 groups are unrolled per row → 8 t1 coefficients (= the n=8 NTT width). Exposes the
+    // unpacked t1 OUTPUT publics [0..8]; a wrong-endianness / off-by-a-bit unpack is rejected.
+    // =======================================================================================
+    pub mod pkd {
+        use super::*;
+
+        pub const NG: usize = 2; // groups unrolled per row
+        const NC1: usize = 4; // coefficients per group
+        const NBY: usize = 5; // packed bytes per group
+        const NBITS: usize = 40; // 4 coeffs × 10 bits = 5 bytes × 8 bits
+        pub const NT1: usize = NG * NC1; // 8 unpacked t1 coefficients (= NJOIN)
+
+        // ---- per-group relative column layout (VERBATIM pkdecode_t1_air.rs) ----
+        const GC: usize = 0; // c[0..4]
+        const GBY: usize = NC1; // byte[0..5]
+        const GNP: usize = NC1 + NBY; // 9
+        const GBITS: usize = GNP; // 40 shared bits start here
+        const GROUP_COLS: usize = GNP + NBITS; // 49
+        pub const NUM_COLS_PKD: usize = NG * GROUP_COLS; // 98
+
+        // ---- public values: t1 OUTPUT [0..8] ----
+        pub const PI_T1_OUT: usize = 0;
+        pub const NUM_PIS_PKD: usize = NT1;
+
+        pub fn height() -> usize {
+            64 // ≥ 2^6 FRI foldability floor; every row carries the same NG-group unpack
+        }
+        pub fn num_pis() -> usize {
+            NUM_PIS_PKD
+        }
+
+        #[derive(Clone)]
+        pub struct PkDecodeAir {}
+
+        impl<F: PrimeField64> BaseAir<F> for PkDecodeAir {
+            fn width(&self) -> usize {
+                NUM_COLS_PKD
+            }
+            fn num_public_values(&self) -> usize {
+                num_pis()
+            }
+            fn max_constraint_degree(&self) -> Option<usize> {
+                Some(2)
+            }
+        }
+
+        impl<AB: AirBuilder> Air<AB> for PkDecodeAir
+        where
+            AB::F: PrimeField64,
+        {
+            fn eval(&self, builder: &mut AB) {
+                let one = AB::Expr::ONE;
+                let pis: Vec<AB::Expr> =
+                    (0..num_pis()).map(|k| builder.public_values()[k].into()).collect();
+                let main = builder.main();
+                let row = main.current_slice();
+                let e = |i: usize| -> AB::Expr { row[i].into() };
+
+                for g in 0..NG {
+                    let b = g * GROUP_COLS;
+                    // boolean-check every shared bit.
+                    for bit in 0..NBITS {
+                        let x: AB::Expr = row[b + GBITS + bit].into();
+                        builder.assert_zero(x.clone() * (x - one.clone()));
+                    }
+                    // each coefficient is a 10-bit grouping of the shared bits (bits [10k, 10k+10)).
+                    for k in 0..NC1 {
+                        let mut acc = AB::Expr::ZERO;
+                        let mut w = AB::Expr::ONE;
+                        for i in 0..10 {
+                            let x: AB::Expr = row[b + GBITS + 10 * k + i].into();
+                            acc = acc + x * w.clone();
+                            w = w.clone() + w.clone();
+                        }
+                        builder.assert_eq(e(b + GC + k), acc);
+                    }
+                    // each byte is an 8-bit grouping of the SAME shared bits (bits [8j, 8j+8)).
+                    for j in 0..NBY {
+                        let mut acc = AB::Expr::ZERO;
+                        let mut w = AB::Expr::ONE;
+                        for i in 0..8 {
+                            let x: AB::Expr = row[b + GBITS + 8 * j + i].into();
+                            acc = acc + x * w.clone();
+                            w = w.clone() + w.clone();
+                        }
+                        builder.assert_eq(e(b + GBY + j), acc);
+                    }
+                }
+
+                // ---- IO binding on the first row: the 8 unpacked coefficients to the surfaced publics ----
+                let mut wf = builder.when_first_row();
+                for g in 0..NG {
+                    let b = g * GROUP_COLS;
+                    for k in 0..NC1 {
+                        wf.assert_eq(
+                            Into::<AB::Expr>::into(row[b + GC + k]),
+                            pis[PI_T1_OUT + g * NC1 + k].clone(),
+                        );
+                    }
+                }
+            }
+        }
+
+        /// Reference SimpleBitPack unpack: 5 bytes → 4 ten-bit coefficients (VERBATIM pkdecode_t1_air.rs).
+        pub fn unpack10(bytes: &[u8; 5]) -> [u16; 4] {
+            let mut v: u64 = 0;
+            for (j, &b) in bytes.iter().enumerate() {
+                v |= (b as u64) << (8 * j);
+            }
+            core::array::from_fn(|k| ((v >> (10 * k)) & 0x3FF) as u16)
+        }
+
+        /// Fill the full-height trace: every row holds the NG-group unpack. Returns the trace and the
+        /// 8 unpacked t1 coefficients (each in [0, 2^10)).
+        pub fn generate<F: PrimeField64>(groups: &[[u8; 5]; NG]) -> (RowMajorMatrix<F>, [u64; NT1]) {
+            let mut rowvals = F::zero_vec(NUM_COLS_PKD);
+            let mut t1 = [0u64; NT1];
+            for g in 0..NG {
+                let b = g * GROUP_COLS;
+                let bytes = &groups[g];
+                let mut v: u64 = 0;
+                for (j, &by) in bytes.iter().enumerate() {
+                    v |= (by as u64) << (8 * j);
+                }
+                let coeffs = unpack10(bytes);
+                for k in 0..NC1 {
+                    rowvals[b + GC + k] = F::from_u64(coeffs[k] as u64);
+                    t1[g * NC1 + k] = coeffs[k] as u64;
+                }
+                for j in 0..NBY {
+                    rowvals[b + GBY + j] = F::from_u64(bytes[j] as u64);
+                }
+                for bit in 0..NBITS {
+                    rowvals[b + GBITS + bit] = F::from_u64((v >> bit) & 1);
+                }
+            }
+            let h = height();
+            let mut vals = F::zero_vec(h * NUM_COLS_PKD);
+            for r in 0..h {
+                vals[r * NUM_COLS_PKD..(r + 1) * NUM_COLS_PKD].copy_from_slice(&rowvals);
+            }
+            (RowMajorMatrix::new(vals, NUM_COLS_PKD), t1)
+        }
+
+        pub fn build_pis<F: PrimeField64>(t1: &[u64; NT1]) -> Vec<F> {
+            t1.iter().map(|&v| F::from_u64(v)).collect()
+        }
+    }
+
+    // =======================================================================================
+    // Native batch-STARK leg provers (single-instance batch proofs)
+    // =======================================================================================
+    type LegProof = (
+        BatchProof<ConfigWithFriParams>,
+        ProverData<ConfigWithFriParams>,
+        Vec<F>,
+    );
+
+    /// Prove Leg F (forward NTT front) over the coefficient-domain input; return (proof, ..., publics)
+    /// and the NTT-domain output.
+    fn prove_ntt_leg(
+        config: &ConfigWithFriParams,
+        air: &ntt::NttAir,
+        z_in: &[u64; NJOIN],
+    ) -> (LegProof, [u64; NJOIN]) {
+        let (trace, zhat_out) = ntt::generate::<F>(z_in, &air.zetas);
+        let pis = ntt::build_pis::<F>(z_in, &zhat_out);
+        let instances = vec![StarkInstance { air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .expect("native Leg F batch verify failed");
+        ((proof, pd, pis), zhat_out)
+    }
+
+    /// Whether Leg F over a trace with a TAMPERED butterfly output is REJECTED by native verify.
+    fn ntt_tamper_rejects(config: &ConfigWithFriParams, air: &ntt::NttAir, z_in: &[u64; NJOIN]) -> bool {
+        let (mut trace, zhat_out) = ntt::generate::<F>(z_in, &air.zetas);
+        let a0 = 8 * 460 + 24; // bf8 base = 8 * 460; A0 = column 24
+        trace.values[a0] += F::ONE;
+        let pis = ntt::build_pis::<F>(z_in, &zhat_out);
+        let instances = vec![StarkInstance { air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .is_err()
+    }
+
+    /// Prove Leg P (pkDecode t1 unpack) over NG packed groups; return (proof, ..., publics) and the
+    /// 8 unpacked t1 coefficients.
+    fn prove_pkd_leg(
+        config: &ConfigWithFriParams,
+        groups: &[[u8; 5]; pkd::NG],
+    ) -> (LegProof, [u64; pkd::NT1]) {
+        let air = pkd::PkDecodeAir {};
+        let (trace, t1) = pkd::generate::<F>(groups);
+        let pis = pkd::build_pis::<F>(&t1);
+        let instances = vec![StarkInstance { air: &air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(&air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .expect("native Leg P batch verify failed");
+        ((proof, pd, pis), t1)
+    }
+
+    /// NEG-UNPACK: tamper coefficient 0 — its 10-bit grouping no longer matches the packed bytes →
+    /// native Leg P verify REJECTS (a wrong-endianness / off-by-a-bit unpack is caught).
+    fn pkd_tamper_rejects(config: &ConfigWithFriParams, groups: &[[u8; 5]; pkd::NG]) -> bool {
+        let air = pkd::PkDecodeAir {};
+        let (mut trace, t1) = pkd::generate::<F>(groups);
+        trace.values[0] += F::ONE; // group-0 coefficient 0 (column 0) — desync from its 10-bit grouping
+        let pis = pkd::build_pis::<F>(&t1);
+        let instances = vec![StarkInstance { air: &air, trace: &trace, public_values: pis.clone() }];
+        let pd = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &pd);
+        verify_batch(config, core::slice::from_ref(&air), &proof, core::slice::from_ref(&pis), &pd.common)
+            .is_err()
+    }
+
+    // =======================================================================================
+    // TWO-stage outer recursion: verify Leg P (pkDecode t1) + Leg F (forward NTT) in ONE circuit,
+    // bind the ONE cross-stage tie (P↔F: t1 OUTPUT == t1 INPUT), produce ONE outer proof = the
+    // pk-parse front stage joined into the forward NTT that transforms t1.
+    // =======================================================================================
+    #[allow(clippy::too_many_arguments)]
+    fn build_and_prove_outer2_pkd(
+        config: &ConfigWithFriParams,
+        fvp: &FriVerifierParams,
+        fri_params: &FriParams,
+        air_p: &pkd::PkDecodeAir,
+        leg_p: &LegProof,
+        air_f: &ntt::NttAir,
+        leg_f: &LegProof,
+        do_connect: bool,
+    ) -> Result<(usize, u32), String> {
+        let (proof_p, pd_p, pub_p) = leg_p;
+        let (proof_f, pd_f, pub_f) = leg_f;
+        let perm = p3_koala_bear::default_koalabear_poseidon2_16();
+        let mut cb = CircuitBuilder::new();
+        cb.enable_poseidon2_perm::<p3_poseidon2_circuit_air::KoalaBearD4Width16, _>(
+            generate_poseidon2_trace::<Challenge, p3_poseidon2_circuit_air::KoalaBearD4Width16>,
+            perm,
+        );
+        cb.enable_recompose::<F>(generate_recompose_trace::<F, Challenge>);
+        let lookup_gadget = LogUpGadget::new();
+
+        macro_rules! verify_leg {
+            ($proof:expr, $pd:expr, $pub:expr, $air:expr, $what:literal) => {{
+                let vi = BatchStarkVerifierInputsBuilder::<
+                    ConfigWithFriParams,
+                    MerkleCapTargets<F, DIGEST_ELEMS>,
+                    InnerFri,
+                >::allocate(&mut cb, $proof, &$pd.common, &[$pub.len()]);
+                let op_ids = verify_batch_circuit::<_, _, _, _, _, _, _, WIDTH, RATE>(
+                    config,
+                    core::slice::from_ref($air),
+                    &mut cb,
+                    &vi.proof_targets,
+                    &vi.air_public_targets,
+                    fvp,
+                    &vi.common_data,
+                    &lookup_gadget,
+                    Poseidon2Config::KOALA_BEAR_D4_W16,
+                )
+                .map_err(|e| format!("build {} verify circuit: {e:?}", $what))?;
+                (vi, op_ids)
+            }};
+        }
+
+        let (vi_p, op_ids_p) = verify_leg!(proof_p, pd_p, pub_p, air_p, "Leg P");
+        let (vi_f, op_ids_f) = verify_leg!(proof_f, pd_f, pub_f, air_f, "Leg F");
+
+        // ---- the ONE cross-stage tie (an ALU sub asserted zero — each public read once) ----
+        // Tie (P↔F): Leg-P t1[k] (OUTPUT, PI_T1_OUT) == Leg-F t1_in[k] (INPUT, ntt::PI_Z) for k in 0..8.
+        if do_connect {
+            for k in 0..pkd::NT1 {
+                let diff = cb.sub(
+                    vi_p.air_public_targets[0][pkd::PI_T1_OUT + k],
+                    vi_f.air_public_targets[0][ntt::PI_Z + k],
+                );
+                cb.assert_zero(diff);
+            }
+        }
+
+        let vc = cb.build().map_err(|e| format!("outer circuit build: {e:?}"))?;
+        let witness_count = vc.witness_count;
+        println!("  recursion circuit (2-leg P∘F): witness_count={witness_count}, connect={do_connect}");
+
+        // Pack public/private inputs in allocation order (P, F).
+        let (pub_in_p, priv_in_p) = vi_p.pack_values(core::slice::from_ref(pub_p), proof_p, &pd_p.common);
+        let (pub_in_f, priv_in_f) = vi_f.pack_values(core::slice::from_ref(pub_f), proof_f, &pd_f.common);
+        let mut public_inputs = pub_in_p;
+        public_inputs.extend(pub_in_f);
+        let mut private_inputs = priv_in_p;
+        private_inputs.extend(priv_in_f);
+
+        let mut runner = vc.runner();
+        runner.set_public_inputs(&public_inputs).map_err(|e| format!("set publics: {e:?}"))?;
+        runner.set_private_inputs(&private_inputs).map_err(|e| format!("set privates: {e:?}"))?;
+        for (op_ids, proof) in [(&op_ids_p, proof_p), (&op_ids_f, proof_f)] {
+            set_fri_mmcs_private_data::<F, Challenge, ChallengeMmcs, MyMmcs, MyHash, MyCompress, DIGEST_ELEMS>(
+                &mut runner,
+                op_ids,
+                &proof.opening_proof,
+                Poseidon2Config::KOALA_BEAR_D4_W16,
+            )
+            .map_err(|e| format!("mmcs private data: {e}"))?;
+        }
+
+        // NEGATIVE case fails HERE (aliased cross-stage public with a conflicting value).
+        let traces = runner.run().map_err(|e| format!("recursion circuit run rejected: {e:?}"))?;
+
+        // ---- Prove the outer (aggregated) proof ----
+        let l1_packing = TablePacking::new(1, 2)
+            .with_fri_params(fri_params.log_final_poly_len, fri_params.log_blowup);
+        let npo_prep: Vec<Box<dyn NpoPreprocessor<F>>> =
+            vec![Box::new(Poseidon2Preprocessor), Box::new(RecomposePreprocessor::default())];
+        let mut air_builders = poseidon2_air_builders::<ConfigWithFriParams, D>();
+        air_builders.extend(recompose_air_builders::<ConfigWithFriParams, D>(1, false));
+        let (airs_degrees, prim_cols, non_prim_cols) =
+            get_airs_and_degrees_with_prep::<ConfigWithFriParams, Challenge, D>(
+                &vc,
+                &l1_packing,
+                &npo_prep,
+                &air_builders,
+                ConstraintProfile::Standard,
+            )
+            .map_err(|e| format!("outer airs/degrees: {e:?}"))?;
+        let (airs, degrees): (Vec<_>, Vec<usize>) = airs_degrees.into_iter().unzip();
+        let prover_data = ProverData::from_airs_and_degrees(config, &airs, &degrees);
+        let cpd = CircuitProverData::new(prover_data, prim_cols, non_prim_cols);
+        let mut prover = BatchStarkProver::new(config.clone())
+            .with_table_packing(l1_packing)
+            .with_alu_variant(AirVariant::Baseline);
+        prover.register_poseidon2_table::<D>(Poseidon2Config::KOALA_BEAR_D4_W16);
+        prover.register_recompose_table::<D>(false);
+        let proof = prover.prove_all_tables(&traces, &cpd).map_err(|e| format!("prove outer: {e:?}"))?;
+        prover.verify_all_tables::<Challenge>(&proof).map_err(|e| format!("verify outer: {e:?}"))?;
+        let bytes = postcard::to_allocvec(&proof).map_err(|e| format!("serialize outer: {e:?}"))?.len();
+        Ok((bytes, witness_count))
+    }
+
+    pub fn run() {
+        let fri_params = FriParams {
+            log_blowup: 2,
+            max_log_arity: 2,
+            cap_height: 0,
+            log_final_poly_len: 5,
+            commit_pow_bits: 0,
+            query_pow_bits: 15,
+        };
+        let config = config_with_fri_params(&fri_params, SECURITY, false);
+        let fvp = create_fri_verifier_params(&fri_params, SECURITY);
+
+        let zetas8 = ntt::params();
+        let air_f = ntt::NttAir { zetas: zetas8 };
+        let air_p = pkd::PkDecodeAir {};
+
+        info!(
+            "pkDecode JOIN: Leg P (pkDecode t1 10-bit unpack, NG={} groups, {}×{}, {} pubs), Leg F \
+             (forward NTT n=8 {}×{}, {} pubs); NJOIN={NJOIN}, security={SECURITY}",
+            pkd::NG, pkd::NUM_COLS_PKD, pkd::height(), pkd::num_pis(),
+            ntt::NUM_COLS, ntt::height(), ntt::num_pis(),
+        );
+
+        // ============ GATE 0: forward-NTT gadget correctness — the ntt_zq oracle at n=8 ============
+        {
+            let mut s = 0x9151_C0DE_2718_2818u64;
+            let mut nextq = || {
+                s = s.wrapping_add(0x9E3779B97F4A7C15);
+                let mut z = s;
+                z = (z ^ (z >> 30)).wrapping_mul(0xBF58476D1CE4E5B9);
+                z = (z ^ (z >> 27)).wrapping_mul(0x94D049BB133111EB);
+                (z ^ (z >> 31)) % Q
+            };
+            for _ in 0..200 {
+                let f: [u64; NJOIN] = std::array::from_fn(|_| nextq());
+                let g: [u64; NJOIN] = std::array::from_fn(|_| nextq());
+                let nf = ntt::ntt8(&f, &zetas8);
+                let ng = ntt::ntt8(&g, &zetas8);
+                let nc = ntt::ntt8(&ntt::schoolbook8(&f, &g), &zetas8);
+                for i in 0..NJOIN {
+                    let prod = ((nf[i] as u128 * ng[i] as u128) % Q as u128) as u64;
+                    assert_eq!(prod, nc[i], "convolution theorem failed at {i}");
+                }
+                assert_eq!(ntt::invntt8_scaled(&nf, &zetas8), f, "invNTT(NTT(x)) must recover x");
+            }
+        }
+        println!(
+            "GATE 0 ok — forward NTT gadget: convolution theorem + round-trip, coefficient-exact over \
+             200 random (f,g) — the ntt_zq oracle at n=8."
+        );
+
+        // ============ representative packed t1 bytes (2 groups = 10 bytes = 8 coeffs) ============
+        // A pk is ρ(32B) ‖ t1(packed 10-bit); these are a representative packed-t1 slice — every 5-byte
+        // group is a valid SimpleBitPack encoding of 4 coefficients in [0, 2^10). (Deterministic; the
+        // recursion clone has no libcrux dep to extract a specific key's bytes — see caveats.)
+        let groups: [[u8; 5]; pkd::NG] = core::array::from_fn(|g| {
+            core::array::from_fn(|j| {
+                (g as u32 * 37 + j as u32 * 91 + g as u32 * 5 + 17).wrapping_mul(2654435761) as u8
+            })
+        });
+        let t1_ref: [u64; pkd::NT1] = {
+            let mut v = [0u64; pkd::NT1];
+            for g in 0..pkd::NG {
+                let c = pkd::unpack10(&groups[g]);
+                for k in 0..4 {
+                    v[g * 4 + k] = c[k] as u64;
+                }
+            }
+            v
+        };
+        for &c in &t1_ref {
+            assert!(c < 1024, "t1 coefficient must be a 10-bit value");
+        }
+
+        // ============ Leg P: the pkDecode t1 unpack front stage ============
+        let t = Instant::now();
+        let (leg_p, t1) = prove_pkd_leg(&config, &groups);
+        // GATE 1: Leg P output t1 == reference SimpleBitPack unpack, coefficient-exact.
+        assert_eq!(t1, t1_ref, "Leg P t1 != reference unpack10");
+        for k in 0..pkd::NT1 {
+            assert_eq!(leg_p.2[pkd::PI_T1_OUT + k], F::from_u64(t1[k]), "Leg P public t1[{k}]");
+        }
+        println!(
+            "Leg P (pkDecode t1 front) batch proof: {} bytes, {} pubs, {} cols × {} rows, t1 == reference \
+             SimpleBitPack unpack exact (8 coeffs in [0,2^10)), {:.1?}",
+            postcard::to_allocvec(&leg_p.0).unwrap().len(), leg_p.2.len(), pkd::NUM_COLS_PKD, pkd::height(),
+            t.elapsed()
+        );
+
+        // ============ Leg F: t̂1 = NTT(t1) over the pkDecode output (first n=8 slice = REAL t1) =======
+        let t1_8: [u64; NJOIN] = t1;
+        let t1hat_ref = ntt::ntt8(&t1_8, &zetas8);
+        let t = Instant::now();
+        let (leg_f, t1hat8) = prove_ntt_leg(&config, &air_f, &t1_8);
+        assert_eq!(t1hat8, t1hat_ref, "Leg F t̂1 != reference NTT(t1)");
+        for k in 0..NJOIN {
+            assert_eq!(leg_f.2[ntt::PI_Z + k], F::from_u64(t1_8[k]), "Leg F public t1_in[{k}]");
+            assert_eq!(leg_f.2[ntt::PI_ZHAT + k], F::from_u64(t1hat8[k]), "Leg F public t̂1_out[{k}]");
+        }
+        println!(
+            "Leg F (forward NTT front) batch proof: {} bytes, {} pubs, t̂1 == NTT(t1) exact, {:.1?}",
+            postcard::to_allocvec(&leg_f.0).unwrap().len(), leg_f.2.len(), t.elapsed()
+        );
+
+        // ============ [1] HONEST: P∘F — the tie → the NTT's t1 is the REAL pkDecode output ==========
+        let t = Instant::now();
+        let (bytes, wc) = build_and_prove_outer2_pkd(
+            &config, &fvp, &fri_params, &air_p, &leg_p, &air_f, &leg_f, true,
+        )
+        .expect("HONEST pkDecode→NTT join must succeed");
+        println!(
+            "[1] HONEST  (pk bytes →pkDecode→ t1 →forwardNTT→ t̂1, Tie P↔F): outer proof OK = the pk-parse \
+             front stage is recursion-composed and BOUND into the forward NTT (t1 = REAL pkDecode unpack), \
+             {bytes} bytes, witness_count={wc}, {:.1?}",
+            t.elapsed()
+        );
+
+        // ============ [2] NEG-UNPACK (tamper a coefficient → grouping mismatch) → native REJECT ======
+        let neg_unpack = pkd_tamper_rejects(&config, &groups);
+        assert!(neg_unpack, "NEG-UNPACK: a coefficient inconsistent with its packed bytes must be REJECTED");
+        println!(
+            "[2] NEG-UNPACK (coeff-0 tampered off its 10-bit grouping): Leg P batch proof REJECTED at \
+             native verify = the SimpleBitPack unpack genuinely gates (wrong-endianness / off-by-a-bit)."
+        );
+
+        // ============ [3] NEG-TIE (NTT fed a t1 != pkDecode's t1) → Tie P↔F fails → REJECT ===========
+        let mut t1_bad = t1_8;
+        t1_bad[0] = (t1_8[0] + 1) % Q; // a different valid residue for the NTT's t1-input[0]
+        assert_ne!(t1_bad[0], t1_8[0]);
+        let (leg_f_bad, _t1hat_bad) = prove_ntt_leg(&config, &air_f, &t1_bad);
+        let t = Instant::now();
+        match build_and_prove_outer2_pkd(
+            &config, &fvp, &fri_params, &air_p, &leg_p, &air_f, &leg_f_bad, true,
+        ) {
+            Err(e) => println!(
+                "[3] NEG-TIE (NTT t1_in[0] != pkDecode t1[0]; Tie P↔F): REJECTED at prove, {:.1?} -- {e}",
+                t.elapsed()
+            ),
+            Ok(_) => panic!("NEG-TIE must NOT produce an outer proof"),
+        }
+
+        // sanity: the shared NTT leg gadget still gates on its own tamper (cross-check).
+        assert!(ntt_tamper_rejects(&config, &air_f, &t1_8), "NTT leg tamper must reject");
+
+        println!(
+            "PKDECODE JOIN demonstrated: pk bytes →pkDecode t1 →forward NTT→ t̂1 composed as ONE \
+             recursion tree over TWO HETEROGENEOUS gadgets (PkDecodeAir ∘ NttAir) — the public-key \
+             parse (FIPS-204 SimpleBitPack 10-bit unpack, NG=2 groups → 8 coeffs) landed as a real \
+             batch-STARK leg, diff-tested == reference unpack, and the cross-stage tie (t1 P↔F) PROVEN \
+             in-circuit — the forward NTT's t1 is now the REAL pkDecode output. This is the 2-stage \
+             front sub-chain t1 = pkDecode(pk) → t̂1 = NTT(t1)."
+        );
+    }
+}
