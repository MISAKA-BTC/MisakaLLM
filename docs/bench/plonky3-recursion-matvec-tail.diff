+                // ---- diagonal reads (factored one-hot): banks + publics -----------------------
+                // The placed bank feeds the az b-input DIRECTLY (the reference bank→mult wire);
+                // ẑ/t̂1/ĉ are pinned to INPUT publics and ŵ_i = out_val to the OUTPUT public.
+                for a in 0..CHI_M {
+                    let fa: AB::Expr = prep[PF_CHI + a].into();
+                    for b in 0..CLO_M {
+                        let fb: AB::Expr = prep[PF_CLO + b].into();
+                        let g = fa.clone() * fb;
+                        let k = a * CLO_M + b;
+                        for j in 0..LDIM_M {
+                            // mult b-input == the PLACED bank coefficient (the sampling→mult wire)
+                            builder.assert_zero(
+                                g.clone()
+                                    * (mgv(MG_AZ0 + j * MG_COLS, MG_B0, MG_B1)
+                                        - Into::<AB::Expr>::into(row[BANK + j * NM + k])),
+                            );
+                            // mult ζ-input == ẑ[j][k] public
+                            builder.assert_zero(
+                                g.clone() * (mgv(MG_AZ0 + j * MG_COLS, MG_Z0, MG_Z1) - pis[PI_Z_M + j * NM + k].clone()),
+                            );
+                        }
+                        builder.assert_zero(g.clone() * (mgv(MG_T1S, MG_B0, MG_B1) - pis[PI_T1_M + k].clone()));
+                        builder.assert_zero(g.clone() * (mgv(MG_PSUB, MG_Z0, MG_Z1) - pis[PI_C_M + k].clone()));
+                        builder.assert_zero(g * (out_val.clone() - pis[PI_OUT_M + k].clone()));
+                    }
+                }
+            }
+        }
+
+        // ---- trace generation (verbatim structure; reduced counts) ----
+        /// Fill the candidate gadget for a 24-bit value with counter state (verbatim, N=NM).
+        /// Returns place.
+        fn fill_cand<F: PrimeField64>(vals: &mut [F], base: usize, v: u64, cnt: usize) -> bool {
+            assert!(v < TWO24);
+            let t = v & 0x7F_FFFF;
+            let lt = if t < Q { 1u64 } else { 0 };
+            let diff = t + lt * TWO24 - Q;
+            for j in 0..24 {
+                vals[base + CIN + j] = F::from_u64((v >> j) & 1);
+                vals[base + CDIFFB + j] = F::from_u64((diff >> j) & 1);
+            }
+            vals[base + CT] = F::from_u64(t);
+            vals[base + CLT] = F::from_u64(lt);
+            vals[base + CDIFF] = F::from_u64(diff);
+            let u = (NM - cnt) as u64;
+            let act = if u != 0 { 1u64 } else { 0 };
+            let place = lt == 1 && act == 1;
+            vals[base + CCNT] = F::from_u64(cnt as u64);
+            vals[base + CU] = F::from_u64(u);
+            for j in 0..9 {
+                vals[base + CUB + j] = F::from_u64((u >> j) & 1);
+            }
+            vals[base + CINVU] = if u != 0 { F::from_u64(u).inverse() } else { F::ZERO };
+            vals[base + CACT] = F::from_u64(act);
+            vals[base + CPLACE] = F::from_u64(place as u64);
+            if place {
+                vals[base + CSEL + cnt] = F::ONE;
+            }
+            place
+        }
+
+        /// Valid zero fill of the candidate gadget (readout + padding rows): v=0 ⇒ t=0<q ⇒ lt=1,
+        /// diff=2^24−q; cnt=u=act=place=0 (the f_cand/f_step/... gates are off on these rows).
+        fn fill_cand_zero<F: PrimeField64>(vals: &mut [F], base: usize) {
+            let diff = TWO24 - Q;
+            for j in 0..24 {
+                vals[base + CDIFFB + j] = F::from_u64((diff >> j) & 1);
+            }
+            vals[base + CLT] = F::ONE;
+            vals[base + CDIFF] = F::from_u64(diff);
+        }
+
+        fn split(v: u64) -> (u64, u64) {
+            (v % BETA, v / BETA)
+        }
+
+        /// Fill one mod-q mult gadget (VERBATIM arithmetic from ntt_mul_air.rs). Returns t = ζ·b mod q.
+        fn fill_mult<F: PrimeField64>(vals: &mut [F], off: usize, zeta: u64, b: u64) -> u64 {
+            assert!(zeta < (1 << 23) && b < (1 << 23));
+            let (z0, z1) = split(zeta);
+            let (b0, b1) = split(b);
+            let prod = (zeta as u128) * (b as u128);
+            let t = (prod % Q as u128) as u64;
+            let mm = (prod / Q as u128) as u64;
+            let (m0, m1) = split(mm);
+            let (t0, t1) = split(t);
+            let s0 = z0 * b0;
+            let (l0, kl0) = (s0 % BETA, s0 / BETA);
+            let s1 = z0 * b1 + z1 * b0 + kl0;
+            let (l1, kl1) = (s1 % BETA, s1 / BETA);
+            let s2 = z1 * b1 + kl1;
+            let (l2, kl2) = (s2 % BETA, s2 / BETA);
+            let u0 = m0 + t0;
+            let (mm0, kr0) = (u0 % BETA, u0 / BETA);
+            let u1 = m0 * Q1 + m1 + t1 + kr0;
+            let (mm1, kr1) = (u1 % BETA, u1 / BETA);
+            let u2 = m1 * Q1 + kr1;
+            let (mm2, kr2) = (u2 % BETA, u2 / BETA);
+            assert_eq!((l0, l1, l2, kl2), (mm0, mm1, mm2, kr2), "limb mismatch (zeta={zeta}, b={b})");
+            let (gt0, gt1) = split((Q - 1) - t);
+            let (gm0, gm1) = split((Q - 1) - mm);
+            let prim = [
+                (MG_Z0, z0), (MG_Z1, z1), (MG_B0, b0), (MG_B1, b1),
+                (MG_M0, m0), (MG_M1, m1), (MG_T0, t0), (MG_T1, t1),
+                (MG_KL0, kl0), (MG_KL1, kl1), (MG_KL2, kl2),
+                (MG_KR0, kr0), (MG_KR1, kr1), (MG_KR2, kr2),
+                (MG_L0, l0), (MG_L1, l1), (MG_L2, l2),
+                (MG_MM0, mm0), (MG_MM1, mm1), (MG_MM2, mm2),
+                (MG_GT0, gt0), (MG_GT1, gt1), (MG_GM0, gm0), (MG_GM1, gm1),
+            ];
+            for (col, v) in prim {
+                vals[off + col] = F::from_u64(v);
+                let bo = off + mg_bit_off(col);
+                for j in 0..MG_WIDTHS[col] {
+                    vals[bo + j] = F::from_u64((v >> j) & 1);
+                }
+            }
+            t
+        }
+
+        /// Valid zero fill of the out block: Σ0 − 0 + q = 0 + 1·q ⇒ out = 0, kk = 1, slack = q−1.
+        /// (VERBATIM ntt_accumulate_air.rs reduction.) Returns out.
+        fn fill_out<F: PrimeField64>(vals: &mut [F], base: usize, psum: u64, psub: u64) -> u64 {
+            let s = psum + Q - psub;
+            let out = s % Q;
+            let kk = s / Q;
+            assert!(kk < 8);
+            let (o0, o1) = split(out);
+            let (g0, g1) = split(Q - 1 - out);
+            let prim = [(O0, o0), (O1, o1), (GO0, g0), (GO1, g1), (KKC, kk)];
+            let ow = [12usize, 11, 12, 11, 3];
+            let mut off = OBITS;
+            for (ci, &(col, v)) in prim.iter().enumerate() {
+                vals[base + col] = F::from_u64(v);
+                for j in 0..ow[ci] {
+                    vals[base + off + j] = F::from_u64((v >> j) & 1);
+                }
+                off += ow[ci];
+            }
+            out
+        }
+
+        /// Build the full Leg-M trace + pis: placement core + matvec arithmetic tail. `zhat/t1n/chat`
+        /// are the representative canonical NTT-domain statement inputs (< q). Returns
+        /// (trace, placed Â[0..NM], ŵ_i[0..NM], pis).
+        pub fn generate<F: PrimeField64>(
+            stream: &[u8],
+            zhat: &[u64; NM],
+            t1n: &[u64; NM],
+            chat: &[u64; NM],
+        ) -> (RowMajorMatrix<F>, [u64; NM], [u64; NM], Vec<F>) {
+            assert_eq!(stream.len(), CBUDM * 3, "Leg M expects the {}-byte budget stream", CBUDM * 3);
+            let mut vals = F::zero_vec(HEIGHT_M * NUM_COLS_M);
+            let mut bank = [0u64; NM];
+
+            // candidate rows
+            let mut cnt = 0usize;
+            for rr in 0..CBUDM {
+                let base = rr * NUM_COLS_M;
+                // bank state BEFORE this row's candidate
+                for k in 0..NM {
+                    vals[base + BANK + k] = F::from_u64(bank[k]);
+                }
+                let ch = &stream[3 * rr..3 * rr + 3];
+                let v = ch[0] as u64 | (ch[1] as u64) << 8 | (ch[2] as u64) << 16;
+                let place = fill_cand(&mut vals[base..base + NUM_COLS_M], 0, v, cnt);
+                if place {
+                    bank[cnt] = v & 0x7F_FFFF;
+                    cnt += 1;
+                }
+                if rr == CBUDM - 1 {
+                    assert_eq!(cnt, NM, "entry: {NM}th acceptance must precede the last budget row");
+                    assert!(!place);
+                }
+                // valid zero fill of the coefficient block (mult gadgets are unconditional)
+                for g in 0..(LDIM_M + 2) {
+                    fill_mult(&mut vals[base..base + NUM_COLS_M], CB + g * MG_COLS, 0, 0);
+                }
+                fill_out(&mut vals[base..base + NUM_COLS_M], 0, 0, 0);
+            }
+            assert_eq!(cnt, NM);
+            let ahat = bank;
+
+            // coefficient rows: banks thread the final placed poly; compute ŵ_i per coefficient.
+            //   P[0] = Â[0][jj]·ẑ[0][jj] mod q ; t1s = 8192·t̂1[jj] mod q ; psub = ĉ[jj]·t1s mod q ;
+            //   ŵ_i[jj] = (Σ P − psub) mod q  (VERBATIM fill_mult / fill_out arithmetic).
+            let mut what = [0u64; NM];
+            for jj in 0..NM {
+                let base = (COEFF0_M + jj) * NUM_COLS_M;
+                for k in 0..NM {
+                    vals[base + BANK + k] = F::from_u64(bank[k]);
+                }
+                fill_cand_zero(&mut vals[base..base + NUM_COLS_M], 0);
+                let mut psum = 0u64;
+                for j in 0..LDIM_M {
+                    let p = fill_mult(&mut vals[base..base + NUM_COLS_M], MG_AZ0 + j * MG_COLS, zhat[jj], ahat[jj]);
+                    vals[base + PCOL + j] = F::from_u64(p);
+                    psum += p;
+                }
+                let t1sv = fill_mult(&mut vals[base..base + NUM_COLS_M], MG_T1S, D2, t1n[jj]);
+                let psv = fill_mult(&mut vals[base..base + NUM_COLS_M], MG_PSUB, chat[jj], t1sv);
+                vals[base + PSUBCOL] = F::from_u64(psv);
+                what[jj] = fill_out(&mut vals[base..base + NUM_COLS_M], 0, psum, psv);
+            }
+            // padding rows: valid zero fill everywhere, bank 0
+            for r in REAL_ROWS_M..HEIGHT_M {
+                let base = r * NUM_COLS_M;
+                fill_cand_zero(&mut vals[base..base + NUM_COLS_M], 0);
+                for g in 0..(LDIM_M + 2) {
+                    fill_mult(&mut vals[base..base + NUM_COLS_M], CB + g * MG_COLS, 0, 0);
+                }
+                fill_out(&mut vals[base..base + NUM_COLS_M], 0, 0, 0);
+            }
+
+            // publics: [pi_stream (320) ‖ ẑ (64) ‖ t̂1 (64) ‖ ĉ (64) ‖ ŵ_i (64)]
+            let mut pis: Vec<F> = Vec::with_capacity(NUM_PIS_M);
+            for rr in 0..CBUDM {
+                let ch = &stream[3 * rr..3 * rr + 3];
+                let v = ch[0] as u64 | (ch[1] as u64) << 8 | (ch[2] as u64) << 16;
+                pis.push(F::from_u64(v));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(zhat[k]));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(t1n[k]));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(chat[k]));
+            }
+            for k in 0..NM {
+                pis.push(F::from_u64(what[k]));
+            }
+            assert_eq!(pis.len(), NUM_PIS_M);
+            (RowMajorMatrix::new(vals, NUM_COLS_M), ahat, what, pis)
+        }
+    }
+
+    // =======================================================================================
+    // Host ExpandA reference pieces (real ρ + independent SHAKE128 oracle + rejection sampling)
+    // =======================================================================================
+
+    /// REAL libcrux ML-DSA-87 seed-5 ρ, re-derived by libcrux's OWN keygen H() step.
+    ///
+    /// libcrux-ml-dsa-0.0.9 `ml_dsa_generic.rs::generate_key_pair` computes
+    /// `seed_expanded = SHAKE256(randomness ‖ [ROWS_IN_A, COLUMNS_IN_A])` (128 B) then takes
+    /// `seed_for_a = seed_expanded[0..SEED_FOR_A_SIZE]`, and the verification key is written as
+    /// `seed_for_a ‖ t1`, so `ρ = pk[0..32] = seed_for_a`. For ML-DSA-87 (`constants.rs:130-131`)
+    /// `ROWS_IN_A = 8`, `COLUMNS_IN_A = 7`, `SEED_FOR_A_SIZE = 32`. We reproduce that exact
+    /// computation with an independent SHAKE256 (`tiny_keccak`), so the bytes are byte-identical
+    /// to `libcrux_ml_dsa::ml_dsa_87::generate_key_pair(seed).verification_key[0..32]`.
+    /// `seed` is the seed-5 pattern from `expanda_stream_bind_air.rs` main.
+    fn libcrux_seed5_rho() -> [u8; 32] {
+        let seed: [u8; 32] = core::array::from_fn(|k| (0x1b_u8).wrapping_mul(k as u8 + 1) ^ 5);
+        let mut sh = Shake::v256(); // SHAKE256, DELIM 0x1F
+        sh.update(&seed);
+        sh.update(&[8u8, 7u8]); // [ROWS_IN_A, COLUMNS_IN_A] for ML-DSA-87
+        let mut expanded = [0u8; 128];
+        sh.finalize(&mut expanded);
+        let mut rho = [0u8; 32];
+        rho.copy_from_slice(&expanded[0..32]);
+        rho
+    }
+
+    /// Representative canonical NTT-domain statement inputs `ẑ[0] / t̂1_i / ĉ` (each < q), for the
+    /// matvec tail. The tail's job is the ARITHMETIC, not re-deriving ẑ/ĉ/t̂1 — those come from
+    /// their own stages/publics in the full composition. Deterministic SplitMix64 residues mod q,
+    /// so the run is reproducible and the ŵ_i diff-test is meaningful.
+    fn rep_ntt_inputs() -> ([u64; matvec::NM], [u64; matvec::NM], [u64; matvec::NM]) {
+        let mut s = 0x_C0FF_EE12_3456_789Au64;
+        let mut nextq = || {
+            s = s.wrapping_add(0x9E3779B97F4A7C15);
+            let mut z = s;
+            z = (z ^ (z >> 30)).wrapping_mul(0xBF58476D1CE4E5B9);
+            z = (z ^ (z >> 27)).wrapping_mul(0x94D049BB133111EB);
+            (z ^ (z >> 31)) % Q
+        };
+        let zhat: [u64; matvec::NM] = core::array::from_fn(|_| nextq());
+        let t1n: [u64; matvec::NM] = core::array::from_fn(|_| nextq());
+        let chat: [u64; matvec::NM] = core::array::from_fn(|_| nextq());
+        (zhat, t1n, chat)
+    }
+
+    /// The exact ExpandA byte source, SHAKE128(ρ ‖ s ‖ r), via an INDEPENDENT XOF (`tiny_keccak`).
+    fn shake128_stream(rho: &[u8; 32], s: u8, r: u8, outlen: usize) -> Vec<u8> {
+        let mut sh = Shake::v128();
+        sh.update(rho);
+        sh.update(&[s, r]);
+        let mut out = vec![0u8; outlen];
+        sh.finalize(&mut out);
+        out
+    }
+
+    /// Rejection-sample a budgeted candidate stream (== expanda_matvec_air.rs::expand_entry).
+    fn expand_entry(stream: &[u8]) -> ([i64; N], usize, usize) {
+        let mut poly = [0i64; N];
+        let mut cnt = 0usize;
+        let mut rej = 0usize;
+        let mut done_at = 0usize;
+        for (ci, ch) in stream.chunks(3).enumerate() {
+            if cnt == N {
+                break;
+            }
+            let v = ch[0] as u64 | (ch[1] as u64) << 8 | (ch[2] as u64) << 16;
+            let t = (v & 0x7F_FFFF) as i64;
+            if t < QI {
+                poly[cnt] = t;
+                cnt += 1;
+                done_at = ci;
+            } else {
+                rej += 1;
+            }
+        }
+        assert_eq!(cnt, N, "candidate budget overflow (would need a larger C)");
+        assert!(done_at <= CBUD - 2, "256th acceptance must land strictly before the last budget row");
+        (poly, rej, done_at)
+    }
+
+    /// verify_ref-style ExpandA for one (r=i, s=j) entry, incremental XOF (FIPS-204 / libcrux).
+    fn expand_a_ref_entry(rho: &[u8; 32], s: u8, r: u8) -> [i64; N] {
+        let mut sh = Shake::v128();
+        sh.update(rho);
+        sh.update(&[s, r]);
+        let mut out = [0i64; N];
+        let mut cnt = 0usize;
+        let mut buf = [0u8; 3];
+        while cnt < N {
+            sh.squeeze(&mut buf);
+            let coef = (buf[0] as i64) | ((buf[1] as i64) << 8) | (((buf[2] & 0x7f) as i64) << 16);
+            if coef < QI {
+                out[cnt] = coef;
+                cnt += 1;
+            }
+        }
+        out
+    }
+
+    // =======================================================================================
+    // Native batch-STARK leg provers (single-instance batch proofs — the recursion-verifiable
+    // form of the uni-stark legs; SAME AIR/trace/publics, only the harness differs)
+    // =======================================================================================
+    type LegProof = (
+        BatchProof<ConfigWithFriParams>,
+        ProverData<ConfigWithFriParams>,
+        Vec<F>,
+    );
+
+    /// Prove one SHAKE128 entry as a batch-STARK proof; return (proof, prover_data, publics).
+    /// `pub_out_override` swaps the squeeze-output publics (unused here; kept for parity).
+    fn prove_shake_leg(
+        config: &ConfigWithFriParams,
+        air: &shake::ShakeThreadedAir,
+        rho: &[u8; 32],
+        j: u8,
+        i: u8,
+    ) -> (LegProof, Vec<u8>) {
+        let mut msg = rho.to_vec();
+        msg.push(j);
+        msg.push(i);
+        let chain = shake::build_chain(air, &msg);
+        let out_bytes = shake::chain_out_bytes(air, &chain); // 1008 bytes
+        let pis: Vec<F> =
+            msg.iter().chain(out_bytes.iter()).map(|&b| F::from_u64(b as u64)).collect();
+        assert_eq!(pis.len(), air.num_pis());
+        let trace = shake::generate::<F>(air, &chain);
+        let instances = vec![StarkInstance { air, trace: &trace, public_values: pis.clone() }];
+        let prover_data = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &prover_data);
+        verify_batch(
+            config,
+            core::slice::from_ref(air),
+            &proof,
+            core::slice::from_ref(&pis),
+            &prover_data.common,
+        )
+        .expect("native Leg S batch verify failed");
+        ((proof, prover_data, pis), out_bytes)
+    }
+
+    /// Prove Leg B (l entries) as a batch-STARK proof; return (proof, prover_data, publics).
+    fn prove_bind_leg(config: &ConfigWithFriParams, l: usize, bytes: &[u8]) -> LegProof {
+        let air = bind::BindAir { l };
+        let pis = bind::build_pis(l, bytes);
+        let trace = bind::generate::<F>(l, bytes);
+        let instances = vec![StarkInstance { air: &air, trace: &trace, public_values: pis.clone() }];
+        let prover_data = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &prover_data);
+        verify_batch(
+            config,
+            core::slice::from_ref(&air),
+            &proof,
+            core::slice::from_ref(&pis),
+            &prover_data.common,
+        )
+        .expect("native Leg B batch verify failed");
+        (proof, prover_data, pis)
+    }
+
+    /// Prove Leg M (ExpandA placement core + matvec arithmetic tail) as a batch-STARK proof over
+    /// the 320-candidate stream + the representative ẑ/t̂1/ĉ inputs. Returns (proof, placed Â, ŵ_i).
+    fn prove_matvec_leg(
+        config: &ConfigWithFriParams,
+        stream: &[u8],
+        zhat: &[u64; matvec::NM],
+        t1n: &[u64; matvec::NM],
+        chat: &[u64; matvec::NM],
+    ) -> (LegProof, [u64; matvec::NM], [u64; matvec::NM]) {
+        let air = matvec::ExpandaPlaceAir {};
+        let (trace, ahat, what, pis) = matvec::generate::<F>(stream, zhat, t1n, chat);
+        let instances = vec![StarkInstance { air: &air, trace: &trace, public_values: pis.clone() }];
+        let prover_data = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &prover_data);
+        verify_batch(
+            config,
+            core::slice::from_ref(&air),
+            &proof,
+            core::slice::from_ref(&pis),
+            &prover_data.common,
+        )
+        .expect("native Leg M batch verify failed");
+        ((proof, prover_data, pis), ahat, what)
+    }
+
+    /// Prove Leg M over a TAMPERED trace (a placed-Â coefficient or an accumulate partial-sum
+    /// altered so ŵ_i is wrong) and return whether the native batch verify REJECTS it. The prover
+    /// still produces a proof over a constraint-violating trace (no panic); verify must reject.
+    fn matvec_tamper_rejects(
+        config: &ConfigWithFriParams,
+        stream: &[u8],
+        zhat: &[u64; matvec::NM],
+        t1n: &[u64; matvec::NM],
+        chat: &[u64; matvec::NM],
+        tamper: impl FnOnce(&mut RowMajorMatrix<F>),
+    ) -> bool {
+        let air = matvec::ExpandaPlaceAir {};
+        let (mut trace, _, _, pis) = matvec::generate::<F>(stream, zhat, t1n, chat);
+        tamper(&mut trace);
+        let instances = vec![StarkInstance { air: &air, trace: &trace, public_values: pis.clone() }];
+        let prover_data = ProverData::from_instances(config, &instances);
+        let proof = prove_batch(config, &instances, &prover_data);
+        verify_batch(config, core::slice::from_ref(&air), &proof, core::slice::from_ref(&pis), &prover_data.common)
+            .is_err()
+    }
+
+    // =======================================================================================
+    // THREE-stage outer recursion: verify Leg S + Leg B + Leg M in ONE circuit, bind the TWO
+    // cross-stage ties (S↔B squeeze/stream, B↔M pi_stream), produce ONE outer proof.
+    // =======================================================================================
+    #[allow(clippy::too_many_arguments)]
+    fn build_and_prove_outer3(
+        config: &ConfigWithFriParams,
+        fvp: &FriVerifierParams,
+        fri_params: &FriParams,
+        air_s: &shake::ShakeThreadedAir,
+        leg_s: &LegProof,
+        air_b: &bind::BindAir,
+        leg_b: &LegProof,
+        air_m: &matvec::ExpandaPlaceAir,
+        leg_m: &LegProof,
+        tie1_offset_s: usize, // first squeeze-byte public in Leg S (== pi_out_base = 34)
+        tie1_len: usize,      // squeeze bytes bound S↔B (== l·960)
+        tie2_offset_b: usize, // first pack public in Leg B (== pi_packs_base(l) = 960)
+        tie2_len: usize,      // packs bound B↔M (== CBUD = 320)
+        do_connect: bool,
+    ) -> Result<(usize, u32), String> {
+        let (proof_s, pd_s, pub_s) = leg_s;
+        let (proof_b, pd_b, pub_b) = leg_b;
+        let (proof_m, pd_m, pub_m) = leg_m;
+        let perm = p3_koala_bear::default_koalabear_poseidon2_16();
+        let mut cb = CircuitBuilder::new();
+        cb.enable_poseidon2_perm::<p3_poseidon2_circuit_air::KoalaBearD4Width16, _>(
+            generate_poseidon2_trace::<Challenge, p3_poseidon2_circuit_air::KoalaBearD4Width16>,
+            perm,
+        );
+        cb.enable_recompose::<F>(generate_recompose_trace::<F, Challenge>);
+        let lookup_gadget = LogUpGadget::new();
+
+        // --- Leg S: allocate + verify in-circuit ---
+        let vi_s = BatchStarkVerifierInputsBuilder::<
+            ConfigWithFriParams,
+            MerkleCapTargets<F, DIGEST_ELEMS>,
+            InnerFri,
+        >::allocate(&mut cb, proof_s, &pd_s.common, &[pub_s.len()]);
+        let op_ids_s = verify_batch_circuit::<_, _, _, _, _, _, _, WIDTH, RATE>(
+            config,
+            core::slice::from_ref(air_s),
+            &mut cb,
+            &vi_s.proof_targets,
+            &vi_s.air_public_targets,
+            fvp,
+            &vi_s.common_data,
+            &lookup_gadget,
+            Poseidon2Config::KOALA_BEAR_D4_W16,
+        )
+        .map_err(|e| format!("build Leg S verify circuit: {e:?}"))?;
+
+        // --- Leg B: allocate + verify in-circuit ---
+        let vi_b = BatchStarkVerifierInputsBuilder::<
+            ConfigWithFriParams,
+            MerkleCapTargets<F, DIGEST_ELEMS>,
+            InnerFri,
+        >::allocate(&mut cb, proof_b, &pd_b.common, &[pub_b.len()]);
+        let op_ids_b = verify_batch_circuit::<_, _, _, _, _, _, _, WIDTH, RATE>(
+            config,
+            core::slice::from_ref(air_b),
+            &mut cb,
+            &vi_b.proof_targets,
+            &vi_b.air_public_targets,
+            fvp,
+            &vi_b.common_data,
+            &lookup_gadget,
+            Poseidon2Config::KOALA_BEAR_D4_W16,
+        )
+        .map_err(|e| format!("build Leg B verify circuit: {e:?}"))?;
+
+        // --- Leg M: allocate + verify in-circuit ---
+        let vi_m = BatchStarkVerifierInputsBuilder::<
+            ConfigWithFriParams,
+            MerkleCapTargets<F, DIGEST_ELEMS>,
+            InnerFri,
+        >::allocate(&mut cb, proof_m, &pd_m.common, &[pub_m.len()]);
+        let op_ids_m = verify_batch_circuit::<_, _, _, _, _, _, _, WIDTH, RATE>(
+            config,
+            core::slice::from_ref(air_m),
+            &mut cb,
+            &vi_m.proof_targets,
+            &vi_m.air_public_targets,
+            fvp,
+            &vi_m.common_data,
+            &lookup_gadget,
+            Poseidon2Config::KOALA_BEAR_D4_W16,
+        )
+        .map_err(|e| format!("build Leg M verify circuit: {e:?}"))?;
+
+        // --- TIE 1 (S↔B): Leg-S squeeze-output publics == Leg-B stream-input publics ---
+        // --- TIE 2 (B↔M): Leg-B pi_stream-output packs == Leg-M pi_stream-input packs ---
+        // Each equality is an ALU `sub` asserted zero (each public read once — a direct `connect`
+        // would break the Public-table LogUp).
+        if do_connect {
+            for b in 0..tie1_len {
+                let diff = cb.sub(
+                    vi_s.air_public_targets[0][tie1_offset_s + b],
+                    vi_b.air_public_targets[0][b],
+                );
+                cb.assert_zero(diff);
+            }
+            for r in 0..tie2_len {
+                let diff = cb.sub(
+                    vi_b.air_public_targets[0][tie2_offset_b + r],
+                    vi_m.air_public_targets[0][matvec::PI_STREAM_M + r],
+                );
+                cb.assert_zero(diff);
+            }
+        }
+
+        let vc = cb.build().map_err(|e| format!("outer circuit build: {e:?}"))?;
+        let witness_count = vc.witness_count;
+        println!(
+            "  recursion circuit (3-leg): witness_count={witness_count}, tie1_len={tie1_len}, \
+             tie2_len={tie2_len}, connect={do_connect}"
+        );
+
+        // Pack public/private inputs, in allocation order (S then B then M).
+        let (pub_in_s, priv_in_s) =
+            vi_s.pack_values(core::slice::from_ref(pub_s), proof_s, &pd_s.common);
+        let (pub_in_b, priv_in_b) =
+            vi_b.pack_values(core::slice::from_ref(pub_b), proof_b, &pd_b.common);
+        let (pub_in_m, priv_in_m) =
+            vi_m.pack_values(core::slice::from_ref(pub_m), proof_m, &pd_m.common);
+        let mut public_inputs = pub_in_s;
+        public_inputs.extend(pub_in_b);
+        public_inputs.extend(pub_in_m);
+        let mut private_inputs = priv_in_s;
+        private_inputs.extend(priv_in_b);
+        private_inputs.extend(priv_in_m);
+
+        let mut runner = vc.runner();
+        runner
+            .set_public_inputs(&public_inputs)
+            .map_err(|e| format!("set publics: {e:?}"))?;
+        runner
+            .set_private_inputs(&private_inputs)
+            .map_err(|e| format!("set privates: {e:?}"))?;
+        set_fri_mmcs_private_data::<F, Challenge, ChallengeMmcs, MyMmcs, MyHash, MyCompress, DIGEST_ELEMS>(
+            &mut runner,
+            &op_ids_s,
+            &proof_s.opening_proof,
+            Poseidon2Config::KOALA_BEAR_D4_W16,
+        )
+        .map_err(|e| format!("Leg S mmcs private data: {e}"))?;
+        set_fri_mmcs_private_data::<F, Challenge, ChallengeMmcs, MyMmcs, MyHash, MyCompress, DIGEST_ELEMS>(
+            &mut runner,
+            &op_ids_b,
+            &proof_b.opening_proof,
+            Poseidon2Config::KOALA_BEAR_D4_W16,
+        )
+        .map_err(|e| format!("Leg B mmcs private data: {e}"))?;
+        set_fri_mmcs_private_data::<F, Challenge, ChallengeMmcs, MyMmcs, MyHash, MyCompress, DIGEST_ELEMS>(
+            &mut runner,
+            &op_ids_m,
+            &proof_m.opening_proof,
+            Poseidon2Config::KOALA_BEAR_D4_W16,
+        )
+        .map_err(|e| format!("Leg M mmcs private data: {e}"))?;
+
+        // The negative cases fail HERE: an aliased cross-stage public with a conflicting value.
+        let traces = runner
+            .run()
+            .map_err(|e| format!("recursion circuit run rejected: {e:?}"))?;
+
+        // --- Prove the outer (aggregated) proof ---
+        let l1_packing = TablePacking::new(1, 2)
+            .with_fri_params(fri_params.log_final_poly_len, fri_params.log_blowup);
+        let npo_prep: Vec<Box<dyn NpoPreprocessor<F>>> = vec![
+            Box::new(Poseidon2Preprocessor),
+            Box::new(RecomposePreprocessor::default()),
+        ];
+        let mut air_builders = poseidon2_air_builders::<ConfigWithFriParams, D>();
+        air_builders.extend(recompose_air_builders::<ConfigWithFriParams, D>(1, false));
+        let (airs_degrees, prim_cols, non_prim_cols) =
+            get_airs_and_degrees_with_prep::<ConfigWithFriParams, Challenge, D>(
+                &vc,
+                &l1_packing,
+                &npo_prep,
+                &air_builders,
+                ConstraintProfile::Standard,
+            )
+            .map_err(|e| format!("outer airs/degrees: {e:?}"))?;
+        let (airs, degrees): (Vec<_>, Vec<usize>) = airs_degrees.into_iter().unzip();
+        let prover_data = ProverData::from_airs_and_degrees(config, &airs, &degrees);
+        let cpd = CircuitProverData::new(prover_data, prim_cols, non_prim_cols);
+        let mut prover = BatchStarkProver::new(config.clone())
+            .with_table_packing(l1_packing)
+            .with_alu_variant(AirVariant::Baseline);
+        prover.register_poseidon2_table::<D>(Poseidon2Config::KOALA_BEAR_D4_W16);
+        prover.register_recompose_table::<D>(false);
+        let proof = prover
+            .prove_all_tables(&traces, &cpd)
+            .map_err(|e| format!("prove outer: {e:?}"))?;
+        prover
+            .verify_all_tables::<Challenge>(&proof)
+            .map_err(|e| format!("verify outer: {e:?}"))?;
+        let bytes = postcard::to_allocvec(&proof)
+            .map_err(|e| format!("serialize outer: {e:?}"))?
+            .len();
+        Ok((bytes, witness_count))
+    }
+
+    pub fn run() {
+        // Inner (layer-0) FRI params — same bench-grade shape as `crossleg_bind`.
+        let fri_params = FriParams {
+            log_blowup: 2,
+            max_log_arity: 2,
+            cap_height: 0,
+            log_final_poly_len: 5,
+            commit_pow_bits: 0,
+            query_pow_bits: 15,
+        };
+        let config = config_with_fri_params(&fri_params, SECURITY, false);
+        let fvp = create_fri_verifier_params(&fri_params, SECURITY);
+
+        let air_s = shake::ShakeThreadedAir { rate_lanes: 21, msg_len: MSG_LEN, num_squeeze: NUM_SQZ };
+        let l: usize = 1; // ONE ExpandA entry (both legs FULL)
+
+        // ---- REAL libcrux ML-DSA-87 seed-5 ρ ----
+        let rho = libcrux_seed5_rho();
+        info!(
+            "real-leg cross-leg binding: Leg S = ShakeThreadedAir {}×{} ({} pubs), \
+             Leg B = BindAir(l={}) {}×{} ({} pubs), ρ = libcrux ML-DSA-87 seed-5, security={SECURITY}",
+            air_s.total_width(),
+            air_s.height(),
+            air_s.num_pis(),
+            l,
+            bind::NUM_COLS,
+            bind::height(l),
+            bind::num_pis(l),
+        );
+        println!("  seed-5 ρ (real libcrux) = {}", hex32(&rho));
+
+        // ================= GATE: real-leg faithfulness (host, independent oracles) =================
+        // Leg S's in-AIR sponge output must equal an INDEPENDENT SHAKE128, and the bound stream
+        // must rejection-sample to the FIPS-204 ExpandA reference coefficient-for-coefficient.
+        let chain0 = shake::build_chain(&air_s, &{
+            let mut m = rho.to_vec();
+            m.push(0);
+            m.push(I_ROW as u8);
+            m
+        });
+        let leg_s_sponge = shake::chain_out_bytes(&air_s, &chain0); // 1008 bytes, from Keccak-f
+        let oracle = shake128_stream(&rho, 0, I_ROW as u8, air_s.num_squeeze * air_s.rate_bytes());
+        assert_eq!(
+            leg_s_sponge, oracle,
+            "Leg S in-AIR sponge != independent tiny_keccak SHAKE128 (ρ‖[0,{I_ROW}])"
+        );
+        let stream0: Vec<u8> = leg_s_sponge[..STREAM_BYTES].to_vec();
+        let (poly, rej, done_at) = expand_entry(&stream0);
+        let refp = expand_a_ref_entry(&rho, 0, I_ROW as u8);
+        for k in 0..N {
+            assert_eq!(poly[k], refp[k], "coeff {k}: budgeted ExpandA != FIPS-204 reference");
+        }
+        // Leg B packs == byte recomposition of the squeeze bytes.
+        let b_pis = bind::build_pis(l, &stream0);
+        for r in 0..CBUD {
+            let src = 3 * r;
+            let want = stream0[src] as u64 | (stream0[src + 1] as u64) << 8 | (stream0[src + 2] as u64) << 16;
+            assert_eq!(b_pis[bind::pi_packs_base(l) + r], F::from_u64(want), "pack {r} != recompose");
+        }
+        println!(
+            "GATE ok — real-leg faithfulness: Leg S squeeze == tiny_keccak SHAKE128 (1008 B); \
+             rejection-sampled Â[{I_ROW}][0] == FIPS-204 ExpandA reference (256/256 coeffs, \
+             rejections={rej}, 256th-accept idx={done_at}); Leg B packs == squeeze recomposition (320/320)."
+        );
+
+        // ================= Native layer-0 batch-STARK leg proofs =================
+        let t = Instant::now();
+        let (leg_s0, out0) = prove_shake_leg(&config, &air_s, &rho, 0, I_ROW as u8);
+        assert_eq!(out0[..STREAM_BYTES], stream0[..], "Leg S proof stream != gated stream");
+        println!(
+            "Leg S batch proof (nonce [0,{I_ROW}]): {} bytes, {} pubs, {:.1?}",
+            postcard::to_allocvec(&leg_s0.0).unwrap().len(),
+            leg_s0.2.len(),
+            t.elapsed()
+        );
+
+        let t = Instant::now();
+        let leg_b_match = prove_bind_leg(&config, l, &stream0);
+        println!(
+            "Leg B batch proof (l={l}, matching stream): {} bytes, {} pubs, {:.1?}",
+            postcard::to_allocvec(&leg_b_match.0).unwrap().len(),
+            leg_b_match.2.len(),
+            t.elapsed()
+        );
+
+        // Representative canonical NTT-domain statement inputs for the matvec tail.
+        let (zhat_m, t1n_m, chat_m) = rep_ntt_inputs();
+
+        // Leg M native proof (ExpandA placement core + matvec arithmetic tail) over Leg S's stream.
+        let t = Instant::now();
+        let (leg_m_match, ahat_m, what_m) = prove_matvec_leg(&config, &stream0, &zhat_m, &t1n_m, &chat_m);
+        println!(
+            "Leg M batch proof (l=1, N={}, C={CBUD}, placement+matvec, matching stream): {} bytes, {} pubs, {} cols × {} rows, {:.1?}",
+            matvec::NM,
+            postcard::to_allocvec(&leg_m_match.0).unwrap().len(),
+            leg_m_match.2.len(),
+            matvec::NUM_COLS_M,
+            matvec::HEIGHT_M,
+            t.elapsed()
+        );
+        // GATE (a): the in-AIR placed Â[0][0][0..N] == FIPS-204 ExpandA reference (first N coeffs).
+        for k in 0..matvec::NM {
+            assert_eq!(
+                ahat_m[k] as i64, refp[k],
+                "Leg M placed Â coeff {k} != FIPS-204 ExpandA reference"
+            );
+        }
+        // GATE (b): the in-AIR ŵ_i[0..N] == the mldsa_verify_ref matvec row Σ Â∘ẑ − ĉ∘(t̂1·2^d),
+        // computed the reference way (coefficient-exact diff-test on real Â).
+        let what_ref = matvec::matvec_ref(&ahat_m, &zhat_m, &t1n_m, &chat_m);
+        for k in 0..matvec::NM {
+            assert_eq!(what_m[k], what_ref[k], "Leg M ŵ_i coeff {k} != mldsa_verify_ref matvec row");
+        }
+        println!(
+            "GATE ok — Leg M placed Â[{I_ROW}][0][0..{n}] == FIPS-204 ExpandA reference AND ŵ_{I_ROW}[0..{n}] == \
+             mldsa_verify_ref matvec row (Σ Â∘ẑ − ĉ∘(t̂1·2^d)), both coefficient-exact (reduced-but-real: \
+             rejection-sample → one-hot placement → A-bank → pointwise mult + accumulate, real ρ).",
+            n = matvec::NM
+        );
+
+        let air_b = bind::BindAir { l };
+        let air_m = matvec::ExpandaPlaceAir {};
+        let tie1_offset_s = air_s.pi_out_base(); // 34
+        let tie1_len = l * STREAM_BYTES; // 960 (S↔B squeeze bytes)
+        let tie2_offset_b = bind::pi_packs_base(l); // 960 (first Leg-B pack public)
+        let tie2_len = CBUD; // 320 (B↔M packs)
+
+        // ================= [1] HONEST: S ∘ B ∘ M all on nonce [0,0], both ties =================
+        let t = Instant::now();
+        let (bytes, wc) = build_and_prove_outer3(
+            &config, &fvp, &fri_params, &air_s, &leg_s0, &air_b, &leg_b_match, &air_m, &leg_m_match,
+            tie1_offset_s, tie1_len, tie2_offset_b, tie2_len, true,
+        )
+        .expect("HONEST 3-stage case must succeed");
+        println!(
+            "[1] HONEST  (S∘B∘M all nonce [0,{I_ROW}], tie1={tie1_len} tie2={tie2_len}): outer proof OK, \
+             {bytes} bytes, witness_count={wc}, {:.1?}",
+            t.elapsed()
+        );
+
+        // ================= [2] NEG1 (PRIMARY): Leg M fed a pi_stream inconsistent with Leg B ====
+        // Leg M is built over the DIFFERENT nonce-[1,0] stream — a valid ExpandA placement of a
+        // DIFFERENT candidate set. Bound against Leg B's nonce-[0,0] packs, Tie 2 fails -> reject.
+        let stream1 = shake128_stream(&rho, 1, I_ROW as u8, STREAM_BYTES);
+        assert_ne!(stream1, stream0, "nonce-[1,0] stream must differ from nonce-[0,0] (domain sep)");
+        let (leg_m_mismatch, _, _) = prove_matvec_leg(&config, &stream1, &zhat_m, &t1n_m, &chat_m);
+        let t = Instant::now();
+        match build_and_prove_outer3(
+            &config, &fvp, &fri_params, &air_s, &leg_s0, &air_b, &leg_b_match, &air_m,
+            &leg_m_mismatch, tie1_offset_s, tie1_len, tie2_offset_b, tie2_len, true,
+        ) {
+            Err(e) => println!(
+                "[2] NEG1(Leg M over nonce [1,{I_ROW}] pi_stream; Tie 2 B↔M): REJECTED at prove, {:.1?} -- {e}",
+                t.elapsed()
+            ),
+            Ok(_) => panic!("NEG1 must NOT produce an outer proof"),
+        }
+
+        // ================= [3] NEG2: the S↔B tie still rejects in the 3-leg circuit ==============
+        // B and M both over nonce [1,0] (Tie 2 B↔M holds) but S over nonce [0,0], so Tie 1 fails.
+        let leg_b_mismatch = prove_bind_leg(&config, l, &stream1);
+        let t = Instant::now();
+        match build_and_prove_outer3(
+            &config, &fvp, &fri_params, &air_s, &leg_s0, &air_b, &leg_b_mismatch, &air_m,
+            &leg_m_mismatch, tie1_offset_s, tie1_len, tie2_offset_b, tie2_len, true,
+        ) {
+            Err(e) => println!(
+                "[3] NEG2(B,M over nonce [1,{I_ROW}]; S over [0,{I_ROW}]; Tie 1 S↔B): REJECTED at prove, \
+                 {:.1?} -- {e}",
+                t.elapsed()
+            ),
+            Ok(_) => panic!("NEG2 must NOT produce an outer proof"),
+        }
+
+        // ================= [4] NEG3: the matvec arithmetic tail rejects a wrong ŵ_i =============
+        // Tamper a placed-Â coefficient on the exact coefficient row that routes it into the mult
+        // (the --corrupt-coeff surface): the identity thread INTO that row AND the bank→mult
+        // diagonal read both break, so ŵ_i is wrong and Leg M's own batch proof rejects.
+        let t = Instant::now();
+        let coeff_rejects = matvec_tamper_rejects(&config, &stream0, &zhat_m, &t1n_m, &chat_m, |trace| {
+            trace.values[matvec::ahat_read_cell(20)] += F::ONE;
+        });
+        assert!(coeff_rejects, "NEG3a: tampered placed-Â coeff must be REJECTED by Leg M verify");
+        println!(
+            "[4] NEG3a(placed-Â coeff 20 tampered on its mult-read row → ŵ_{I_ROW} wrong): Leg M batch \
+             proof REJECTED at native verify, {:.1?}",
+            t.elapsed()
+        );
+        // A second variant: tamper an accumulate partial-sum P[0] (the --corrupt-psum surface) —
+        // the P == az.t binding and the accumulation-reduction both break.
+        let t = Instant::now();
+        let psum_rejects = matvec_tamper_rejects(&config, &stream0, &zhat_m, &t1n_m, &chat_m, |trace| {
+            trace.values[matvec::psum_cell(37)] += F::ONE;
+        });
+        assert!(psum_rejects, "NEG3b: tampered accumulate partial-sum must be REJECTED by Leg M verify");
+        println!(
+            "[4] NEG3b(accumulate partial-sum P[0] tampered on coefficient row 37): Leg M batch proof \
+             REJECTED at native verify, {:.1?}",
+            t.elapsed()
+        );
+
+        println!(
+            "THREE-stage ExpandA recursion chain + MATVEC ARITHMETIC TAIL demonstrated: \
+             SHAKE(ρ) → squeeze stream → pi_stream → rejection-sampled Â → pointwise Â∘ẑ mult + \
+             ĉ∘(t̂1·2^d) leg → accumulate-reduce → REAL ŵ_i, composed as ONE recursion tree over THREE \
+             HETEROGENEOUS gadgets (ShakeThreadedAir ∘ BindAir ∘ ExpandaPlaceAir), with the TWO \
+             cross-stage ties (S↔B squeeze/stream, B↔M pi_stream) PROVEN in-circuit and ŵ_i \
+             diff-tested exact against the mldsa_verify_ref matvec row — completing ρ → ŵ_i."
+        );
+    }
+
+    fn hex32(b: &[u8; 32]) -> String {
+        b.iter().map(|x| format!("{x:02x}")).collect()
+    }
+}
