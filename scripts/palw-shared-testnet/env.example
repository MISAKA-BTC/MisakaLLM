# =============================================================================
# env.example — configuration for the PALW closed two-node testnet harness
#               (Phase-0 wiring). DEVNET-111 defaults.
#
# USAGE
#   cp env.example env.local        # then edit env.local (git-ignored)
#   # or point the harness at any file:  export PALW_ENV_FILE=/path/to/env
#
# common.sh sources this file with `set -a` (every var below is exported), then
# overlays the generated artifacts/state.env on top. Environment values that are
# ALREADY set win over the defaults here (every line uses `${VAR:-default}`), so
# you can override any single knob inline:  NETWORK=testnet-110 ./run-all.sh
#
# PORTABILITY: nothing here hardcodes a machine-specific /Users or /private/tmp
# path. REPO_ROOT auto-derives from the checkout; data lives under $HOME.
# =============================================================================

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
# REPO_ROOT — absolute path to the MisakaLLM-palw-shared checkout that contains
#   target/release/{kaspad,kaspa-pq-validator,misaminer}. LEFT UNSET on purpose:
#   common.sh derives it as two levels up from scripts/palw-shared-testnet/.
#   Uncomment to override for an out-of-tree checkout (no hardcoded path here):
#export REPO_ROOT="$HOME/src/MisakaLLM-palw-shared"

# PALW_DATA_ROOT — writable root for ALL runtime state (node appdirs, logs,
#   keys, artifacts). Kept OUTSIDE the repo so `git status` stays clean.
#   Created mode 0700. Node A appdir = $PALW_DATA_ROOT/node-a, B = .../node-b.
export PALW_DATA_ROOT="${PALW_DATA_ROOT:-$HOME/.palw-testnet/devnet-111}"

# -----------------------------------------------------------------------------
# Network selection
#   devnet-111 : local plumbing preset, skip_proof_of_work=true, PALW active
#                from genesis, address prefix misakadev: .
#   testnet-110: shared preset, REAL algo-3 PoW, address prefix misakatest: .
#   NETWORK is the full node network id (kaspad NetworkId::to_string()) used by
#   status/bond/palw-* and misaminer --network-id. NETWORK_BASE is the bare base
#   name {mainnet,testnet,devnet,simnet} required only by `keygen --network`.
# -----------------------------------------------------------------------------
export NETWORK="${NETWORK:-devnet-111}"
export NETWORK_BASE="${NETWORK_BASE:-devnet}"
export NETSUFFIX="${NETSUFFIX:-111}"
export ADDR_PREFIX="${ADDR_PREFIX:-misakadev}"   # informational (devnet: misakadev:)

# --palw-enable-algo4 must be passed IDENTICALLY on ALL nodes (never a subset);
# it is a runtime override of the shipped palw_algo4_accept=false. This flag is
# a closed-net wiring switch only — never a public / value-bearing network.
export PALW_ENABLE_ALGO4="${PALW_ENABLE_ALGO4:-1}"

# Optional network-identity pin (STN-003/§9). If set to a 64-hex block hash,
# preflight.sh fail-closes unless every already-running node reports that exact
# node_genesis_hash. Leave EMPTY to only assert A==B parity (default). Pin it once
# you know the genesis for your NETWORK/NETSUFFIX so an independently-built host on
# the wrong network/config is rejected before the lifecycle starts. Obtain it with:
#   kaspa-pq-validator status --node-wrpc-borsh 127.0.0.1:$A_WRPC_PORT --network $NETWORK | grep node_genesis_hash
export EXPECTED_GENESIS_HASH="${EXPECTED_GENESIS_HASH:-}"

# -----------------------------------------------------------------------------
# Hosts & ports
#   RPC (gRPC + wRPC-borsh) binds loopback only ($RPC_BIND). P2P binds 0.0.0.0
#   but a PALW preset rejects any IP not in --connect pre-handshake.
#   NODE_A_HOST / NODE_B_HOST are the P2P-reachable addresses a peer --connects
#   to. Default 127.0.0.1 (single host, two processes). For a TWO-HOST run set
#   them to each host's routable/Tailscale address and keep RPC on 127.0.0.1.
# -----------------------------------------------------------------------------
export NODE_A_HOST="${NODE_A_HOST:-127.0.0.1}"
export NODE_B_HOST="${NODE_B_HOST:-127.0.0.1}"
export RPC_BIND="${RPC_BIND:-127.0.0.1}"          # RPC loopback bind (do not expose)

# Extra P2P peers beyond the A<->B star (STN-014). Space-separated host:port list
# added as additional --connect entries on BOTH node A and node B. Because the PALW
# preset derives its pre-handshake inbound IP allowlist FROM --connect, a joiner
# listed here is both dialed and admitted. To add a 3rd node: set this to its
# address on A and B (IDENTICALLY), restart A and B, and start the joiner with
# --connect back at A and B. Empty by default (the closed 2-node star).
#   e.g. export PALW_CONNECT_PEERS="100.66.1.9:26611 100.66.1.10:26611"
export PALW_CONNECT_PEERS="${PALW_CONNECT_PEERS:-}"

# devnet-111 local two-process port map (single host must keep A/B disjoint).
export A_P2P_PORT="${A_P2P_PORT:-26611}"          # kaspad --listen (A)
export A_GRPC_PORT="${A_GRPC_PORT:-26610}"        # kaspad --rpclisten (A) / miner --pool
export A_WRPC_PORT="${A_WRPC_PORT:-27610}"        # kaspad --rpclisten-borsh (A) / VAL --node-wrpc-borsh
export B_P2P_PORT="${B_P2P_PORT:-26612}"          # kaspad --listen (B)
export B_GRPC_PORT="${B_GRPC_PORT:-26620}"        # kaspad --rpclisten (B)
export B_WRPC_PORT="${B_WRPC_PORT:-27620}"        # kaspad --rpclisten-borsh (B)
# testnet-110 base ports (P2P 26411 / gRPC 26210 / wRPC 27210): on a SINGLE host
# node B must remap. On two hosts each node can use the base ports directly.

# -----------------------------------------------------------------------------
# Mining
# -----------------------------------------------------------------------------
# Supporting algo-3 miner throttle (misaminer --min-block-interval-ms). On
# devnet blocks are instant (no PoW); 1000-2000 ms keeps propagation sane.
export MINER_INTERVAL_MS="${MINER_INTERVAL_MS:-1000}"
export MINER_WORKER="${MINER_WORKER:-rig0}"       # misaminer --worker

# -----------------------------------------------------------------------------
# PALW batch shape
# -----------------------------------------------------------------------------
export LEAF_COUNT="${LEAF_COUNT:-1}"              # leaves in the batch manifest
export SHAPE_ID="${SHAPE_ID:-7}"                  # leaf shape_id == provider capacity SHAPE
export CAPACITY_COUNT="${CAPACITY_COUNT:-4}"      # provider --capacity <SHAPE>=<COUNT>

# -----------------------------------------------------------------------------
# Bond amounts & lifecycle floors (verified consensus constants)
#   provider-bond floor 10 MSK (1 MSK = 1e8 sompi); devnet unbonding floor 700
#   blocks; provider unbond-delay floor 6 epochs. Amounts accept 10MSK/10KAS/
#   <n>sompi. AUDITOR bond is a normal provider bond with a DISTINCT group id.
# -----------------------------------------------------------------------------
export DNS_BOND_AMOUNT="${DNS_BOND_AMOUNT:-10MSK}"       # VAL bond --amount (validator stake)
export PROVIDER_A_AMOUNT="${PROVIDER_A_AMOUNT:-10MSK}"   # provider A provider-bond
export PROVIDER_B_AMOUNT="${PROVIDER_B_AMOUNT:-10MSK}"   # provider B provider-bond
export AUDITOR_AMOUNT="${AUDITOR_AMOUNT:-10MSK}"         # auditor C provider-bond
export UNBONDING_PERIOD_BLOCKS="${UNBONDING_PERIOD_BLOCKS:-700}"  # VAL bond --unbonding-period-blocks
export UNBOND_DELAY_EPOCHS="${UNBOND_DELAY_EPOCHS:-6}"           # provider-bond --unbond-delay-epochs
export MIN_EPOCH_HEADROOM_DAA="${MIN_EPOCH_HEADROOM_DAA:-20}"    # palw-submit --min-epoch-headroom-daa

# -----------------------------------------------------------------------------
# Ticket mode  (governs whether an algo-4 block can be MINTED)
#   skip : (default) register the leaf-chunk with palw-submit
#          --unsafe-skip-ticket-secret-check. Reaches batch.status=active but
#          the block can NEVER be mined (no ticket). No mint.
#   mock : mint a WIRING-ONLY (non-inference) block. REQUIRES the mock-ticket
#          helper (see mock-ticket/README.md) to populate a TicketSecretStore;
#          it is specified, not shipped. Real inference needs the provider GPU
#          tool — this harness does not and cannot produce a real inference block.
# -----------------------------------------------------------------------------
export TICKET_MODE="${TICKET_MODE:-skip}"
# Ticket-authority seed + secret store (used only when TICKET_MODE=mock and by
# the algo-4 miner). Kept under keys/ at mode 0600. Do NOT copy between hosts.
export TICKET_AUTHORITY_KEY="${TICKET_AUTHORITY_KEY:-$PALW_DATA_ROOT/keys/ticket-authority.seed}"
export TICKET_SECRET_FILE="${TICKET_SECRET_FILE:-$PALW_DATA_ROOT/keys/ticket-secret.json}"
# PALW algo-4 miner payout address (ML-DSA-87 P2PKH). Discovered/derived at run
# time when empty; leave blank for the harness to fill (see PALW_MINE_ADDR slot).
export PALW_MINE_ADDRESS="${PALW_MINE_ADDRESS:-}"

# -----------------------------------------------------------------------------
# Commitment inputs (128-hex Hash64). Deterministic devnet placeholders — fine
# for a closed no-value wiring run. INVARIANTS enforced by the binaries:
#   * every leaf runtime_class_id MUST equal the providers' --runtime-class;
#   * leaf shape_id MUST match a provider capacity SHAPE;
#   * the AUDITOR operator-group-id MUST DIFFER from BOTH leaf providers'.
# -----------------------------------------------------------------------------
export OPERATOR_GROUP_A="${OPERATOR_GROUP_A:-a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1}"
export OPERATOR_GROUP_B="${OPERATOR_GROUP_B:-b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2}"
export OPERATOR_GROUP_AUD="${OPERATOR_GROUP_AUD:-c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3c3}"
export RUNTIME_CLASS_ID="${RUNTIME_CLASS_ID:-44444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444444}"
export MODEL_PROFILE_ID="${MODEL_PROFILE_ID:-11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111}"
export REWARD_KEY_ROOT_A="${REWARD_KEY_ROOT_A:-55555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555}"
export REWARD_KEY_ROOT_B="${REWARD_KEY_ROOT_B:-66666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666666}"
export AUDIT_POLICY_ID="${AUDIT_POLICY_ID:-77777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777}"
export DESCRIPTOR_ROOT="${DESCRIPTOR_ROOT:-88888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888888}"
# Per-leaf provider reward pubkey BYTES (expanded x64 into the reward SPK via
# reward_spk_p2pkh_mldsa). MUST differ between provider A and B.
export PROV_A_REWARD_PK_BYTE="${PROV_A_REWARD_PK_BYTE:-71}"
export PROV_B_REWARD_PK_BYTE="${PROV_B_REWARD_PK_BYTE:-72}"

# -----------------------------------------------------------------------------
# Readiness-gate tuning (seconds)
# -----------------------------------------------------------------------------
export GATE_TIMEOUT_SECS="${GATE_TIMEOUT_SECS:-180}"       # generic gate deadline
export GATE_DNS_TIMEOUT_SECS="${GATE_DNS_TIMEOUT_SECS:-300}" # dns_confirmed can span epochs
export GATE_POLL_SECS="${GATE_POLL_SECS:-2}"               # gate poll interval
export STOP_TIMEOUT_SECS="${STOP_TIMEOUT_SECS:-15}"        # stop_pid SIGTERM grace
export INCLUSION_TIMEOUT_SECS="${INCLUSION_TIMEOUT_SECS:-120}" # palw-submit --inclusion-timeout-secs

# =============================================================================
# Discovered-state slots — populated at run time into artifacts/state.env by
# state_set (do NOT edit by hand; listed here for documentation). load_env
# overlays state.env after this file, so these override the blanks below.
# =============================================================================
export DNS_BOND="${DNS_BOND:-}"           # validator stake-bond outpoint  txid:index
export PROV_A_BOND="${PROV_A_BOND:-}"     # provider A provider-bond outpoint txid:index
export PROV_B_BOND="${PROV_B_BOND:-}"     # provider B provider-bond outpoint txid:index
export AUD_C_BOND="${AUD_C_BOND:-}"       # auditor C provider-bond outpoint  txid:index
export PALW_BATCH_ID="${PALW_BATCH_ID:-}" # batch id (128hex) from batch-manifest
export DNS_ADDR="${DNS_ADDR:-}"           # validator/DNS funding address (misakadev:...)
export PROV_A_ADDR="${PROV_A_ADDR:-}"     # provider A funding address
export PROV_B_ADDR="${PROV_B_ADDR:-}"     # provider B funding address
export AUD_C_ADDR="${AUD_C_ADDR:-}"       # auditor C funding address
export PALW_MINE_ADDR="${PALW_MINE_ADDR:-}" # algo-4 miner payout address (mock mint)
